<!doctype html>
<html lang="en">
<head>
<title>PokeTranslate</title>
    <link rel="icon" href="/static/yt-ukraine.svg">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta content="PokeTranslate" property="og:title">
    <meta content="Translate text - Anonymously!" property="twitter:description">
    <meta charset="UTF-8">
    <meta http-equiv="Content-Security-Policy" content="script-src 'self' 'unsafe-inline'">
    <meta name="referrer" content="no-referrer">
    <link rel="manifest" href="/manifest.json">
    <link href="https://fonts.bunny.net/css?family=roboto:400,500,700&display=swap" rel="stylesheet">
    <link href="https://fonts.bunny.net/icon?family=Material+Icons" rel="stylesheet">
    
  <style>
   :root {
   --bg-body: #202124;
  --bg-surface: #292a2d;
  --bg-output: #303134;
  --border-color: #5f6368;
  --divider-subtle: #3c4043;
  --text-main: #e8eaed;
  --text-muted: #9aa0a6;
  --accent-blue: #8ab4f8
  --accent-pink: #ffabcc;
  --accent-hover: #aecbfa;
  --btn-hover-bg: rgba(255, 255, 255, 0.04);
  --btn-active-bg: rgba(255, 255, 255, 0.08);
  --shadow-elevation: 0 1px 3px 0 rgba(0,0,0,0.3), 0 4px 8px 3px rgba(0,0,0,0.15);
  
  --radius-card: 12px;
  --nav-height: 64px;
}

* { margin:0; padding:0; box-sizing:border-box; }

body {
  font-family: 'Roboto', sans-serif;
  background: var(--bg-body);
  color: var(--text-main);
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* Navbar */
header {
  background: var(--bg-body);
  height: var(--nav-height);
  display: flex;
  align-items: center;
  padding: 0 24px;
  border-bottom: 1px solid var(--divider-subtle);
  position: sticky;
  top: 0;
  z-index: 10;
}

header h1 {
  font-size: 22px;
  font-weight: 500;
  color: var(--text-muted);
  display: flex;
  align-items: center;
}

.site-logo {
  height: 32px;
  width: auto;
  margin-right: 12px;
  display: block;
}

header h1 span {
  color: var(--text-main);
}

/* Main Container */
main {
  flex: 1;
  width: 100%;
  max-width: 1360px;
  margin: 0 auto;
  padding: 32px 24px;
}

/* Card Styling */
.translate-card {
  background: var(--bg-surface);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-elevation);
  border: 1px solid var(--divider-subtle);
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

/* Language Toolbar */
.language-toolbar {
  display: flex;
  align-items: center;
  border-bottom: 1px solid var(--divider-subtle);
  min-height: 56px;
  padding: 8px 16px;
}

.lang-group {
  flex: 1;
  display: flex;
  align-items: center;
}

/* Clean Dropdown Tabs */
.select-wrapper {
  position: relative;
  display: inline-flex;
  align-items: center;
}

.select-wrapper select {
  appearance: none;
  background: transparent;
  border: none;
  font-family: inherit;
  font-size: 15px;
  font-weight: 500;
  color: var(--accent-pink);
  padding: 10px 32px 10px 16px;
  cursor: pointer;
  border-radius: 6px;
  transition: background 0.2s ease;
  outline: none;
}

.select-wrapper select option {
  background-color: var(--bg-surface);
  color: var(--text-main);
  font-weight: 400;
}

.select-wrapper select:hover,
.select-wrapper select:focus {
  background: var(--btn-hover-bg);
}

.select-wrapper::after {
  content: '▼';
  font-size: 10px;
  color: var(--accent-blue);
  position: absolute;
  right: 12px;
  pointer-events: none;
}

/* Swap Button */
.swap-btn {
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  color: var(--text-muted);
  text-decoration: none;
  transition: all 0.2s ease;
  margin: 0 16px;
  cursor: pointer;
  user-select: none;
}

.swap-btn:hover {
  background: var(--btn-hover-bg);
  color: var(--text-main);
}

.swap-btn:active {
  background: var(--btn-active-bg);
}

/* Input/Output Grid */
.editor-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  min-height: 250px;
}

.editor-panel {
  padding: 24px;
  display: flex;
  flex-direction: column;
}

.input-panel {
  background: var(--bg-surface);
  border-right: 1px solid var(--divider-subtle);
}

.output-panel {
  background: var(--bg-output);
}

.editor-panel textarea {
  width: 100%;
  border: none;
  resize: none;
  background: transparent;
  font-family: inherit;
  font-size: 24px;
  line-height: 1.4;
  color: var(--text-main);
  outline: none;
  min-height: 180px;
  overflow-y: auto;
}

.editor-panel textarea::placeholder {
  color: var(--text-muted);
}

 .card-footer {
  padding: 16px 24px;
  display: flex;
  justify-content: flex-end;
  background: var(--bg-surface);
  border-top: 1px solid var(--divider-subtle);
  display: none; /* Hidden by default, JS auto-translates */
}

.translate-submit {
  background: var(--accent-blue);
  color: #171717;
  border: none;
  padding: 10px 24px;
  border-radius: 4px;
  font-weight: 500;
  font-size: 14px;
  cursor: pointer;
  transition: background 0.2s;
}

.translate-submit:hover {
  background: var(--accent-hover);
}

/* Footer/Credits */
.site-footer {
  text-align: center;
  padding: 24px;
  color: var(--text-muted);
  font-size: 0.85rem;
  margin-top: auto;
}

/* Responsive */
@media (max-width: 800px) {
  main { padding: 16px; }
  
  .editor-grid {
    grid-template-columns: 1fr;
    grid-template-rows: auto auto;
  }

  .input-panel {
    border-right: none;
    border-bottom: 1px solid var(--divider-subtle);
  }
  
  .language-toolbar {
    flex-wrap: wrap;
    justify-content: center;
    padding: 12px;
  }
  
  .lang-group {
    flex: initial;
    width: calc(50% - 40px);
    justify-content: center;
  }
  
  .editor-panel textarea { font-size: 20px; }
}
  </style>

  <noscript>
    <style>
      .card-footer { display: flex !important; }
    </style>
  </noscript>
</head>
<body>

  <header>
    <h1>
       <img src="/static/logo-poke.svg" alt="Poke LOGO" class="site-logo">
     </h1>
  </header>

  <main>
    <form action="/translate" method="GET" class="translate-card">
      
      <div class="language-toolbar">
        <div class="lang-group" style="justify-content: flex-start;">
          <div class="select-wrapper">
            <select name="from_language" id="from_language">
              <% languageOptions.forEach(lang => { %>
                <option value="<%= lang.code %>" <%= lang.code === (from_language||'auto')?'selected':''%>>
                  <%= lang.name %>
                </option>
              <% }); %>
            </select>
          </div>
        </div>

        <a href="?from_language=<%= to_language %>&to_language=<%= from_language %>&input=<%= encodeURIComponent(text) %>"
           id="swapBtn"
           class="material-icons swap-btn"
           title="Swap languages">
           swap_horiz
        </a>

        <div class="lang-group" style="justify-content: flex-end;">
          <div class="select-wrapper">
             <select name="to_language" id="to_language">
              <% languageOptions.slice(1).forEach(lang => { %>
                <option value="<%= lang.code %>" <%= lang.code===to_language?'selected':''%>>
                  <%= lang.name %>
                </option>
              <% }); %>
            </select>
          </div>
        </div>
      </div>

      <div class="editor-grid">
        <div class="editor-panel input-panel">
          <textarea id="input" name="input" placeholder="Enter text" spellcheck="false"><%= text %></textarea>
        </div>
        
        <div class="editor-panel output-panel">
          <textarea id="output" readonly placeholder="Translation"><%= translation %></textarea>
        </div>
      </div>

      <div class="card-footer">
        <button type="submit" class="translate-submit">Translate</button>
      </div>
      
    </form>
  </main>
  
  <div class="site-footer">
    <p>&copy; 2021-2026 PokeTranslate </p>
  </div>

  <script>
  (function() {
      'use strict';

      const DOM = {
          swapBtn: document.getElementById('swapBtn'),
          from: document.getElementById('from_language'),
          to: document.getElementById('to_language'),
          input: document.getElementById('input'),
          output: document.getElementById('output'),
          textareas: document.querySelectorAll('textarea')
      };

      if (!DOM.from || !DOM.to || !DOM.input || !DOM.output) return;

      // Local Storage Setup
      const STORAGE_KEYS = { FROM: 'poke_trans_from', TO: 'poke_trans_to' };

      const loadPreferences = () => {
          const savedFrom = localStorage.getItem(STORAGE_KEYS.FROM);
          const savedTo = localStorage.getItem(STORAGE_KEYS.TO);
          if (savedFrom) DOM.from.value = savedFrom;
          if (savedTo) DOM.to.value = savedTo;
      };

      const savePreferences = () => {
          localStorage.setItem(STORAGE_KEYS.FROM, DOM.from.value);
          localStorage.setItem(STORAGE_KEYS.TO, DOM.to.value);
      };

      // Debounce utility to prevent spamming translation requests
      const debounce = (func, delay) => {
          let timeoutId;
          return (...args) => {
              clearTimeout(timeoutId);
              timeoutId = setTimeout(() => func(...args), delay);
          };
      };

      // Auto-resize logic
      const resize = (el) => {
          if (!el) return;
          el.style.height = 'auto';
          el.style.height = `${el.scrollHeight}px`;
      };

      DOM.textareas.forEach(el => {
          el.addEventListener('input', () => resize(el));
          resize(el);
      });

      // Async Translation Fetch
      const fetchTranslation = async () => {
          const text = DOM.input.value.trim();
          
          if (!text) {
              DOM.output.value = "";
              resize(DOM.output);
              return;
          }

          const queryParams = new URLSearchParams({
              from_language: DOM.from.value,
              to_language: DOM.to.value,
              input: text
          });

          try {
              const response = await fetch(`/translate?${queryParams}`);
              if (!response.ok) throw new Error('Network response failed');
              
              const html = await response.text();
              const doc = new DOMParser().parseFromString(html, 'text/html');
              const newOut = doc.getElementById('output');
              
              if (newOut) {
                  DOM.output.value = newOut.value;
                  resize(DOM.output);
              }
          } catch (error) {
              console.error("Translation Error:", error);
          }
      };

      const debouncedTranslate = debounce(fetchTranslation, 300);

      // Event Listeners
      DOM.from.addEventListener('change', () => { savePreferences(); fetchTranslation(); });
      DOM.to.addEventListener('change', () => { savePreferences(); fetchTranslation(); });
      DOM.input.addEventListener('input', debouncedTranslate);

      if (DOM.swapBtn) {
          DOM.swapBtn.addEventListener('click', (e) => {
              e.preventDefault();
              [DOM.from.value, DOM.to.value] = [DOM.to.value, DOM.from.value];
              [DOM.input.value, DOM.output.value] = [DOM.output.value, DOM.input.value];
              
              savePreferences();
              resize(DOM.input);
              resize(DOM.output);
              fetchTranslation();
          });
      }

      // Init
      loadPreferences();
  })();
  </script>
</body>
</html>