<!doctype html>
<html lang="en">
<head>
    <title>PokeTranslate</title>
    <link rel="icon" href="/static/yt-ukraine.svg">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta content="PokeTranslate" property="og:title">
    <meta content="Translate text - Anonymously!" property="twitter:description">
    <meta charset="UTF-8">
    <meta http-equiv="Content-Security-Policy" content="script-src 'self' 'unsafe-inline'">
    <meta name="referrer" content="no-referrer">
    <link rel="manifest" href="/manifest.json">
    <link href="https://fonts.bunny.net/css?family=roboto:400,500,700&display=swap" rel="stylesheet">
    <link href="https://fonts.bunny.net/icon?family=Material+Icons" rel="stylesheet">
    
    <style>
    :root {
         --bg-body: #202124;
        --bg-surface: #202124; 
        --bg-output: #303134;
        --bg-hover: rgba(255, 255, 255, 0.08);
        --bg-active: rgba(255, 255, 255, 0.12);
        --border-color: #5f6368;
        --divider-subtle: #3c4043;
        
        --text-main: #e8eaed;
        --text-muted: #9aa0a6;
        
         --accent-pink: #ffabcc;
        --accent-hover: #f88ab4;
        --accent-bg: rgba(255, 171, 204, 0.15); 
        
        --radius-card: 12px;
        --nav-height: 64px;
    }

    * { margin:0; padding:0; box-sizing:border-box; font-family: 'Roboto', sans-serif; }
    .symbol-of-tolerance {  margin-top:1em;  height:.25em;  background:linear-gradient(90deg,#ea392f 0% 9.091%,#f28917 9.091% 18.182%,#eecb12 18.182% 27.273%,#78b82a 27.273% 36.364%,#4375ca 36.364% 45.455%,#c346e3 45.455% 54.545%,#7bcce5 54.545% 63.636%,#eaeaea 63.636% 72.727%,#f4aec8 72.727% 81.818%,#000 81.818% 90.909%,#945516 90.909% 100%)}
    body {
        background: var(--bg-body);
        color: var(--text-main);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
    }

    /* Navbar */
    header {
        height: var(--nav-height);
        display: flex;
        align-items: center;
        padding: 0 24px;
        border-bottom: 1px solid var(--divider-subtle);
        background: var(--bg-body);
    }
    .site-logo { height: 32px; width: auto; margin-right: 12px; display: block; }
    header h1 { font-size: 22px; font-weight: 500; color: var(--text-main); display: flex; align-items: center; }

    /* Main App Layout */
    main {
        flex: 1;
        width: 100%;
        max-width: 1400px;
        margin: 0 auto;
        padding: 32px 24px;
        position: relative;
    }

    /* Translation Card Area */
    .translate-container {
        display: flex;
        flex-direction: column;
        border: 1px solid var(--divider-subtle);
        border-radius: var(--radius-card);
        background: var(--bg-surface);
        overflow: hidden;
    }

    /* JavaScript Toolbar (Tabs) */
    .toolbar {
        display: flex;
        align-items: center;
        border-bottom: 1px solid var(--divider-subtle);
        min-height: 48px;
        padding: 0 8px;
    }

    .lang-tabs-group {
        display: flex;
        align-items: center;
        flex: 1;
        overflow-x: auto;
        scrollbar-width: none;
    }
    .lang-tabs-group::-webkit-scrollbar { display: none; }

    .tab-btn {
        background: transparent;
        border: none;
        color: var(--text-muted);
        font-size: 14px;
        font-weight: 500;
        padding: 0 16px;
        height: 48px;
        cursor: pointer;
        position: relative;
        white-space: nowrap;
        border-radius: 4px;
        transition: background 0.2s, color 0.2s;
    }
    .tab-btn:hover { background: var(--bg-hover); color: var(--text-main); }
    
    .tab-btn.active { color: var(--accent-pink); }
    .tab-btn.active::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: var(--accent-pink);
        border-radius: 3px 3px 0 0;
    }

    .dropdown-btn {
        background: transparent; border: none; color: var(--text-muted);
        height: 40px; width: 40px; display: flex; align-items: center;
        justify-content: center; border-radius: 50%; cursor: pointer; margin-left: 4px;
    }
    .dropdown-btn:hover { background: var(--bg-hover); color: var(--text-main); }

    .swap-btn {
        background: transparent; border: none; color: var(--text-muted);
        height: 40px; width: 40px; display: flex; align-items: center; text-decoration: none;
        justify-content: center; border-radius: 50%; cursor: pointer;
        margin: 0 12px; transition: transform 0.2s;
    }
    .swap-btn:hover { background: var(--bg-hover); color: var(--text-main); }

    /* Input/Output Grids */
    .editor-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        min-height: 200px;
    }

    .editor-panel {
        padding: 16px 24px;
        display: flex;
        flex-direction: column;
    }
    .input-panel { border-right: 1px solid var(--divider-subtle); }
    .output-panel { background: var(--bg-output); }

    textarea {
        width: 100%;
        border: none;
        resize: none;
        background: transparent;
        font-size: 24px;
        line-height: 1.4;
        color: var(--text-main);
        outline: none;
        flex: 1;
        min-height: 150px;
    }
    textarea::placeholder { color: var(--text-muted); }

    /* Modal Overlay */
    .lang-modal-overlay {
        position: absolute; top: 0; left: 0; right: 0; bottom: 0;
        background: var(--bg-body); z-index: 100;
        display: none; flex-direction: column;
        border-radius: var(--radius-card); overflow: hidden;
    }
    .lang-modal-overlay.active { display: flex; }

    .modal-header {
        display: flex; align-items: center; padding: 8px 16px;
        border-bottom: 1px solid var(--divider-subtle);
    }
    
    .modal-back {
        background: none; border: none; color: var(--text-muted);
        width: 48px; height: 48px; border-radius: 50%;
        cursor: pointer; margin-right: 8px;
    }
    .modal-back:hover { background: var(--bg-hover); color: var(--text-main); }

    .search-input {
        background: transparent; border: none; color: var(--text-main);
        font-size: 16px; flex: 1; outline: none;
    }

    .modal-body { padding: 16px 24px; overflow-y: auto; flex: 1; }

    .lang-grid {
        display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 4px;
    }

    .lang-item {
        background: transparent; border: none; color: var(--text-main);
        font-size: 14px; text-align: left; padding: 10px 16px;
        border-radius: 6px; cursor: pointer; display: flex; align-items: center;
    }
    .lang-item:hover { background: var(--bg-hover); }
    .lang-item.selected { background: var(--accent-bg); color: var(--accent-pink); font-weight: 500; }
    .lang-item .check-icon { margin-right: 12px; font-size: 18px; opacity: 0; }
    .lang-item.selected .check-icon { opacity: 1; }
    
    /* Sparkle Icon for Detect Language */
    .sparkle-icon { font-size: 16px; margin-left: 6px; color: var(--text-muted); }
    .lang-item.selected .sparkle-icon { color: var(--accent-pink); }

    /* ---------------------------------
       No-JS Fallback Base Styling
       --------------------------------- */
    .no-js-fallback { display: none; } /* Hidden by default when JS is active */
    .fallback-controls { display: none; }
    
    .translate-submit-btn {
        background: var(--accent-pink); color: #171717;
        border: none; padding: 10px 24px; border-radius: 4px;
        font-weight: 500; font-size: 14px; cursor: pointer; transition: background 0.2s;
    }
    .translate-submit-btn:hover { background: var(--accent-hover); }

    @media (max-width: 800px) {
        .editor-grid { grid-template-columns: 1fr; }
        .input-panel { border-right: none; border-bottom: 1px solid var(--divider-subtle); }
    }
    </style>

    <noscript>
        <style>
            .toolbar { display: none !important; }
            .lang-modal-overlay { display: none !important; }
            
            .no-js-fallback {
                display: flex;
                align-items: center;
                min-height: 48px;
                padding: 0 16px;
                border-bottom: 1px solid var(--divider-subtle);
                background: var(--bg-surface);
            }

            .select-wrapper {
                position: relative;
                display: flex;
                align-items: center;
                flex: 1;
            }

            .no-js-select {
                appearance: none;
                background: transparent;
                color: var(--accent-pink);
                border: none;
                font-size: 14px;
                font-weight: 500;
                padding: 10px 32px 10px 12px;
                border-radius: 4px;
                cursor: pointer;
                outline: none;
                width: 100%;
                transition: background 0.2s;
            }
            .no-js-select option { background: var(--bg-surface); color: var(--text-main); font-weight: normal; }
            .no-js-select:hover { background: var(--bg-hover); }
            
            .select-arrow {
                position: absolute;
                right: 8px;
                pointer-events: none;
                font-size: 18px;
                color: var(--text-muted);
            }

            .fallback-controls {
                display: flex !important;
                justify-content: flex-end;
                padding: 16px 24px;
                background: var(--bg-surface);
                border-top: 1px solid var(--divider-subtle);
            }
        </style>
    </noscript>
</head>
<body>

    <header>
        <h1>
            <img src="/static/logo-poke.svg" alt="Poke LOGO" class="site-logo">
         </h1>
    </header>

    <main>
        <form action="/translate" method="GET" class="translate-container">
            
            <div class="toolbar">
                <div class="lang-tabs-group" id="tabs_from"></div>
                <button type="button" class="dropdown-btn material-icons" onclick="openModal('from')">expand_more</button>

                <button type="button" id="swapBtn" class="swap-btn material-icons" title="Swap languages">swap_horiz</button>

                <div class="lang-tabs-group" id="tabs_to" style="justify-content: flex-end;"></div>
                <button type="button" class="dropdown-btn material-icons" onclick="openModal('to')">expand_more</button>
            </div>

            <div class="no-js-fallback">
                <div class="select-wrapper">
                    <select name="from_language" id="native_from" class="no-js-select">
                        <% languageOptions.forEach(lang => { %>
                            <option value="<%= lang.code %>" <%= (typeof from_language !== 'undefined' ? from_language : 'auto') === lang.code ? 'selected' : '' %>>
                                <%= lang.name %>
                            </option>
                        <% }); %>
                    </select>
                    <span class="material-icons select-arrow">expand_more</span>
                </div>

                <a href="?from_language=<%= typeof to_language !== 'undefined' ? to_language : 'en' %>&to_language=<%= typeof from_language !== 'undefined' ? from_language : 'auto' %>&input=<%= encodeURIComponent(typeof text !== 'undefined' ? text : '') %>" 
                   class="swap-btn material-icons" 
                   title="Swap languages">
                   swap_horiz
                </a>

                <div class="select-wrapper">
                    <select name="to_language" id="native_to" class="no-js-select">
                        <% languageOptions.forEach(lang => { %>
                            <% if(lang.code !== 'auto') { %>
                                <option value="<%= lang.code %>" <%= (typeof to_language !== 'undefined' ? to_language : 'en') === lang.code ? 'selected' : '' %>>
                                    <%= lang.name %>
                                </option>
                            <% } %>
                        <% }); %>
                    </select>
                    <span class="material-icons select-arrow">expand_more</span>
                </div>
            </div>

            <div class="editor-grid">
                <div class="editor-panel input-panel">
                    <textarea id="input" name="input" placeholder="Enter text" spellcheck="false"><%= (typeof text !== 'undefined' ? text : '') %></textarea>
                </div>
                <div class="editor-panel output-panel">
                    <textarea id="output" readonly placeholder="Translation"><%= (typeof translation !== 'undefined' ? translation : '') %></textarea>
                </div>
            </div>

            <div class="fallback-controls">
                <button type="submit" class="translate-submit-btn">Translate</button>
            </div>

            <div class="lang-modal-overlay" id="langModal">
                <div class="modal-header">
                    <button type="button" class="modal-back material-icons" onclick="closeModal()">arrow_back</button>
                    <input type="text" class="search-input" id="langSearch" placeholder="Search languages">
                </div>
                <div class="modal-body">
                    <div class="lang-grid" id="modalLangGrid"></div>
                </div>
            </div>

        </form>
    </main>
  
    <div style="text-align: center; padding: 24px; color: var(--text-muted); font-size: 0.85rem;">
        <p>&copy; 2021-2026 PokeTranslate</p><br>
        <p>Backend by SimplyTranslate!</p>
    </div>
           <div class="symbol-of-tolerance" role="img"></div>
           
    <script>
        const ALL_LANGS = <%- JSON.stringify(languageOptions) %>;
    </script>

    <script>
    // @license magnet:?xt=urn:btih:1f739d935676111cfff4b4693e3816e664797050&dn=gpl-3.0.txt GPL-3.0-or-later
    (function() {
        'use strict';

        const DOM = {
            nativeFrom: document.getElementById('native_from'),
            nativeTo: document.getElementById('native_to'),
            tabsFrom: document.getElementById('tabs_from'),
            tabsTo: document.getElementById('tabs_to'),
            input: document.getElementById('input'),
            output: document.getElementById('output'),
            swapBtn: document.getElementById('swapBtn'),
            modal: document.getElementById('langModal'),
            modalGrid: document.getElementById('modalLangGrid'),
            searchInput: document.getElementById('langSearch'),
            textareas: document.querySelectorAll('textarea')
        };

        // State Tracking (Pulling initial state from the native selects)
        let state = {
            currentFrom: DOM.nativeFrom.value,
            currentTo: DOM.nativeTo.value,
            recentFrom: [],
            recentTo: [],
            modalMode: null 
        };

        const STORAGE_KEYS = { FROM: 'poke_trans_rec_from', TO: 'poke_trans_rec_to' };
        
        const getLangName = (code) => {
            const l = ALL_LANGS.find(x => x.code === code);
            return l ? l.name : code;
        };

        const initRecents = () => {
            try {
                let sF = JSON.parse(localStorage.getItem(STORAGE_KEYS.FROM));
                let sT = JSON.parse(localStorage.getItem(STORAGE_KEYS.TO));
                
                state.recentFrom = Array.isArray(sF) && sF.length ? sF : ['en', 'es', 'fr'];
                state.recentTo = Array.isArray(sT) && sT.length ? sT : ['en', 'es', 'fr'];
                
                state.recentFrom = state.recentFrom.filter(c => c !== 'auto');
                state.recentTo = state.recentTo.filter(c => c !== 'auto');
            } catch(e) {
                state.recentFrom = ['en', 'es', 'fr'];
                state.recentTo = ['en', 'es', 'fr'];
            }
        };

        const saveRecents = () => {
            localStorage.setItem(STORAGE_KEYS.FROM, JSON.stringify(state.recentFrom));
            localStorage.setItem(STORAGE_KEYS.TO, JSON.stringify(state.recentTo));
        };

        const addRecent = (type, code) => {
            if(code === 'auto') return; 
            let arr = type === 'from' ? state.recentFrom : state.recentTo;
            arr = arr.filter(c => c !== code);
            arr.unshift(code);
            if(arr.length > 3) arr.pop();
            
            if(type === 'from') state.recentFrom = arr;
            else state.recentTo = arr;
            saveRecents();
        };

        const createTab = (code, isActive, type) => {
            const btn = document.createElement('button');
            btn.type = 'button';
            btn.className = `tab-btn ${isActive ? 'active' : ''}`;
            btn.textContent = getLangName(code);
            btn.onclick = () => selectLanguage(type, code);
            return btn;
        };

        const renderTabs = () => {
            DOM.tabsFrom.innerHTML = '';
            DOM.tabsTo.innerHTML = '';

            // Source Tabs
            DOM.tabsFrom.appendChild(createTab('auto', state.currentFrom === 'auto', 'from'));
            state.recentFrom.forEach(code => {
                DOM.tabsFrom.appendChild(createTab(code, state.currentFrom === code, 'from'));
            });

            // Target Tabs
            state.recentTo.forEach(code => {
                DOM.tabsTo.appendChild(createTab(code, state.currentTo === code, 'to'));
            });
            
            // Keep native selects synced for form submission functionality
            DOM.nativeFrom.value = state.currentFrom;
            DOM.nativeTo.value = state.currentTo;
        };

        const selectLanguage = (type, code) => {
            if(type === 'from') {
                state.currentFrom = code;
                addRecent('from', code);
            } else {
                state.currentTo = code;
                addRecent('to', code);
            }
            
            renderTabs();
            closeModal();
            fetchTranslation(); 
        };

        window.openModal = (type) => {
            state.modalMode = type;
            DOM.modal.classList.add('active');
            DOM.searchInput.value = '';
            renderModalGrid('');
            DOM.searchInput.focus();
        };

        window.closeModal = () => {
            DOM.modal.classList.remove('active');
        };

        const renderModalGrid = (filterText) => {
            DOM.modalGrid.innerHTML = '';
            const lowerFilter = filterText.toLowerCase();
            const currentSelected = state.modalMode === 'from' ? state.currentFrom : state.currentTo;

            ALL_LANGS.forEach(lang => {
                if(state.modalMode === 'to' && lang.code === 'auto') return;

                if(lang.name.toLowerCase().includes(lowerFilter)) {
                    const isSelected = lang.code === currentSelected;
                    const btn = document.createElement('button');
                    btn.type = 'button';
                    btn.className = `lang-item ${isSelected ? 'selected' : ''}`;
                    
                    const icon = document.createElement('span');
                    icon.className = 'material-icons check-icon';
                    icon.textContent = 'check';
                    btn.appendChild(icon);
                    
                    const textNode = document.createTextNode(lang.name);
                    btn.appendChild(textNode);
                    
                    // Add Sparkle Icon if it's "Detect Language"
                    if(lang.code === 'auto') {
                        const sparkle = document.createElement('span');
                        sparkle.className = 'material-icons sparkle-icon';
                        sparkle.textContent = 'auto_awesome';
                        btn.appendChild(sparkle);
                    }
                    
                    btn.onclick = () => selectLanguage(state.modalMode, lang.code);
                    DOM.modalGrid.appendChild(btn);
                }
            });
        };

        DOM.searchInput.addEventListener('input', (e) => renderModalGrid(e.target.value));

        DOM.swapBtn.addEventListener('click', (e) => {
            e.preventDefault(); // Prevent the fallback anchor link from firing in JS mode
            let safeFrom = state.currentFrom === 'auto' ? 'en' : state.currentFrom;
            
            const temp = safeFrom;
            safeFrom = state.currentTo;
            state.currentTo = temp;
            state.currentFrom = safeFrom;
            
            addRecent('from', state.currentFrom);
            addRecent('to', state.currentTo);
            
            [DOM.input.value, DOM.output.value] = [DOM.output.value, DOM.input.value];
            
            renderTabs();
            resizeAllTextareas();
            fetchTranslation();
        });

        const resize = (el) => {
            if (!el) return;
            el.style.height = 'auto';
            el.style.height = `${Math.max(150, el.scrollHeight)}px`;
        };
        const resizeAllTextareas = () => DOM.textareas.forEach(resize);

        DOM.textareas.forEach(el => el.addEventListener('input', () => resize(el)));

        const debounce = (func, delay) => {
            let timeoutId;
            return (...args) => { clearTimeout(timeoutId); timeoutId = setTimeout(() => func(...args), delay); };
        };

        const fetchTranslation = async () => {
            const text = DOM.input.value.trim();
            if (!text) {
                DOM.output.value = "";
                resize(DOM.output);
                return;
            }

            const queryParams = new URLSearchParams({
                from_language: state.currentFrom,
                to_language: state.currentTo,
                input: text
            });

            try {
                const response = await fetch(`/translate?${queryParams}`);
                if (!response.ok) throw new Error('Network response failed');
                
                const html = await response.text();
                const doc = new DOMParser().parseFromString(html, 'text/html');
                const newOut = doc.getElementById('output');
                
                if (newOut) {
                    DOM.output.value = newOut.value;
                    resize(DOM.output);
                }
            } catch (error) {
                console.error("Translation Error:", error);
            }
        };

        const debouncedTranslate = debounce(fetchTranslation, 300);
        DOM.input.addEventListener('input', debouncedTranslate);

        // Run Setup
        initRecents();
        if(state.currentFrom && state.currentFrom !== 'auto') addRecent('from', state.currentFrom);
        if(state.currentTo) addRecent('to', state.currentTo);
        renderTabs();
        resizeAllTextareas();

    })();
    // @license-end
    </script>
</body>
</html>