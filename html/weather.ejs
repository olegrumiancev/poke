<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover, maximum-scale=1, user-scalable=no" />
<title>PokeWeather</title>
<meta name="theme-color" content="#0f172a" />
<meta name="color-scheme" content="dark" />
<meta content="PokeWeather" property="og:title">
<meta content="View Weather info :3c" property="twitter:description">
<meta content="summary_large_image" name="twitter:card">

<!-- Fonts -->
<link rel="preconnect" href="https://fonts.bunny.net">
<link href="https://fonts.bunny.net/css?family=inter:400,500,600,700&display=swap" rel="stylesheet" />

<style>
:root {
  --bg-dark: #0f172a;
  --bg-card: rgba(30, 41, 59, 0.7);
  --bg-card-hover: rgba(51, 65, 85, 0.8);
  --text-main: #f8fafc;
  --text-muted: #94a3b8;
  --accent: #38bdf8;
  --accent-glow: rgba(56, 189, 248, 0.5);
  --border: rgba(255, 255, 255, 0.1);
  --glass: blur(12px);
  --radius: 24px;
}

* { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
html, body { height: 100%; margin: 0; overflow-x: hidden; }

body {
  font-family: 'Inter', system-ui, -apple-system, sans-serif;
  background-color: var(--bg-dark);
  color: var(--text-main);
  transition: background 1s ease;
  overflow-y: auto;
}

/* Dynamic Backgrounds based on existing JS classes */
body.is-day { background: linear-gradient(180deg, #0ea5e9 0%, #0f172a 100%); }
body.is-night { background: linear-gradient(180deg, #0f172a 0%, #1e1b4b 100%); }
body.weather-rain { background: linear-gradient(180deg, #1e293b 0%, #0f172a 100%); }
body.weather-storm { background: linear-gradient(180deg, #1e1b4b 0%, #020617 100%); }

/* Background Canvas */
#bg-canvas {
  position: fixed;
  top: 0; left: 0;
  width: 100%; height: 100%;
  z-index: -1;
  pointer-events: none;
}

/* Layout */
.app-container {
  max-width: 480px;
  margin: 0 auto;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  position: relative;
  padding-bottom: 40px;
}

/* Header */
header {
  position: sticky;
  top: 0;
  z-index: 100;
  padding: 16px;
  background: rgba(15, 23, 42, 0.8);
  backdrop-filter: var(--glass);
  border-bottom: 1px solid var(--border);
}

.top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12px;
}

.brand {
  display: flex;
  align-items: center;
  gap: 10px;
}

.chip {
  background: rgba(255,255,255,0.1);
  padding: 6px 12px;
  border-radius: 20px;
  font-size: 13px;
  font-weight: 600;
  backdrop-filter: blur(4px);
  border: 1px solid var(--border);
  max-width: 200px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.controls {
  display: flex;
  gap: 8px;
}

button, .btn {
  background: rgba(255,255,255,0.1);
  border: 1px solid var(--border);
  color: var(--text-main);
  height: 36px;
  width: 36px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.2s;
  font-size: 16px;
}

button:hover, .btn:hover {
  background: rgba(255,255,255,0.2);
  transform: scale(1.05);
}

button:active { transform: scale(0.95); }

/* Search */
.search-container {
  position: relative;
  margin-top: 8px;
}

.search-form {
  display: flex;
  gap: 8px;
  background: rgba(0,0,0,0.2);
  padding: 4px;
  border-radius: 16px;
  border: 1px solid var(--border);
}

.search-input {
  flex: 1;
  background: transparent;
  border: none;
  color: white;
  padding: 8px 12px;
  font-size: 14px;
  outline: none;
}

.search-btn {
  width: 32px;
  height: 32px;
  border-radius: 12px;
  background: var(--accent);
  color: #000;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: bold;
}

.suggest {
  position: absolute;
  top: 100%;
  left: 0; right: 0;
  background: #1e293b;
  border: 1px solid var(--border);
  border-radius: 16px;
  margin-top: 8px;
  overflow: hidden;
  z-index: 200;
  display: none;
  box-shadow: 0 10px 30px rgba(0,0,0,0.5);
}

.suggest button {
  width: 100%;
  height: auto;
  padding: 12px 16px;
  border-radius: 0;
  border-bottom: 1px solid var(--border);
  justify-content: flex-start;
  font-size: 13px;
  background: transparent;
}

.suggest button:last-child { border-bottom: none; }
.suggest button:hover { background: rgba(255,255,255,0.05); }

/* Main Content */
main {
  padding: 16px;
  display: flex;
  flex-direction: column;
  gap: 16px;
  flex: 1;
}

/* Current Weather Card */
.current-card {
  background: var(--bg-card);
  backdrop-filter: var(--glass);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 24px;
  position: relative;
  overflow: hidden;
  min-height: 320px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  box-shadow: 0 8px 32px rgba(0,0,0,0.2);
}

.current-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  position: relative;
  z-index: 2;
}

.temp-display {
  font-size: 64px;
  font-weight: 700;
  line-height: 1;
  letter-spacing: -2px;
  background: linear-gradient(180deg, #fff, #cbd5e1);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.weather-icon-large {
  font-size: 64px;
  filter: drop-shadow(0 4px 12px rgba(0,0,0,0.3));
}

.weather-desc {
  font-size: 18px;
  color: var(--text-muted);
  font-weight: 500;
  margin-top: 4px;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
  margin-top: 24px;
  position: relative;
  z-index: 2;
}

.stat-box {
  background: rgba(255,255,255,0.05);
  padding: 12px;
  border-radius: 16px;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.stat-label {
  font-size: 12px;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.stat-value {
  font-size: 16px;
  font-weight: 600;
}

/* Effects Container */
#effects-container {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 1;
  overflow: hidden;
}

/* Rain/Snow Effects */
.effect-rain {
  position: absolute;
  width: 1px;
  height: 20px;
  background: rgba(255,255,255,0.4);
  animation: rain-drop 0.5s linear infinite;
}
.effect-snow {
  position: absolute;
  width: 4px;
  height: 4px;
  background: #fff;
  border-radius: 50%;
  animation: snow-fall 3s linear infinite;
  filter: blur(1px);
}

@keyframes rain-drop {
  0% { transform: translateY(-20px); opacity: 0; }
  10% { opacity: 1; }
  100% { transform: translateY(400px); opacity: 0; }
}
@keyframes snow-fall {
  0% { transform: translateY(-10px) translateX(0); opacity: 0.8; }
  100% { transform: translateY(400px) translateX(20px); opacity: 0; }
}

/* Hourly & Daily */
.panel-card {
  background: var(--bg-card);
  backdrop-filter: var(--glass);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 20px;
}

.section-title {
  font-size: 14px;
  color: var(--text-muted);
  margin: 0 0 16px 0;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 1px;
}

.scroll-x {
  display: flex;
  gap: 12px;
  overflow-x: auto;
  padding-bottom: 8px;
  scrollbar-width: none;
}
.scroll-x::-webkit-scrollbar { display: none; }

.hour-item {
  min-width: 60px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  padding: 8px;
  border-radius: 12px;
  background: rgba(255,255,255,0.03);
}

.hour-time { font-size: 12px; color: var(--text-muted); }
.hour-icon { font-size: 20px; }
.hour-temp { font-size: 14px; font-weight: 600; }

canvas {
  width: 100%;
  height: 100px;
  margin-top: 10px;
  filter: drop-shadow(0 2px 4px rgba(0,0,0,0.2));
}

/* Daily List */
.day-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 0;
  border-bottom: 1px solid var(--border);
}
.day-row:last-child { border-bottom: none; }

.day-info {
  display: flex;
  align-items: center;
  gap: 12px;
  flex: 1;
}
.day-icon { font-size: 24px; }
.day-name { font-size: 14px; font-weight: 500; }
.day-desc { font-size: 12px; color: var(--text-muted); display: none; }

.day-temps {
  display: flex;
  gap: 12px;
  font-size: 14px;
  font-weight: 600;
}
.temp-high { color: var(--text-main); }
.temp-low { color: var(--text-muted); }

@media (min-width: 600px) {
  .day-desc { display: block; }
}

/* Footer */
footer {
  text-align: center;
  padding: 20px;
  font-size: 12px;
  color: var(--text-muted);
  opacity: 0.6;
}
footer a { color: var(--accent); text-decoration: none; }

.loading { opacity: 0.5; pointer-events: none; filter: blur(2px); }
.hidden { display: none !important; }
</style>
</head>
<body>

<!-- Background Animation Canvas -->
<canvas id="bg-canvas"></canvas>

<div class="app-container">
  <header>
    <div class="top">
      <div class="brand">
        <div class="chip" id="locChip">Loading...</div>
      </div>
      <div class="controls">
        <button id="btnUnits" title="Toggle Units">°C</button>
        <button id="btnTheme" title="Toggle Theme">🌗</button>
        <a class="btn" href="#" id="btnShare" title="Share">🔗</a>
      </div>
    </div>
    
    <div class="search-container">
      <form class="search-form" id="searchForm" role="search">
        <input id="q" name="q" class="search-input" type="search" placeholder="Search city..." autocomplete="off" />
        <input type="hidden" name="units" id="unitsHidden" value="metric"/>
        <button id="btnSearch" class="search-btn" type="submit">🔍</button>
        <button id="btnGeo" type="button" title="My Location">📍</button>
      </form>
      <div id="suggest" class="suggest"></div>
    </div>
  </header>

  <main>
    <!-- Current Weather -->
    <section class="current-card" id="now">
      <div id="effects-container"></div>
      
      <div class="current-top">
        <div>
          <div class="temp-display" id="currTemp">--°</div>
          <div class="weather-desc" id="currDesc">Loading</div>
        </div>
        <div class="weather-icon-large" id="currIcon">☁️</div>
      </div>

      <div class="stats-grid">
        <div class="stat-box">
          <span class="stat-label">Feels Like</span>
          <span class="stat-value" id="currFeels">--°</span>
        </div>
        <div class="stat-box">
          <span class="stat-label">Wind</span>
          <span class="stat-value" id="currWind">--</span>
        </div>
        <div class="stat-box">
          <span class="stat-label">Humidity</span>
          <span class="stat-value" id="currHum">--%</span>
        </div>
        <div class="stat-box">
          <span class="stat-label">Pressure</span>
          <span class="stat-value" id="currPress">--</span>
        </div>
        <div class="stat-box">
          <span class="stat-label">Sunrise</span>
          <span class="stat-value" id="sunrise">--:--</span>
        </div>
        <div class="stat-box">
          <span class="stat-label">UV Index</span>
          <span class="stat-value" id="uv">--</span>
        </div>
      </div>
    </section>

    <!-- Hourly Forecast -->
    <section class="panel-card" id="hourly">
      <h3 class="section-title">Next 24 Hours</h3>
      <div id="hours" class="scroll-x"></div>
      <canvas id="chart"></canvas>
    </section>

    <!-- Daily Forecast -->
    <section class="panel-card" id="daily">
      <h3 class="section-title">7-Day Forecast</h3>
      <div id="days"></div>
    </section>
  </main>

  <footer>
    <p>PokeWeather Project<br>
    <a href="https://open-meteo.com/">Data by Open-Meteo</a></p>
  </footer>
</div>

<!-- Original Script Logic (Preserved) -->
<script>
window.__SSR__ = {}; 
window.__SSR_ROUTE__ = "/weather";
</script>
<script>
const $=s=>document.querySelector(s);const $$=s=>[...document.querySelectorAll(s)];
const units=JSON.parse(localStorage.getItem('pokeweather:units')||'{}');
let state={lat:null,lon:null,name:null,units:units.units||'metric'};
const btnUnits=$('#btnUnits'); btnUnits.textContent=state.units==='metric'?"°C":"°F";
const weatherText=(c)=>{
if([0].includes(c))return"Clear sky";
if([1].includes(c))return"Mostly clear";
if([2].includes(c))return"Partly cloudy";
if([3].includes(c))return"Overcast";
if([45,48].includes(c))return"Fog";
if([51,53,55].includes(c))return"Drizzle";
if([56,57].includes(c))return"Freezing drizzle";
if([61,63,65].includes(c))return"Rain";
if([66,67].includes(c))return"Freezing rain";
if([71,73,75].includes(c))return"Snow";
if([77].includes(c))return"Snow grains";
if([80,81,82].includes(c))return"Showers";
if([85,86].includes(c))return"Snow showers";
if([95].includes(c))return"Thunderstorm";
if([96,99].includes(c))return"Storm & hail";return"—"}
const weatherIcon=(c,isDay)=>{
if(c===0)return isDay?"☀️":"🌙";
if([1,2].includes(c))return isDay?"🌤️":"☁️";
if([3].includes(c))return"☁️";
if([45,48].includes(c))return"🌫️";
if([51,53,55,80,81,82].includes(c))return"🌦️";
if([61,63,65].includes(c))return"🌧️";
if([66,67].includes(c))return"🌧️❄️";
if([71,73,75,77,85,86].includes(c))return"❄️";
if([95,96,99].includes(c))return"⛈️";return"☁️";
};
const fmt=(n,u='')=>n==null?'—':`${Math.round(n)}${u}`;
const fmtTime=(s)=>new Date(s).toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'});
const fmtDay=(s)=>new Date(s).toLocaleDateString([], {weekday:'short',month:'short',day:'numeric'});
function setAmbientEffects(code, isDay) {
const container = document.getElementById('effects-container');
if(!container) return;
container.innerHTML = '';
const body = document.body;
body.className = body.className.replace(/weather-\w+|is-(day|night)/g, '').trim();
let type = 'clear';
if([1,2,3].includes(code)) type = 'cloudy';
if([45,48].includes(code)) type = 'fog';
if([51,53,55,56,57,61,63,65,66,67,80,81,82].includes(code)) type = 'rain';
if([71,73,75,77,85,86].includes(code)) type = 'snow';
if([95,96,99].includes(code)) type = 'storm';
body.classList.add(`weather-${type}`);
body.classList.add(isDay ? 'is-day' : 'is-night');
if(type === 'rain' || type === 'storm') {
for(let i=0; i<30; i++) {
let d = document.createElement('div');
d.className = 'effect-rain';
d.style.left = Math.random() * 100 + '%';
d.style.animationDuration = (Math.random() * 0.4 + 0.3) + 's';
d.style.animationDelay = Math.random() * 2 + 's';
container.appendChild(d);
}
} else if(type === 'snow') {
for(let i=0; i<40; i++) {
let d = document.createElement('div');
d.className = 'effect-snow';
d.style.left = Math.random() * 100 + '%';
d.style.animationDuration = (Math.random() * 3 + 2) + 's';
d.style.animationDelay = Math.random() * 3 + 's';
d.style.opacity = Math.random() * 0.6 + 0.4;
d.style.transform = `scale(${Math.random() * 0.8 + 0.2})`;
container.appendChild(d);
}
} else if(type === 'cloudy' || type === 'fog') {
for(let i=0; i<4; i++) {
let d = document.createElement('div');
d.className = 'effect-cloud';
d.style.top = Math.random() * 30 + '%';
d.style.animationDuration = (Math.random() * 30 + 30) + 's';
d.style.animationDelay = (Math.random() * -30) + 's';
container.appendChild(d);
}
}
}
async function searchPlaces(q){
if(!q) return[];
const url = `/api/nominatim/search?format=json&limit=5&addressdetails=1&q=${encodeURIComponent(q)}`;
const r=await fetch(url,{headers:{'Accept-Language':navigator.language}});
if(!r.ok) return[];
return r.json();
}
function applyUnits(){
btnUnits.textContent=state.units==='metric'?"°C":"°F";
const uHidden=document.getElementById('unitsHidden');
if(uHidden) uHidden.value = state.units === 'metric' ? 'metric' : 'imperial';
if(state.lat&&state.lon) loadWeather(state.lat,state.lon,state.name);
localStorage.setItem('pokeweather:units',JSON.stringify({units:state.units}))
}
async function loadWeather(lat,lon,name){
state.lat=+lat;state.lon=+lon;state.name=name||state.name||`${lat.toFixed(3)},${lon.toFixed(3)}`;
$('#locChip').textContent=state.name;
const tu=state.units==='metric'?"celsius":"fahrenheit";
const wu=state.units==='metric'?"kmh":"mph";
const url = new URL("/api/weather", location.origin);
url.search={}.toString();
url.searchParams.set('latitude',lat);url.searchParams.set('longitude',lon);
url.searchParams.set('current','temperature_2m,relative_humidity_2m,apparent_temperature,is_day,precipitation,weather_code,wind_speed_10m,wind_direction_10m,pressure_msl');
url.searchParams.set('hourly','temperature_2m,apparent_temperature,precipitation_probability,precipitation,weather_code,wind_speed_10m');
url.searchParams.set('daily','weather_code,temperature_2m_max,temperature_2m_min,sunrise,sunset,uv_index_max');
url.searchParams.set('timezone','auto');url.searchParams.set('forecast_days','7');
url.searchParams.set('temperature_unit',tu);url.searchParams.set('windspeed_unit',wu);
$('.current-card').classList.add('loading');
try{
const res=await fetch(url.toString());
if(!res.ok) throw new Error('Weather error');
const data=await res.json();
localStorage.setItem('pokeweather:last',JSON.stringify({when:Date.now(),state,data}));
render(data);
}catch(e){
const cached=JSON.parse(localStorage.getItem('pokeweather:last')||'null');
if(cached){render(cached.data);}
else alert('Could not load weather.');
}finally{$('.current-card').classList.remove('loading')}
}
function render(d){
const c=d.current; const daily=d.daily; const hourly=d.hourly;
$('#currIcon').textContent=weatherIcon(c.weather_code,c.is_day);
$('#currTemp').textContent=fmt(c.temperature_2m,'°');
$('#currDesc').textContent=weatherText(c.weather_code);
$('#currFeels').textContent=fmt(c.apparent_temperature,'°');
$('#currWind').textContent=`${fmt(c.wind_speed_10m)} ${state.units==='metric'?'km/h':'mph'} ↗ ${c.wind_direction_10m??'—'}°`;
$('#currHum').textContent=fmt(c.relative_humidity_2m,'%');
$('#currPress').textContent=fmt(c.pressure_msl,' hPa');
$('#sunrise').textContent=fmtTime(daily.sunrise[0]);
$('#sunset').textContent=fmtTime(daily.sunset[0]);
$('#uv').textContent=(daily.uv_index_max?.[0]??'—');
const nowIndex=hourly.time.findIndex(t=>Date.parse(t)>Date.now());
const popNext=hourly.precipitation_probability?.[nowIndex]??hourly.precipitation_probability?.[0]??null;
$('#pop').textContent=popNext==null?'—':popNext+"%";
setAmbientEffects(c.weather_code, c.is_day);
const H=$('#hours'); H.innerHTML='';
const start=nowIndex>0?nowIndex-1:0; const end=Math.min(start+24,hourly.time.length);
for(let i=start;i<end;i++){
const el=document.createElement('div');
el.className='hour-item';
const t=new Date(hourly.time[i]).toLocaleTimeString([], {hour:'2-digit'});
el.innerHTML=`<div class="hour-time">${t}</div><div class="hour-icon">${weatherIcon(hourly.weather_code[i],1)}</div><div class="hour-temp">${fmt(hourly.temperature_2m[i],'°')}</div>`;
H.appendChild(el);
}
drawChart($('#chart'), hourly.time.slice(start,end).map(t=>new Date(t)), hourly.temperature_2m.slice(start,end));
const D=$('#days'); D.innerHTML='';
for(let i=0;i<daily.time.length;i++){
const row=document.createElement('div'); row.className='day-row';
const dt=fmtDay(daily.time[i]);
const hi=fmt(daily.temperature_2m_max[i],'°');
const lo=fmt(daily.temperature_2m_min[i],'°');
row.innerHTML=`<div class="day-info"><div class="day-icon">${weatherIcon(daily.weather_code[i],1)}</div><div><div class="day-name">${dt}</div><div class="day-desc">${weatherText(daily.weather_code[i])}</div></div></div><div class="day-temps"><span class="temp-high">${hi}</span><span class="temp-low">${lo}</span></div>`;
D.appendChild(row);
}
}
function drawChart(canvas, xs, ys){
const ctx=canvas.getContext('2d');
const w=canvas.width=canvas.clientWidth*2; const h=canvas.height=canvas.clientHeight*2; ctx.scale(2,2);
const min=Math.min(...ys), max=Math.max(...ys), pad=8; const xstep=(canvas.clientWidth-2*pad)/(ys.length-1);
const ymap=v=>{if(max===min) return canvas.clientHeight/2; const t=(v-min)/(max-min); return canvas.clientHeight-pad - t*(canvas.clientHeight-2*pad)};
ctx.clearRect(0,0,canvas.clientWidth,canvas.clientHeight);
ctx.lineWidth=3; ctx.strokeStyle=getComputedStyle(document.documentElement).getPropertyValue('--accent');
ctx.beginPath(); ctx.moveTo(pad, ymap(ys[0]));
for(let i=1;i<ys.length;i++){ctx.lineTo(pad+i*xstep, ymap(ys[i]));}
ctx.stroke();
ctx.fillStyle=getComputedStyle(document.documentElement).getPropertyValue('--accent');
ys.forEach((v,i)=>{ctx.beginPath();ctx.arc(pad+i*xstep, ymap(v), 3.5, 0, Math.PI*2);ctx.fill()});
}
btnUnits.addEventListener('click',()=>{
state.units=state.units==='metric'?'imperial':'metric';
applyUnits();
});
$('#btnTheme').addEventListener('click',()=>{
const dark=document.documentElement.style.getPropertyValue('--bg')==='#121212';
if(dark){
document.documentElement.style.setProperty('--bg','#f8f9fa');
document.documentElement.style.setProperty('--fg','#202124');
document.documentElement.style.setProperty('--muted','#5f6368');
