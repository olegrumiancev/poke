							</style>
							
							<% } %>
							
							<style>
							body {
								overflow-x: hidden;
							}
							
							@font-face {
								font-family: "PokeTube Flex";
								src: url("/static/robotoflex.ttf");
								font-style: normal;
								font-stretch: 1% 800%;
								font-display: swap;
							}
							
							.discover-video-button > a {
								border: 2px white solid;
								border-radius: 3rem;
								padding: 12px 1em 12px 12px;
								display: flex;
								align-items: center;
								width: 146px;
								text-align: center;
								margin: auto;
								color: #fff;
								margin-bottom: 2em;
								margin-top: 26px;
								text-decoration: none;
							}
							
							.discover-video-button > a:hover {
								filter: brightness(0.8);
							}
							
							.subtitle {
								text-align: center;
								color: #FFFF00;
								text-shadow: 1px 1px 0px #000;
								position: relative;
								left: 68px;
								top: -35px;
								bottom: 50px;
								animation: subtitle .25s;
								animation-direction: alternate;
								animation-iteration-count: infinite;
							}
							
							@-webkit-keyframes subtitle {
								0% {
									transform: scale(0.875) rotate(-20deg)
								}
								
								100% {
									transform: scale(1) rotate(-20deg)
								}
							}
							
							.donate-banner {
								text-align: center;
								background: red;
								color: #1f2937;
								font-weight: 700;
								font-size: 14px;
								padding: 10px 14px;
								border-bottom: 1px solid rgba(0,0,0,.1);
								letter-spacing: .3px;
								margin-top: 6em;
								border-radius: 3em;
								width: fit-content;
								margin-left: auto;
								margin-right: auto;
							}
							
							.donate-banner strong {
								color: #111827;
							}

							/* ─── SCROLL ARROW — center of viewport ─── */
							.problem-jump {
								position: fixed;
								left: 50%;
								top: 50%;
								transform: translate(-50%, calc(-50% + 22px));
								width: 58px;
								height: 58px;
								border: 1px solid rgba(255,255,255,.18);
								border-radius: 16px;
								background: linear-gradient(160deg, rgba(255,171,204,.18), rgba(255,255,255,.06));
								color: #fff;
								box-shadow: 0 18px 50px rgba(0,0,0,.38), 0 0 0 1px rgba(255,171,204,.1) inset;
								backdrop-filter: blur(14px);
								display: inline-flex;
								align-items: center;
								justify-content: center;
								cursor: pointer;
								opacity: 0;
								pointer-events: none;
								transition: opacity .28s ease, transform .28s cubic-bezier(.34,1.56,.64,1), border-color .18s ease;
								z-index: 60;
							}
							
							.problem-jump.is-visible {
								opacity: 1;
								pointer-events: auto;
								transform: translate(-50%, -50%);
							}
							
							.problem-jump:hover {
								border-color: rgba(255,171,204,.5);
								background: linear-gradient(160deg, rgba(255,171,204,.28), rgba(255,255,255,.1));
							}

							.problem-jump-ring {
								position: absolute;
								inset: -8px;
								border-radius: 22px;
								border: 1px solid rgba(255,171,204,.2);
								animation: pjRing 2.2s ease-out infinite;
								pointer-events: none;
							}

							@keyframes pjRing {
								0%   { opacity: .6; transform: scale(1); }
								100% { opacity: 0;  transform: scale(1.55); }
							}
							
							.problem-jump svg {
								width: 24px;
								height: 24px;
								animation: pjBob 1.5s ease-in-out infinite;
							}

							@keyframes pjBob {
								0%, 100% { transform: translateY(0); }
								50%       { transform: translateY(3px); }
							}

							/* ─── PROBLEM SECTION ─── */
							.poke-problem-section {
								margin: 4.5em auto 2.75em auto;
								max-width: 1240px;
								padding: 0 20px;
							}

							/* Tag chips row — square-circle style */
							.poke-chip-row {
								display: flex;
								flex-wrap: wrap;
								gap: 8px;
								margin-bottom: 22px;
							}

							.poke-chip {
								display: inline-flex;
								align-items: center;
								justify-content: center;
								height: 32px;
								padding: 0 12px;
								border-radius: 9px;
								background: rgba(255,255,255,.06);
								border: 1px solid rgba(255,255,255,.14);
								color: #e8e8e8;
								font-size: 12px;
								font-weight: 700;
								letter-spacing: .1em;
								text-transform: uppercase;
							}

							/* Statement hero */
							.poke-statement-hero {
								position: relative;
								overflow: hidden;
								border: 1px solid rgba(255,255,255,.13);
								border-radius: 24px;
								padding: 48px 52px 44px 52px;
								background:
									radial-gradient(ellipse at 80% 50%, rgba(255,171,204,.18) 0%, transparent 55%),
									linear-gradient(160deg, rgba(255,255,255,.07) 0%, rgba(255,255,255,.025) 100%);
								box-shadow: 0 22px 60px rgba(0,0,0,.22);
								backdrop-filter: blur(10px);
								margin-bottom: 16px;
							}

							.poke-statement-hero::before {
								content: "THE WEB GOT WEIRD.";
								position: absolute;
								right: -10px;
								bottom: -18px;
								font-size: clamp(3.5rem, 9vw, 8rem);
								font-weight: 900;
								line-height: 1;
								color: rgba(255,255,255,.03);
								white-space: nowrap;
								pointer-events: none;
								user-select: none;
								letter-spacing: -.02em;
							}

							.poke-statement-tag {
								display: inline-flex;
								align-items: center;
								gap: 7px;
								height: 28px;
								padding: 0 10px;
								border-radius: 7px;
								background: rgba(255,171,204,.16);
								border: 1px solid rgba(255,171,204,.3);
								color: #ffd6e8;
								font-size: 11px;
								font-weight: 800;
								letter-spacing: .14em;
								text-transform: uppercase;
								margin-bottom: 20px;
							}

							.poke-statement-tag::before {
								content: "";
								width: 6px;
								height: 6px;
								border-radius: 2px;
								background: #ffabcc;
								flex-shrink: 0;
							}

							.poke-statement-title {
								margin: 0 0 20px 0;
								font-size: clamp(3rem, 7vw, 6.5rem);
								line-height: .9;
								font-weight: 900;
								color: #fff;
								letter-spacing: -.025em;
								text-shadow: 0 12px 40px rgba(0,0,0,.2);
							}

							.poke-statement-rule {
								width: 56px;
								height: 3px;
								border-radius: 2px;
								background: linear-gradient(90deg, #ffabcc, rgba(255,171,204,.2));
								margin-bottom: 20px;
								border: none;
							}

							.poke-statement-sub {
								margin: 0;
								max-width: 680px;
								font-size: clamp(1rem, 1.8vw, 1.2rem);
								line-height: 1.72;
								color: #dcdcdc;
							}

							/* Two column split below hero */
							.poke-split {
								display: grid;
								grid-template-columns: minmax(0, 1fr) minmax(280px, .72fr);
								gap: 16px;
								margin-bottom: 16px;
							}

							.poke-split-main {
								position: relative;
								overflow: hidden;
								border: 1px solid rgba(255,255,255,.12);
								border-radius: 20px;
								padding: 32px 34px;
								background: linear-gradient(160deg, rgba(255,255,255,.07), rgba(255,255,255,.025));
								backdrop-filter: blur(10px);
							}

							.poke-split-eyebrow {
								display: block;
								font-size: 11px;
								font-weight: 800;
								letter-spacing: .18em;
								text-transform: uppercase;
								color: #ffd6e8;
								margin-bottom: 14px;
							}

							.poke-split-heading {
								margin: 0 0 14px 0;
								font-size: clamp(1.6rem, 3vw, 2.4rem);
								line-height: 1;
								font-weight: 900;
								color: #fff;
							}

							.poke-split-lead {
								margin: 0 0 22px 0;
								font-size: .98rem;
								line-height: 1.74;
								color: #e2e2e2;
								max-width: 480px;
							}

							.poke-action-row {
								display: flex;
								flex-wrap: wrap;
								gap: 10px;
							}

							/* Square-circle action buttons */
							.poke-action-btn {
								display: inline-flex;
								align-items: center;
								justify-content: center;
								height: 42px;
								padding: 0 18px;
								border-radius: 11px;
								border: 1px solid rgba(255,255,255,.16);
								background: rgba(255,255,255,.07);
								color: #fff;
								text-decoration: none;
								font-size: .9rem;
								font-weight: 700;
								transition: transform .16s ease, background .18s ease, border-color .18s ease;
							}

							.poke-action-btn:hover {
								transform: translateY(-1px);
								background: rgba(255,255,255,.11);
								border-color: rgba(255,171,204,.34);
							}

							.poke-action-btn.primary {
								background: rgba(255,171,204,.2);
								border-color: rgba(255,171,204,.42);
							}

							.poke-action-btn.primary:hover {
								background: rgba(255,171,204,.3);
							}

							/* Reasons aside */
							.poke-split-reasons {
								position: relative;
								overflow: hidden;
								border: 1px solid rgba(255,255,255,.12);
								border-radius: 20px;
								padding: 28px;
								background: linear-gradient(160deg, rgba(255,255,255,.06), rgba(255,255,255,.02));
								backdrop-filter: blur(10px);
							}

							.poke-reasons-label {
								font-size: 11px;
								font-weight: 800;
								letter-spacing: .18em;
								text-transform: uppercase;
								color: #ffd6e8;
								margin: 0 0 18px 0;
							}

							.poke-reasons-list {
								list-style: none;
								padding: 0;
								margin: 0;
								display: grid;
								gap: 0;
							}

							.poke-reasons-list li {
								display: grid;
								grid-template-columns: 40px minmax(0, 1fr);
								gap: 10px;
								align-items: start;
								padding: 14px 0;
								border-bottom: 1px solid rgba(255,255,255,.07);
							}

							.poke-reasons-list li:last-child {
								border-bottom: none;
								padding-bottom: 0;
							}

							.poke-reasons-list li:first-child {
								padding-top: 0;
							}

							.poke-reason-num {
								display: inline-flex;
								align-items: center;
								justify-content: center;
								width: 34px;
								height: 34px;
								border-radius: 9px;
								background: rgba(255,171,204,.1);
								border: 1px solid rgba(255,171,204,.2);
								color: #ffd7e9;
								font-size: 12px;
								font-weight: 800;
								flex-shrink: 0;
							}

							.poke-reason-body strong {
								display: block;
								color: #fff;
								font-size: .93rem;
								font-weight: 700;
								margin-bottom: 2px;
							}

							.poke-reason-body span {
								display: block;
								color: #cbcbcb;
								font-size: 13px;
								line-height: 1.5;
							}

							/* Issues — editorial numbered layout, not bento */
							.poke-issues {
								border: 1px solid rgba(255,255,255,.1);
								border-radius: 20px;
								overflow: hidden;
								background: linear-gradient(160deg, rgba(255,255,255,.055), rgba(255,255,255,.018));
								backdrop-filter: blur(8px);
								margin-bottom: 14px;
							}

							.poke-issues-header {
								padding: 22px 28px 0 28px;
								border-bottom: 1px solid rgba(255,255,255,.08);
								padding-bottom: 16px;
								display: flex;
								align-items: center;
								justify-content: space-between;
								gap: 12px;
							}

							.poke-issues-header-label {
								font-size: 11px;
								font-weight: 800;
								letter-spacing: .18em;
								text-transform: uppercase;
								color: #ffd6e8;
							}

							.poke-issues-header-count {
								font-size: 12px;
								color: #aaa;
								font-weight: 600;
							}

							.poke-issues-grid {
								display: grid;
								grid-template-columns: repeat(4, minmax(0, 1fr));
								gap: 0;
							}

							.poke-issue-item {
								padding: 22px 24px;
								border-right: 1px solid rgba(255,255,255,.07);
								border-bottom: 1px solid rgba(255,255,255,.07);
								transition: background .18s ease;
							}

							.poke-issue-item:nth-child(4n) {
								border-right: none;
							}

							.poke-issue-item:nth-last-child(-n+4) {
								border-bottom: none;
							}

							.poke-issue-item:hover {
								background: rgba(255,171,204,.04);
							}

							.poke-issue-num {
								font-size: 11px;
								font-weight: 800;
								letter-spacing: .12em;
								color: rgba(255,171,204,.6);
								margin-bottom: 8px;
								display: block;
							}

							.poke-issue-item h3 {
								margin: 0 0 6px 0;
								font-size: .95rem;
								font-weight: 800;
								color: #fff;
								line-height: 1.2;
							}

							.poke-issue-item p {
								margin: 0;
								font-size: 13px;
								color: #c8c8c8;
								line-height: 1.55;
							}

							.poke-answer-banner {
								margin: 14px auto 0 auto;
								text-align: center;
								padding: 18px 24px;
								border-radius: 16px;
								border: 1px solid rgba(255,255,255,.12);
								background: linear-gradient(160deg, rgba(255,255,255,.055), rgba(255,255,255,.02));
								font-size: 1rem;
								line-height: 1.72;
								color: #e0e0e0;
							}

							.poke-answer-banner strong {
								color: #fff;
							}

							/* ─── WATCH SECTION ─── */
							.poke-watch-section {
								margin: 4.5em auto 2em auto;
								max-width: 1200px;
								padding: 0 20px;
							}

							.poke-watch-header {
								display: flex;
								align-items: flex-end;
								justify-content: space-between;
								gap: 24px;
								flex-wrap: wrap;
								margin-bottom: 24px;
							}

							.poke-watch-header-left {
								flex: 1 1 320px;
							}

							.poke-watch-eyebrow {
								display: block;
								font-size: 11px;
								font-weight: 800;
								letter-spacing: .18em;
								text-transform: uppercase;
								color: #ffd6e8;
								margin-bottom: 12px;
							}

							.poke-watch-heading {
								margin: 0;
								font-size: clamp(2.4rem, 5vw, 4rem);
								font-weight: 900;
								line-height: .92;
								letter-spacing: -.02em;
								color: #fff;
							}

							.poke-watch-subheading {
								flex: 1 1 300px;
								max-width: 480px;
								color: #d8d8d8;
								font-size: .97rem;
								line-height: 1.72;
								padding-bottom: 4px;
							}

							.poke-watch-shell {
								border: 1px solid rgba(255,255,255,.13);
								border-radius: 24px;
								overflow: hidden;
								background: linear-gradient(160deg, rgba(255,255,255,.07) 0%, rgba(255,255,255,.025) 100%);
