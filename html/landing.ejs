						<% if(isOldWindows) { %>
							<style>
							@font-face {
								font-family: 'Ginto Nord';
								font-weight: 800;
								src: url('https://cdn.statically.io/gh/brecert/discord-quote-generator/main/Ginto-Nord-800.woff') format("woff");
