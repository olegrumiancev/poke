    <script>
       (function () {
        var tabs   = document.querySelectorAll('.poke-watch-tab');
        var panels = document.querySelectorAll('.poke-watch-panel');

        function activateTab(name) {
          tabs.forEach(function (tab) {
            var isActive = tab.getAttribute('data-target') === name;
            tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
          });

          panels.forEach(function (panel) {
            var isActive = panel.id === 'watch-panel-' + name;
            panel.classList.toggle('is-active', isActive);
            if (isActive) {
              panel.removeAttribute('hidden');
            } else {
              panel.setAttribute('hidden', '');
            }
          });
        }

        tabs.forEach(function (tab) {
          tab.addEventListener('click', function () {
            activateTab(tab.getAttribute('data-target'));
          });
        });
      })();
    </script>

    <script>
       (function () {
        var jump    = document.getElementById('problemJump');
        var section = document.getElementById('why-poke');

        if (!jump || !section) return;

        function syncJump() {
          var rect       = section.getBoundingClientRect();
          var threshold  = window.innerHeight * 0.85;
          var isBeforeIt = rect.top > threshold;
          var isPastIt   = rect.bottom <= 0;

          jump.classList.toggle('is-visible', isBeforeIt && !isPastIt);
        }

        jump.addEventListener('click', function () {
          section.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });

        syncJump();
        window.addEventListener('scroll', syncJump, { passive: true });
        window.addEventListener('resize', syncJump);
      })();
    </script>

