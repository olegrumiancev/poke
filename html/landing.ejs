  <style>
    body {
      overflow-x: hidden;
    }

    @font-face {
      font-family: "PokeTube Flex";
      src: url("/static/robotoflex.ttf");
      font-style: normal;
      font-stretch: 1% 800%;
      font-display: swap;
    }

    .discover-video-button > a {
      border: 2px white solid;
      border-radius: 3rem;
      padding: 12px 1em 12px 12px;
      display: flex;
      align-items: center;
      width: 146px;
      text-align: center;
      margin: auto;
      color: #fff;
      margin-bottom: 2em;
      margin-top: 26px;
      text-decoration: none;
    }

    .discover-video-button > a:hover {
      filter: brightness(0.8);
    }

    .subtitle {
      text-align: center;
      color: #FFFF00;
      text-shadow: 1px 1px 0px #000;
      position: relative;
      left: 68px;
      top: -35px;
      bottom: 50px;
      animation: subtitle .25s;
      animation-direction: alternate;
      animation-iteration-count: infinite;
    }

    @-webkit-keyframes subtitle {
      0% {
        transform: scale(0.875) rotate(-20deg)
      }

      100% {
        transform: scale(1) rotate(-20deg)
      }
    }

    .donate-banner {
      text-align: center;
      background: red;
      color: #1f2937;
      font-weight: 700;
      font-size: 14px;
      padding: 10px 14px;
      border-bottom: 1px solid rgba(0,0,0,.1);
      letter-spacing: .3px;
      margin-top: 6em;
      border-radius: 3em;
      width: fit-content;
      margin-left: auto;
      margin-right: auto;
    }

    .donate-banner strong {
      color: #111827;
    }

    .problem-jump {
      position: fixed;
      left: 50%;
      bottom: 24px;
      transform: translateX(-50%) translateY(26px);
      width: 62px;
      height: 62px;
      border: 1px solid rgba(255,255,255,.16);
      border-radius: 20px;
      background: linear-gradient(180deg, rgba(255,255,255,.1), rgba(255,255,255,.04));
      color: #fff;
      box-shadow: 0 14px 40px rgba(0,0,0,.26);
      backdrop-filter: blur(12px);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      opacity: 0;
      pointer-events: none;
      transition: opacity .22s ease, transform .22s ease, border-color .18s ease, filter .18s ease;
      z-index: 60;
    }

    .problem-jump.is-visible {
      opacity: 1;
      pointer-events: auto;
      transform: translateX(-50%) translateY(0);
    }

    .problem-jump:hover {
      border-color: rgba(255,171,204,.42);
      filter: brightness(1.06);
      transform: translateX(-50%) translateY(-2px);
    }

    .problem-jump svg {
      width: 26px;
      height: 26px;
    }

    .poke-problem-section {
      margin: 4.25em auto 2.75em auto;
      max-width: 1240px;
      padding: 0 20px;
    }

    .poke-problem-stage {
      display: grid;
      grid-template-columns: minmax(0, 1.45fr) minmax(300px, .78fr);
      gap: 18px;
      align-items: stretch;
    }

    .poke-problem-feature {
      position: relative;
      overflow: hidden;
      background:
        radial-gradient(circle at top right, rgba(255,171,204,.15), transparent 36%),
        linear-gradient(180deg, rgba(255,255,255,.08), rgba(255,255,255,.03));
      border: 1px solid rgba(255,255,255,.14);
      border-radius: 28px;
      padding: 20px;
      box-shadow: 0 18px 42px rgba(0,0,0,.18);
      backdrop-filter: blur(12px);
    }

    .poke-problem-feature::before {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      background: linear-gradient(135deg, rgba(255,255,255,.05), transparent 46%);
    }

    .poke-problem-feature-bar {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-bottom: 16px;
    }

    .poke-problem-feature-chip {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 36px;
      padding: 0 14px;
      border-radius: 14px;
      background: rgba(255,255,255,.05);
      border: 1px solid rgba(255,255,255,.12);
      color: #fff;
      font-size: 13px;
      font-weight: 700;
      letter-spacing: .02em;
    }

    .poke-problem-feature-body {
      display: grid;
      grid-template-columns: minmax(0, 1.15fr) minmax(280px, .95fr);
      gap: 18px;
      align-items: stretch;
    }

    .poke-problem-preview {
      position: relative;
      overflow: hidden;
      min-height: 340px;
      border-radius: 24px;
      border: 1px solid rgba(255,255,255,.12);
      background:
        radial-gradient(circle at center, rgba(255,255,255,.09), transparent 40%),
        linear-gradient(135deg, rgba(255,171,204,.24), rgba(124,58,237,.12) 55%, rgba(255,255,255,.03));
      padding: 22px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      box-shadow: inset 0 1px 0 rgba(255,255,255,.04);
    }

    .poke-problem-preview-badge {
      width: fit-content;
      min-height: 34px;
      padding: 0 12px;
      border-radius: 12px;
      border: 1px solid rgba(255,255,255,.14);
      background: rgba(0,0,0,.18);
      display: inline-flex;
      align-items: center;
      color: #fff;
      font-size: 12px;
      font-weight: 700;
      letter-spacing: .08em;
      text-transform: uppercase;
    }

    .poke-problem-preview-play {
      position: absolute;
      right: 18px;
      bottom: 18px;
      width: 72px;
      height: 72px;
      border-radius: 22px;
      background: rgba(255,255,255,.1);
      border: 1px solid rgba(255,255,255,.16);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 14px 35px rgba(0,0,0,.18);
      backdrop-filter: blur(8px);
    }

    .poke-problem-preview-title {
      margin: 18px 0 10px 0;
      max-width: 520px;
      font-size: clamp(2.4rem, 5vw, 4.25rem);
      line-height: .9;
      font-weight: 900;
      color: #fff;
      text-wrap: balance;
      text-shadow: 0 8px 28px rgba(0,0,0,.18);
    }

    .poke-problem-preview-meta {
      max-width: 520px;
      color: #f3f3f3;
      font-size: 1rem;
      line-height: 1.65;
    }

    .poke-problem-copy {
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      gap: 16px;
      padding: 4px 2px;
    }

    .poke-problem-eyebrow {
      display: inline-block;
      font-size: 12px;
      letter-spacing: .18em;
      text-transform: uppercase;
      color: #ffd6e7;
      margin-bottom: 12px;
      font-weight: 700;
    }

    .poke-problem-heading {
      margin: 0 0 14px 0;
      font-size: clamp(1.9rem, 4vw, 3rem);
      line-height: .98;
      text-wrap: balance;
    }

    .poke-problem-lead {
      margin: 0;
      font-size: 1rem;
      line-height: 1.72;
      color: #ececec;
      max-width: 470px;
    }

    .poke-problem-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-top: 2px;
    }

    .poke-problem-action {
      min-height: 44px;
      padding: 0 16px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 14px;
      border: 1px solid rgba(255,255,255,.14);
      background: rgba(255,255,255,.05);
      color: #fff;
      text-decoration: none;
      font-weight: 700;
      transition: transform .16s ease, filter .16s ease, border-color .16s ease;
    }

    .poke-problem-action:hover {
      transform: translateY(-1px);
      filter: brightness(1.04);
      border-color: rgba(255,171,204,.28);
    }

    .poke-problem-side {
      position: relative;
      overflow: hidden;
      background: linear-gradient(180deg, rgba(255,255,255,.07), rgba(255,255,255,.03));
      border: 1px solid rgba(255,255,255,.14);
      border-radius: 28px;
      padding: 20px;
      box-shadow: 0 18px 42px rgba(0,0,0,.14);
      backdrop-filter: blur(12px);
    }

    .poke-problem-side h2 {
      margin: 0 0 14px 0;
      font-size: 1.1rem;
      letter-spacing: .02em;
    }

    .poke-problem-side-list {
      display: grid;
      gap: 12px;
    }

    .poke-problem-side-item {
      display: grid;
      grid-template-columns: 48px minmax(0, 1fr);
      gap: 12px;
      align-items: start;
      padding: 14px;
      border-radius: 18px;
      border: 1px solid rgba(255,255,255,.1);
      background: rgba(255,255,255,.035);
    }

    .poke-problem-side-number {
      width: 48px;
      height: 48px;
      border-radius: 16px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: rgba(255,171,204,.14);
      border: 1px solid rgba(255,171,204,.22);
      color: #ffd7e9;
      font-size: 13px;
      font-weight: 800;
    }

    .poke-problem-side-text strong {
      display: block;
      color: #fff;
      font-size: .98rem;
      margin-bottom: 3px;
    }

    .poke-problem-side-text span {
      display: block;
      color: #dfdfdf;
      font-size: 14px;
      line-height: 1.52;
    }

    .poke-problem-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 14px;
      margin-top: 18px;
    }

    .poke-problem-card {
      position: relative;
      overflow: hidden;
      min-height: 126px;
      background: linear-gradient(180deg, rgba(255,255,255,.06), rgba(255,255,255,.025));
      border: 1px solid rgba(255,255,255,.12);
      border-radius: 22px;
      padding: 16px;
      box-shadow: 0 10px 28px rgba(0,0,0,.1);
      transition: transform .18s ease, border-color .18s ease, background .18s ease;
    }

    .poke-problem-card:hover {
      transform: translateY(-2px);
      border-color: rgba(255,171,204,.24);
      background: linear-gradient(180deg, rgba(255,255,255,.08), rgba(255,255,255,.03));
    }

    .poke-problem-card-number {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 34px;
      height: 34px;
      border-radius: 12px;
      background: rgba(255,171,204,.14);
      border: 1px solid rgba(255,171,204,.22);
      color: #ffd7e9;
      font-size: 13px;
      font-weight: 700;
      margin-bottom: 12px;
    }

    .poke-problem-card h2 {
      margin: 0 0 6px 0;
      font-size: 1rem;
      line-height: 1.24;
      color: #fff;
    }

    .poke-problem-card p {
      margin: 0;
      color: #e4e4e4;
      line-height: 1.52;
      font-size: 13px;
    }

    .poke-answer-banner {
      margin: 18px auto 0 auto;
      max-width: 920px;
      text-align: center;
      padding: 18px 20px;
      border-radius: 20px;
      border: 1px solid rgba(255,255,255,.14);
      background: linear-gradient(180deg, rgba(255,255,255,.05), rgba(255,255,255,.02));
      font-size: 1rem;
      line-height: 1.7;
    }

    .poke-answer-banner strong {
      color: #fff;
    }

    .poke-watch-section {
      margin: 4em auto 2em auto;
      max-width: 1200px;
      padding: 0 20px;
    }

    .poke-watch-heading {
      text-align: center;
      font-size: clamp(2rem, 4vw, 3rem);
      margin-bottom: .25em;
    }

    .poke-watch-subheading {
      text-align: center;
      max-width: 860px;
      margin: 0 auto 2em auto;
      line-height: 1.7;
      color: #e5e7eb;
    }

    .poke-watch-shell {
      background: linear-gradient(180deg, rgba(255,255,255,.08), rgba(255,255,255,.03));
      border: 2px solid rgba(255,255,255,.14);
      border-radius: 28px;
      padding: 20px;
      box-shadow: 0 12px 35px rgba(0,0,0,.18);
      backdrop-filter: blur(10px);
    }

    .poke-watch-tabs {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      justify-content: center;
      margin-bottom: 18px;
    }

    .poke-watch-tab {
      border: 2px solid rgba(255,255,255,.15);
      background: rgba(255,255,255,.05);
      color: #fff;
      border-radius: 18px;
      padding: 12px 18px;
      font: inherit;
      font-weight: 700;
      cursor: pointer;
      transition: transform .15s ease, background .2s ease, border-color .2s ease, filter .2s ease;
    }

    .poke-watch-tab:hover {
      transform: translateY(-1px);
      filter: brightness(1.05);
    }

    .poke-watch-tab[aria-selected="true"] {
      background: rgba(255,171,204,.22);
      border-color: rgba(255,171,204,.55);
      box-shadow: 0 0 0 3px rgba(255,171,204,.12);
    }

    .poke-watch-panels {
      position: relative;
    }

    .poke-watch-panel {
      display: none;
      animation: pokeFade .2s ease;
    }

    .poke-watch-panel.is-active {
      display: block;
    }

    .poke-watch-shot {
      width: 100%;
      display: block;
      border-radius: 20px;
      border: 2px solid rgba(255,255,255,.14);
      background: rgba(0,0,0,.22);
      box-shadow: 0 10px 30px rgba(0,0,0,.18);
      object-fit: cover;
    }

    .poke-watch-panel-copy {
      text-align: center;
      margin-top: 14px;
    }

    .poke-watch-panel-copy h3 {
      margin: 0 0 8px 0;
      font-size: 1.35rem;
    }

    .poke-watch-panel-copy p {
      margin: 0;
      color: #e5e7eb;
      line-height: 1.65;
      max-width: 800px;
      margin-left: auto;
      margin-right: auto;
    }

    @keyframes pokeFade {
      from {
        opacity: 0;
        transform: translateY(4px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @media (max-width: 1120px) {
      .poke-problem-stage {
        grid-template-columns: 1fr;
      }

      .poke-problem-feature-body {
        grid-template-columns: 1fr;
      }

      .poke-problem-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 700px) {
      .poke-problem-section {
        margin-top: 3.5em;
      }

      .poke-problem-feature,
      .poke-problem-side {
        padding: 16px;
        border-radius: 22px;
      }

      .poke-problem-preview {
        min-height: 260px;
        border-radius: 18px;
        padding: 18px;
      }

      .poke-problem-preview-title {
        font-size: clamp(2rem, 9vw, 3rem);
      }

      .poke-problem-preview-play {
        width: 58px;
        height: 58px;
        border-radius: 18px;
      }

      .poke-problem-grid {
        grid-template-columns: 1fr;
      }

      .poke-problem-card {
        min-height: unset;
        padding: 16px;
        border-radius: 18px;
      }

      .poke-answer-banner {
        padding: 16px;
        font-size: .98rem;
      }

      .poke-watch-shell {
        padding: 16px;
        border-radius: 20px;
      }

      .poke-watch-tab {
        width: 100%;
      }

      .poke-watch-shot {
        border-radius: 16px;
      }

      .problem-jump {
        width: 56px;
        height: 56px;
        border-radius: 18px;
        bottom: 18px;
      }
    }
  </style>
</head>

<body>
 
  <div style="margin-top: 6em;margin-left: auto;margin-right: auto;margin-bottom: -7em;background: #000;padding: 1em;border-radius: 14px;font-family: ubuntu;" id="banner_text"> <%- banner %> </div>
  <%- include('./partials/header.ejs') %>
  <video playsinline muted paused><source src="/bg-480.webm" type="video/webm"/></video>
  <div class="landing">
    <h1 style="text-align: center;">WELCOME TO POKE!</h1>
    <p style="max-width: 800px;text-align: center;margin: auto;margin-bottom: 3em;">Poke is a free software AD-FREE ! YouTube front-end, translator, weather app, and more!!1! Watch videos and explore without a trace in this all-in-one privacy app!!1! :3</p>   
    <div style="text-align: center; padding: 10px; border-radius: 8px;margin-left: -1em;">
      <details>
        <summary style="cursor: pointer; color: white; font-size: 18px; text-decoration: underline;">
          Support Humanitarian Efforts
        </summary>
        <div style="margin-top: 10px;">
          <a style="color: white; text-decoration: underline; margin: 0 5px;" href="https://buildpalestine.com/2021/05/15/trusted-organizations-to-donate-to-palestine">
             Support Palestine
          </a>
          <a style="color: white; text-decoration: underline; margin: 0px -6px;" href="https://gazaesims.com">
