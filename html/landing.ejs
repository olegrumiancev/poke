    </style>
  <% } %>

  <style>
    body {
      overflow-x: hidden;
    }

    @font-face {
      font-family: "PokeTube Flex";
      src: url("/static/robotoflex.ttf");
      font-style: normal;
      font-stretch: 1% 800%;
      font-display: swap;
    }

    .discover-video-button > a {
      border: 2px white solid;
      border-radius: 3rem;
      padding: 12px 1em 12px 12px;
      display: flex;
      align-items: center;
      width: 146px;
      text-align: center;
      margin: auto;
      color: #fff;
      margin-bottom: 2em;
      margin-top: 26px;
      text-decoration: none;
    }

    .discover-video-button > a:hover {
      filter: brightness(0.8);
    }

    .subtitle {
      text-align: center;
      color: #FFFF00;
      text-shadow: 1px 1px 0px #000;
      position: relative;
      left: 68px;
      top: -35px;
      bottom: 50px;
      animation: subtitle .25s;
      animation-direction: alternate;
      animation-iteration-count: infinite;
    }

    @-webkit-keyframes subtitle {
      0%   { transform: scale(0.875) rotate(-20deg); }
      100% { transform: scale(1)     rotate(-20deg); }
    }

    .donate-banner {
      text-align: center;
      background: red;
      color: #1f2937;
      font-weight: 700;
      font-size: 14px;
      padding: 10px 14px;
      border-bottom: 1px solid rgba(0,0,0,.1);
      letter-spacing: .3px;
      margin-top: 6em;
      border-radius: 3em;
      width: fit-content;
      margin-left: auto;
      margin-right: auto;
    }

    .donate-banner strong {
      color: #111827;
    }

    /* ==========================================
       SCROLL ARROW
       ========================================== */

    .problem-jump {
      position: fixed;
      left: 50%;
      bottom: 28px;
      transform: translateX(-50%) translateY(22px);
      width: 58px;
      height: 58px;
      border: 1px solid rgba(255, 171, 204, 0.3);
      border-radius: 20px;
      background: linear-gradient(160deg, rgba(255, 171, 204, 0.2), rgba(255, 255, 255, 0.07));
      color: #fff;
      box-shadow:
        0 16px 48px rgba(0, 0, 0, 0.28),
        inset 0 1px 0 rgba(255, 255, 255, 0.16);
      backdrop-filter: blur(18px) saturate(180%);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      opacity: 0;
      pointer-events: none;
      transition: opacity .26s ease, transform .26s ease, border-color .2s ease, background .2s ease;
      z-index: 60;
    }

    .problem-jump.is-visible {
      opacity: 1;
      pointer-events: auto;
      transform: translateX(-50%) translateY(0);
    }

    .problem-jump:hover {
      border-color: rgba(255, 171, 204, 0.65);
      background: linear-gradient(160deg, rgba(255, 171, 204, 0.32), rgba(255, 255, 255, 0.1));
      transform: translateX(-50%) translateY(-2px);
    }

    .problem-jump svg {
      width: 24px;
      height: 24px;
      animation: jumpPulse 1.8s ease-in-out infinite;
    }

    @keyframes jumpPulse {
      0%, 100% { transform: translateY(0); }
      50%       { transform: translateY(4px); }
    }

    /* ==========================================
       THE WEB GOT WEIRD — PROBLEM SECTION
       ========================================== */

    .poke-problem-section {
      margin: 4.5em auto 3em;
      max-width: 1260px;
      padding: 0 20px;
    }

    /* ---- Hero statement ---- */

    .ppb-hero {
      position: relative;
      overflow: hidden;
      border-radius: 28px;
      background:
        linear-gradient(
          135deg,
          rgba(255, 171, 204, 0.16) 0%,
          rgba(255, 255, 255, 0.07) 40%,
          rgba(100, 60, 200, 0.13) 100%
        );
      border: 1px solid rgba(255, 255, 255, 0.16);
      box-shadow:
        0 24px 64px rgba(0, 0, 0, 0.28),
        0 0 120px rgba(255, 171, 204, 0.06),
        inset 0 1px 0 rgba(255, 255, 255, 0.14);
      backdrop-filter: blur(18px) saturate(180%);
      padding: 60px 64px 56px;
      margin-bottom: 20px;
    }

    .ppb-hero::before {
      content: "";
      position: absolute;
      top: -100px;
      right: -60px;
      width: 500px;
      height: 500px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(255, 171, 204, 0.16), transparent 68%);
      pointer-events: none;
    }

    .ppb-hero::after {
      content: "";
      position: absolute;
      bottom: -60px;
      left: -40px;
      width: 320px;
      height: 320px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(100, 60, 200, 0.1), transparent 70%);
      pointer-events: none;
    }

    .ppb-eyebrow {
      display: inline-block;
      margin: 0 0 18px;
      font-size: 11px;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: #ffc8e0;
      font-weight: 700;
      background: rgba(255, 171, 204, 0.12);
      border: 1px solid rgba(255, 171, 204, 0.2);
      padding: 6px 14px;
      border-radius: 100px;
    }

    .ppb-hero-title {
      margin: 0 0 22px;
      font-size: clamp(3.8rem, 9.5vw, 8rem);
      font-weight: 900;
      line-height: 0.86;
      letter-spacing: -0.03em;
      background: linear-gradient(135deg, #fff 0%, #ffabcc 45%, #c084fc 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      filter: drop-shadow(0 4px 24px rgba(255, 171, 204, 0.22)) drop-shadow(0 16px 48px rgba(0, 0, 0, 0.22));
    }

    .ppb-hero-sub {
      margin: 0 0 34px;
      max-width: 620px;
      font-size: 1.1rem;
      line-height: 1.72;
      color: #e0e0e0;
    }

    .ppb-hero-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
    }

    .ppb-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 48px;
      padding: 0 28px;
      border-radius: 14px;
      border: 1px solid rgba(255, 255, 255, 0.18);
      background: rgba(255, 255, 255, 0.09);
      backdrop-filter: blur(10px);
      color: #fff;
      text-decoration: none;
      font-weight: 700;
      font-size: 0.96rem;
      transition: transform .2s ease, border-color .2s ease, background .2s ease, box-shadow .2s ease;
    }

    .ppb-btn:first-child {
      background: linear-gradient(135deg, rgba(255, 171, 204, 0.28), rgba(192, 132, 252, 0.2));
      border-color: rgba(255, 171, 204, 0.35);
    }

    .ppb-btn:hover {
      transform: translateY(-2px);
      border-color: rgba(255, 171, 204, 0.55);
      background: rgba(255, 171, 204, 0.18);
      box-shadow: 0 8px 24px rgba(255, 171, 204, 0.12);
    }

    .ppb-btn:first-child:hover {
      background: linear-gradient(135deg, rgba(255, 171, 204, 0.36), rgba(192, 132, 252, 0.28));
      box-shadow: 0 8px 32px rgba(255, 171, 204, 0.18);
    }

    /* ---- Two-column split: narrative + reasons ---- */

    .ppb-two {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
      margin-bottom: 20px;
    }

    .ppb-narrative {
      padding: 38px 40px;
      border-radius: 24px;
      background: linear-gradient(160deg, rgba(255, 255, 255, 0.09), rgba(255, 255, 255, 0.04));
      border: 1px solid rgba(255, 255, 255, 0.13);
      box-shadow:
        0 16px 42px rgba(0, 0, 0, 0.16),
        inset 0 1px 0 rgba(255, 255, 255, 0.08);
      backdrop-filter: blur(14px) saturate(160%);
    }

    .ppb-label {
      display: block;
      margin-bottom: 14px;
      font-size: 11px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: #ffc8e0;
      font-weight: 700;
    }

    .ppb-narrative h2 {
      margin: 0 0 18px;
      font-size: clamp(1.7rem, 3.2vw, 2.6rem);
      font-weight: 900;
      line-height: 1.05;
      background: linear-gradient(135deg, #fff, #ffd6e8);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .ppb-narrative p {
      margin: 0;
      font-size: 1.02rem;
      line-height: 1.78;
      color: #dcdcdc;
    }

    .ppb-reasons-list {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .ppb-reason {
      display: flex;
      gap: 16px;
      align-items: flex-start;
      padding: 18px 20px;
      border-radius: 18px;
      background: linear-gradient(160deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.03));
      border: 1px solid rgba(255, 255, 255, 0.11);
      box-shadow: 0 6px 20px rgba(0, 0, 0, 0.1);
      backdrop-filter: blur(12px);
      transition: border-color .18s ease, background .18s ease, transform .18s ease;
    }

    .ppb-reason:hover {
      border-color: rgba(255, 171, 204, 0.24);
      background: linear-gradient(160deg, rgba(255, 171, 204, 0.09), rgba(255, 255, 255, 0.04));
      transform: translateX(4px);
    }

    .ppb-reason-n {
      flex-shrink: 0;
      width: 44px;
      height: 44px;
      border-radius: 14px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(255, 171, 204, 0.15);
      border: 1px solid rgba(255, 171, 204, 0.28);
      color: #ffd6e8;
      font-size: 12px;
      font-weight: 800;
      letter-spacing: 0.04em;
    }

    .ppb-reason-body strong {
      display: block;
      color: #fff;
      font-size: 0.96rem;
      margin-bottom: 4px;
    }

    .ppb-reason-body span {
      display: block;
      color: #c8c8c8;
      font-size: 13.5px;
      line-height: 1.52;
    }

    /* ---- Problem cards grid ---- */

    .ppb-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 14px;
      margin-bottom: 20px;
    }

    .ppb-card {
      position: relative;
      overflow: hidden;
      padding: 22px 20px 20px;
      border-radius: 20px;
      background: linear-gradient(160deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.03));
      border: 1px solid rgba(255, 255, 255, 0.11);
      box-shadow:
        0 8px 24px rgba(0, 0, 0, 0.12),
        inset 0 1px 0 rgba(255, 255, 255, 0.07);
      backdrop-filter: blur(12px);
      transition: transform .2s ease, border-color .2s ease, background .2s ease;
    }

    .ppb-card:hover {
      transform: translateY(-4px);
      border-color: rgba(255, 171, 204, 0.34);
      background: linear-gradient(160deg, rgba(255, 171, 204, 0.1), rgba(255, 255, 255, 0.05));
      box-shadow:
        0 16px 40px rgba(0, 0, 0, 0.18),
        0 0 40px rgba(255, 171, 204, 0.06),
        inset 0 1px 0 rgba(255, 255, 255, 0.1);
    }

    .ppb-card-n {
      width: 36px;
      height: 36px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(255, 171, 204, 0.14);
      border: 1px solid rgba(255, 171, 204, 0.22);
      color: #ffd6e8;
      font-size: 12px;
      font-weight: 800;
      margin-bottom: 14px;
    }

    .ppb-card h3 {
      margin: 0 0 8px;
      font-size: 1.0rem;
      font-weight: 700;
      color: #fff;
    }

    .ppb-card p {
      margin: 0;
      font-size: 13.5px;
      color: #cdcdcd;
      line-height: 1.56;
    }

    /* ---- Answer strip ---- */

    .ppb-answer {
      padding: 22px 32px;
      border-radius: 20px;
      background: linear-gradient(160deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.03));
      border: 1px solid rgba(255, 255, 255, 0.12);
      box-shadow:
        0 8px 28px rgba(0, 0, 0, 0.14),
        inset 0 1px 0 rgba(255, 255, 255, 0.07);
      backdrop-filter: blur(14px);
      text-align: center;
      font-size: 1.05rem;
      line-height: 1.72;
      color: #d8d8d8;
    }

    .ppb-answer strong {
      color: #fff;
    }

    /* ==========================================
       WATCH WHATEVER U WANT
       ========================================== */

    .poke-watch-section {
      margin: 4.5em auto 2.5em;
      max-width: 1200px;
      padding: 0 20px;
    }

    .poke-watch-heading {
      text-align: center;
      font-size: clamp(2.2rem, 5.5vw, 3.8rem);
      font-weight: 900;
      letter-spacing: -0.02em;
      margin-bottom: 0.2em;
      background: linear-gradient(135deg, #fff 0%, #ffabcc 50%, #c084fc 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      filter: drop-shadow(0 2px 12px rgba(255, 171, 204, 0.15));
    }

    .poke-watch-subheading {
      text-align: center;
      max-width: 680px;
      margin: 0 auto 2.2em;
      line-height: 1.72;
      color: #ccc;
      font-size: 1.06rem;
    }

    .poke-watch-shell {
      position: relative;
      border-radius: 28px;
      background: linear-gradient(160deg, rgba(255, 255, 255, 0.1), rgba(255, 255, 255, 0.04));
      border: 1px solid rgba(255, 255, 255, 0.16);
      box-shadow:
        0 20px 56px rgba(0, 0, 0, 0.26),
        0 0 100px rgba(255, 171, 204, 0.04),
        inset 0 1px 0 rgba(255, 255, 255, 0.14);
      backdrop-filter: blur(18px) saturate(180%);
      padding: 30px;
    }

    .poke-watch-tabs {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      justify-content: center;
      margin-bottom: 22px;
    }

    .poke-watch-tab {
      border: 1px solid rgba(255, 255, 255, 0.16);
      background: rgba(255, 255, 255, 0.06);
      color: #fff;
      border-radius: 14px;
      padding: 12px 26px;
      font: inherit;
      font-weight: 700;
      font-size: 0.95rem;
      cursor: pointer;
      backdrop-filter: blur(8px);
      transition: transform .16s ease, background .2s ease, border-color .2s ease, box-shadow .2s ease;
    }

    .poke-watch-tab:hover {
      transform: translateY(-1px);
      border-color: rgba(255, 171, 204, 0.3);
      background: rgba(255, 255, 255, 0.1);
    }

    .poke-watch-tab[aria-selected="true"] {
      background: linear-gradient(135deg, rgba(255, 171, 204, 0.24), rgba(192, 132, 252, 0.16));
      border-color: rgba(255, 171, 204, 0.58);
      box-shadow:
        0 0 0 3px rgba(255, 171, 204, 0.1),
        0 4px 16px rgba(255, 171, 204, 0.1),
        inset 0 1px 0 rgba(255, 255, 255, 0.14);
    }

    .poke-watch-panels {
      position: relative;
    }

    .poke-watch-panel {
      display: none;
      animation: pokeFade .22s ease;
    }

    .poke-watch-panel.is-active {
      display: grid;
      grid-template-columns: 1fr 1.65fr;
      gap: 24px;
      align-items: center;
    }

    .poke-watch-panel-copy {
      padding: 8px 4px;
    }

    .poke-watch-panel-copy h3 {
      margin: 0 0 14px;
      font-size: clamp(1.3rem, 2.6vw, 1.9rem);
      font-weight: 800;
      line-height: 1.15;
      background: linear-gradient(135deg, #fff, #ffd6e8);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .poke-watch-panel-copy p {
      margin: 0;
      font-size: 1rem;
      color: #c8c8c8;
      line-height: 1.72;
    }

    .poke-watch-shot {
      width: 100%;
      display: block;
      border-radius: 18px;
      border: 1px solid rgba(255, 255, 255, 0.14);
      background: rgba(0, 0, 0, 0.2);
      box-shadow:
        0 10px 32px rgba(0, 0, 0, 0.22),
        0 0 60px rgba(255, 171, 204, 0.04);
      object-fit: cover;
      transition: transform .25s ease, box-shadow .25s ease;
    }

    .poke-watch-shot:hover {
      transform: scale(1.015);
      box-shadow:
        0 14px 40px rgba(0, 0, 0, 0.28),
        0 0 80px rgba(255, 171, 204, 0.06);
    }

    @keyframes pokeFade {
      from { opacity: 0; transform: translateY(6px); }
      to   { opacity: 1; transform: translateY(0);   }
    }

    /* ==========================================
       FAQ
       ========================================== */

    .poke-faq-section {
      margin: 4.5em auto 2.5em;
      max-width: 1200px;
      padding: 0 20px;
    }

    .poke-faq-heading {
      text-align: center;
      font-size: clamp(2rem, 5vw, 3.5rem);
      font-weight: 900;
      letter-spacing: -0.02em;
      margin-bottom: 0.2em;
      background: linear-gradient(135deg, #fff 0%, #ffabcc 50%, #c084fc 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      filter: drop-shadow(0 2px 12px rgba(255, 171, 204, 0.15));
    }

    .poke-faq-subheading {
      text-align: center;
      max-width: 720px;
      margin: 0 auto 2em;
      line-height: 1.72;
      color: #ccc;
      font-size: 1.03rem;
    }

    .poke-faq-list {
      display: grid;
      gap: 14px;
    }

    .poke-faq-item {
      border-radius: 22px;
      background: linear-gradient(160deg, rgba(255, 255, 255, 0.1), rgba(255, 255, 255, 0.04));
      border: 1px solid rgba(255, 255, 255, 0.14);
      box-shadow:
        0 16px 42px rgba(0, 0, 0, 0.16),
        inset 0 1px 0 rgba(255, 255, 255, 0.1);
      backdrop-filter: blur(16px) saturate(180%);
      padding: 20px 22px;
      overflow: hidden;
      transition: border-color .2s ease, background .2s ease, box-shadow .2s ease;
    }

    .poke-faq-item:hover {
      border-color: rgba(255, 171, 204, 0.22);
      background: linear-gradient(160deg, rgba(255, 171, 204, 0.08), rgba(255, 255, 255, 0.04));
    }

    .poke-faq-item[open] {
      border-color: rgba(255, 171, 204, 0.3);
      box-shadow:
        0 16px 42px rgba(0, 0, 0, 0.16),
        0 0 40px rgba(255, 171, 204, 0.04),
        inset 0 1px 0 rgba(255, 255, 255, 0.12);
    }

    .poke-faq-item summary {
      list-style: none;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 18px;
      color: #fff;
      font-size: 1.02rem;
      font-weight: 800;
      line-height: 1.4;
    }

    .poke-faq-item summary::-webkit-details-marker {
      display: none;
    }

    .poke-faq-item summary::after {
      content: "+";
      flex-shrink: 0;
      width: 34px;
      height: 34px;
      border-radius: 12px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: rgba(255, 171, 204, 0.14);
      border: 1px solid rgba(255, 171, 204, 0.26);
      color: #ffd6e8;
      font-size: 1.25rem;
      line-height: 1;
      transition: transform .18s ease, background .18s ease, border-color .18s ease;
    }

    .poke-faq-item[open] summary::after {
      transform: rotate(45deg);
      background: rgba(255, 171, 204, 0.22);
      border-color: rgba(255, 171, 204, 0.4);
    }

    .poke-faq-a {
      margin-top: 14px;
      color: #d5d5d5;
      font-size: 0.98rem;
      line-height: 1.76;
      max-width: 930px;
      animation: pokeFade .25s ease;
    }

    /* ==========================================
       RESPONSIVE
       ========================================== */

    @media (max-width: 1100px) {
      .ppb-two {
        grid-template-columns: 1fr;
      }

      .ppb-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 820px) {
      .poke-watch-panel.is-active {
        display: block;
      }

      .poke-watch-panel-copy {
        margin-bottom: 16px;
        text-align: center;
      }
    }

    @media (max-width: 700px) {
      .ppb-hero {
        padding: 34px 24px 30px;
        border-radius: 22px;
      }

      .ppb-hero-title {
        font-size: clamp(3rem, 14vw, 5.5rem);
      }

      .ppb-narrative {
        padding: 26px 22px;
        border-radius: 20px;
      }

      .ppb-grid {
        grid-template-columns: 1fr;
      }

      .ppb-card {
        border-radius: 18px;
        padding: 18px 16px;
      }

      .ppb-answer {
        padding: 18px 20px;
        font-size: 0.98rem;
        border-radius: 18px;
      }

      .poke-watch-shell {
        padding: 18px;
        border-radius: 22px;
      }

      .poke-watch-tab {
        width: 100%;
        text-align: center;
        justify-content: center;
      }

      .poke-watch-shot {
        border-radius: 14px;
      }

      .problem-jump {
        width: 52px;
        height: 52px;
        border-radius: 18px;
        bottom: 20px;
      }

      .poke-faq-item {
        border-radius: 18px;
        padding: 16px 16px;
      }

      .poke-faq-item summary {
        font-size: 0.98rem;
      }

      .poke-faq-a {
        font-size: 0.95rem;
      }
    }
  </style>

</head>

<body>

