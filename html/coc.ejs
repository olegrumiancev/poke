<!-- TTS FAB + Player -->
<style>
  #tts-fab {
    position: fixed; bottom: 24px; right: 24px; z-index: 99;
    width: 56px; height: 56px; border-radius: 50%;
    background: #ffabcc; border: none; color: #0b0b0b;
    font-size: 1.3rem; cursor: pointer;
    box-shadow: 0 4px 20px rgba(255,171,204,0.4);
    display: flex; align-items: center; justify-content: center;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  #tts-fab:hover { transform: scale(1.1); box-shadow: 0 6px 28px rgba(255,171,204,0.5); }
  #tts-fab .fab-label {
    position: absolute; right: 68px; white-space: nowrap;
    background: #222; color: #eee; padding: 6px 12px; border-radius: 8px;
    font-size: 0.82rem; font-weight: 500; pointer-events: none;
    opacity: 0; transition: opacity 0.2s;
    box-shadow: 0 2px 12px rgba(0,0,0,0.5);
  }
  #tts-fab:hover .fab-label { opacity: 1; }

  #tts-player {
    position: fixed; bottom: 0; left: 0; right: 0; z-index: 100;
    background: #1a1a1a; border-top: 2px solid #ffabcc;
    transform: translateY(100%); transition: transform 0.3s ease;
    font-family: system-ui, sans-serif;
    box-shadow: 0 -4px 30px rgba(0,0,0,0.6);
  }
  #tts-player.open { transform: translateY(0); }

  #tts-player .tts-row {
    display: flex; flex-wrap: wrap; align-items: center; gap: 10px;
    padding: 12px 16px;
  }
  #tts-player button {
    border: none; cursor: pointer; display: flex;
    align-items: center; justify-content: center;
    font-family: system-ui, sans-serif;
  }
  .tts-ctrl {
    width: 38px; height: 38px; border-radius: 50%;
    background: rgba(255,171,204,0.12); color: #ffabcc;
    border: 1px solid rgba(255,171,204,0.3) !important; font-size: 1.05rem;
  }
  .tts-ctrl:hover { background: rgba(255,171,204,0.25); }
  .tts-skip {
    height: 32px; padding: 0 12px; border-radius: 8px;
    background: rgba(255,255,255,0.05); color: #ccc;
    border: 1px solid #444 !important; font-size: 0.82rem; font-weight: 500;
  }
  .tts-skip:hover { background: rgba(255,255,255,0.1); color: #fff; }

  #tts-seekbar-wrap {
    width: 100%; height: 6px; background: #333; cursor: pointer;
  }
  #tts-seekbar-fill {
    height: 100%; background: #ffabcc; width: 0%;
    pointer-events: none; transition: width 0.15s;
  }
  .tts-select {
    background: #222; color: #eee; border: 1px solid #444;
    border-radius: 6px; padding: 4px 8px; font-size: 0.82rem;
  }
  #tts-status-text {
    color: #999; font-size: 0.82rem; white-space: nowrap;
    overflow: hidden; text-overflow: ellipsis; max-width: 200px;
  }
  #tts-close {
    width: 32px; height: 32px; border-radius: 8px;
    background: rgba(255,255,255,0.05); color: #888;
    border: 1px solid #333 !important; font-size: 0.95rem;
    margin-left: auto;
  }
  #tts-close:hover { color: #fff; background: rgba(255,255,255,0.1); }

  #tts-beta {
    font-size: 0.7rem; color: #ffabcc; background: rgba(255,171,204,0.1);
    border: 1px solid rgba(255,171,204,0.2); border-radius: 4px;
    padding: 2px 6px; font-weight: 700; letter-spacing: 0.5px;
    cursor: help; position: relative;
  }
  #tts-beta-popup {
    display: none; position: absolute; bottom: 28px; left: 50%;
    transform: translateX(-50%); width: 260px;
    background: #222; border: 1px solid #444; border-radius: 10px;
    padding: 12px; font-size: 0.8rem; color: #ccc; line-height: 1.5;
    box-shadow: 0 4px 20px rgba(0,0,0,0.6); z-index: 200;
    font-weight: 400; letter-spacing: 0;
  }
  #tts-beta:hover #tts-beta-popup { display: block; }

  .tts-slider-group {
    display: flex; align-items: center; gap: 4px;
  }
  .tts-slider-group label {
    color: #888; font-size: 0.78rem; min-width: 34px;
  }
  .tts-slider-group input[type="range"] {
    width: 65px; accent-color: #ffabcc;
  }
  .tts-slider-group span {
    color: #ffabcc; font-size: 0.8rem; min-width: 30px;
  }

  @media (max-width: 640px) {
    #tts-fab { bottom: 16px; right: 16px; width: 48px; height: 48px; font-size: 1.1rem; }
    #tts-fab .fab-label { display: none; }
    .tts-select { max-width: 120px; }
    .tts-slider-group input[type="range"] { width: 50px; }
  }
</style>

<button id="tts-fab" title="Listen to this page" aria-label="Open text-to-speech reader">
  &#9654;
  <span class="fab-label">Listen to this page</span>
</button>

<div id="tts-player" role="region" aria-label="Text-to-speech player">
  <div id="tts-seekbar-wrap" title="Click to jump to a section">
    <div id="tts-seekbar-fill"></div>
  </div>
  <div class="tts-row">
    <button id="tts-prev" class="tts-skip" title="Previous section">&#9664; Prev</button>
    <button id="tts-play" class="tts-ctrl" title="Play">&#9654;</button>
    <button id="tts-pause" class="tts-ctrl" title="Pause" style="display:none">&#10074;&#10074;</button>
    <button id="tts-next" class="tts-skip" title="Next section">Next &#9654;</button>

    <div class="tts-slider-group">
      <label for="tts-speed">Speed</label>
      <input id="tts-speed" type="range" min="0.5" max="2.5" step="0.1" value="1.0">
      <span id="tts-speed-val">1.0x</span>
    </div>

    <div class="tts-slider-group">
      <label for="tts-vol">Vol</label>
      <input id="tts-vol" type="range" min="0" max="1" step="0.05" value="1.0">
      <span id="tts-vol-val">100%</span>
    </div>

    <select id="tts-section-select" class="tts-select" title="Jump to section" style="max-width:180px"></select>
    <select id="tts-voice" class="tts-select" title="Voice" style="max-width:150px"></select>

    <span id="tts-beta">BETA
      <div id="tts-beta-popup">
        <strong style="color:#ffabcc">Text-to-Speech is in beta</strong><br>
        This uses your browser's built-in speech synthesis. Quality varies between
        browsers and operating systems. You might notice some words sound weird,
        timing can be a little off, and some voices are better than others.
        We're working on it!
      </div>
    </span>
    <span id="tts-status-text">Ready</span>
    <button id="tts-close" title="Close player">&#10005;</button>
  </div>
</div>

<script>
(function () {
  if (!('speechSynthesis' in window)) {
    var fab = document.getElementById('tts-fab');
    if (fab) fab.style.display = 'none';
    return;
  }

  var synth = window.speechSynthesis;
  var fab = document.getElementById('tts-fab');
  var player = document.getElementById('tts-player');
  var playBtn = document.getElementById('tts-play');
  var pauseBtn = document.getElementById('tts-pause');
  var prevBtn = document.getElementById('tts-prev');
  var nextBtn = document.getElementById('tts-next');
  var closeBtn = document.getElementById('tts-close');
  var speedSlider = document.getElementById('tts-speed');
  var speedVal = document.getElementById('tts-speed-val');
  var volSlider = document.getElementById('tts-vol');
  var volVal = document.getElementById('tts-vol-val');
  var sectionSelect = document.getElementById('tts-section-select');
  var voiceSelect = document.getElementById('tts-voice');
  var statusText = document.getElementById('tts-status-text');
  var seekWrap = document.getElementById('tts-seekbar-wrap');
  var seekFill = document.getElementById('tts-seekbar-fill');

  var sections = [];
  var curIdx = 0;
  var playing = false;
  var paused = false;

  function cleanForTTS(raw) {
    return raw
      .replace(/\n+/g, ' ')
      .replace(/\s+/g, ' ')
      .replace(/\.{2,}/g, '.')
      .replace(/\.\s*\./g, '.')
      .replace(/(\.\s){2,}/g, '. ')
      .replace(/\u2014/g, ', ')
      .replace(/\u2013/g, ', ')
      .replace(/-{2,}/g, ', ')
      .replace(/\s*[.]\s*$/g, '')
      .trim();
  }

  // get visible text from a section, reading it in DOM order
  function getVisibleText(sectionEl) {
    var walker = document.createTreeWalker(
      sectionEl, NodeFilter.SHOW_TEXT, {
        acceptNode: function (node) {
          var el = node.parentElement;
          if (!el) return NodeFilter.FILTER_REJECT;
          // skip hidden elements
          if (el.offsetParent === null && el.tagName !== 'BODY') return NodeFilter.FILTER_REJECT;
          // skip content inside closed details (except summary)
          var det = el.closest('details');
          if (det && !det.open && !el.closest('summary')) return NodeFilter.FILTER_REJECT;
          // skip script/style
          var tag = el.tagName;
          if (tag === 'SCRIPT' || tag === 'STYLE') return NodeFilter.FILTER_REJECT;
          return NodeFilter.FILTER_ACCEPT;
        }
      }
    );
    var parts = [];
    var node;
    while (node = walker.nextNode()) {
      var t = node.textContent.trim();
      if (t.length > 1) parts.push(t);
    }
    return cleanForTTS(parts.join(' '));
  }

  function gatherSections() {
    sections = [];
    sectionSelect.innerHTML = '';
    var els = document.querySelectorAll('main.content > section[id]');
    for (var i = 0; i < els.length; i++) {
      var sec = els[i];
      var heading = sec.querySelector('h2.section');
      if (!heading) heading = sec.querySelector('h2');
      var title = heading ? heading.textContent.trim() : sec.id;
      var text = getVisibleText(sec);
      if (text.length > 10) {
        sections.push({ id: sec.id, title: title, text: text, el: sec });
        var opt = document.createElement('option');
        opt.value = sections.length - 1;
        opt.textContent = sections.length + '. ' + title.substring(0, 32);
        sectionSelect.appendChild(opt);
      }
    }
  }

  function loadVoices() {
    var voices = synth.getVoices();
    voiceSelect.innerHTML = '';
    var en = [], other = [];
    for (var i = 0; i < voices.length; i++) {
      if (voices[i].lang.startsWith('en')) en.push(voices[i]);
      else other.push(voices[i]);
    }
    var all = en.concat(other);
    for (var i = 0; i < all.length; i++) {
      var opt = document.createElement('option');
      opt.setAttribute('data-idx', voices.indexOf(all[i]));
      opt.textContent = all[i].name.substring(0, 26) + ' (' + all[i].lang + ')';
      voiceSelect.appendChild(opt);
    }
  }
  synth.onvoiceschanged = loadVoices;
  loadVoices();

  speedSlider.addEventListener('input', function () {
    speedVal.textContent = parseFloat(this.value).toFixed(1) + 'x';
  });
  volSlider.addEventListener('input', function () {
    volVal.textContent = Math.round(parseFloat(this.value) * 100) + '%';
  });

  function getVoice() {
    var voices = synth.getVoices();
    var sel = voiceSelect.selectedOptions[0];
    if (!sel) return null;
    return voices[parseInt(sel.getAttribute('data-idx'))] || null;
  }

  function updateSeek() {
    if (!sections.length) return;
    seekFill.style.width = ((curIdx + 1) / sections.length * 100) + '%';
    sectionSelect.value = curIdx;
  }

  function scrollToSec(sec) {
    sec.el.scrollIntoView({ behavior: 'smooth', block: 'start' });
    sec.el.style.transition = 'outline-color 0.3s';
    sec.el.style.outline = '2px solid rgba(255,171,204,0.25)';
    sec.el.style.outlineOffset = '6px';
    sec.el.style.borderRadius = '8px';
    setTimeout(function () { sec.el.style.outline = 'none'; }, 2500);
  }

  function showPlay() { playBtn.style.display = ''; pauseBtn.style.display = 'none'; }
  function showPause() { playBtn.style.display = 'none'; pauseBtn.style.display = ''; }

  function splitChunks(text) {
    var bits = text.match(/[^,;.!?]+[,;.!?]*\s*/g) || [text];
    var chunks = [];
    var buf = '';
    for (var i = 0; i < bits.length; i++) {
      if (buf.length + bits[i].length > 160 && buf.length > 0) {
        chunks.push(buf.trim());
        buf = '';
      }
      buf += bits[i];
    }
    if (buf.trim()) chunks.push(buf.trim());
    return chunks;
  }

  function speakSection(idx) {
    if (idx >= sections.length) {
      playing = false; paused = false;
      showPlay();
      statusText.textContent = 'Finished';
      seekFill.style.width = '100%';
      return;
    }
    if (idx < 0) idx = 0;
    curIdx = idx;
    var sec = sections[idx];
    statusText.textContent = sec.title;
    scrollToSec(sec);
    updateSeek();

    var chunks = splitChunks(sec.text);
    var ci = 0;

    function next() {
      if (!playing || paused) return;
      if (ci >= chunks.length) { speakSection(idx + 1); return; }
      var u = new SpeechSynthesisUtterance(chunks[ci]);
      u.rate = parseFloat(speedSlider.value);
      u.volume = parseFloat(volSlider.value);
      u.voice = getVoice();
      u.onend = function () { ci++; next(); };
      u.onerror = function () { ci++; next(); };
      synth.speak(u);
    }
    next();
  }

  fab.addEventListener('click', function () {
    gatherSections();
    player.classList.add('open');
    fab.style.display = 'none';
  });

  closeBtn.addEventListener('click', function () {
    synth.cancel();
    playing = false; paused = false;
    showPlay();
    statusText.textContent = 'Ready';
    seekFill.style.width = '0%';
    player.classList.remove('open');
    fab.style.display = '';
  });

  playBtn.addEventListener('click', function () {
    if (paused) {
      paused = false; playing = true;
      showPause();
      synth.cancel();
      speakSection(curIdx);
      return;
    }
    if (playing) return;
    synth.cancel();
    gatherSections();
    if (!sections.length) { statusText.textContent = 'Nothing to read'; return; }
    playing = true; paused = false;
    showPause();
    speakSection(curIdx || 0);
  });

  pauseBtn.addEventListener('click', function () {
    if (playing && !paused) {
      synth.cancel();
      paused = true;
      showPlay();
      statusText.textContent = 'Paused: ' + (sections[curIdx] ? sections[curIdx].title : '');
    }
  });

  function jumpTo(t) {
    synth.cancel();
    curIdx = t; updateSeek();
    if (sections[t]) { scrollToSec(sections[t]); statusText.textContent = sections[t].title; }
    if (playing && !paused) { speakSection(t); showPause(); }
  }

  prevBtn.addEventListener('click', function () { if (sections.length) jumpTo(Math.max(0, curIdx - 1)); });
  nextBtn.addEventListener('click', function () { if (sections.length) jumpTo(Math.min(sections.length - 1, curIdx + 1)); });
  sectionSelect.addEventListener('change', function () { var t = parseInt(this.value); if (!isNaN(t) && sections[t]) jumpTo(t); });

  seekWrap.addEventListener('click', function (e) {
    if (!sections.length) return;
    var rect = seekWrap.getBoundingClientRect();
    var pct = (e.clientX - rect.left) / rect.width;
    jumpTo(Math.min(sections.length - 1, Math.max(0, Math.floor(pct * sections.length))));
  });

  document.addEventListener('keydown', function (e) {
    if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA' || e.target.tagName === 'SELECT') return;
    if (e.key === ' ' && e.shiftKey) {
      e.preventDefault();
      if (playing && !paused) pauseBtn.click();
      else playBtn.click();
    }
  });
})();
</script>
</body>
</html>