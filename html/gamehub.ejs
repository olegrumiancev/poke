        </select>
      </div>

      <div class="setting-group" id="diff-group">
        <label>AI Difficulty</label>
        <select id="set-difficulty">
          <option value="easy">Easy (Loose)</option>
          <option value="medium">Normal (Tough)</option>
          <option value="hard" selected>Hard (Unbeatable)</option>
        </select>
      </div>

      <div class="setting-group">
        <label>Start As</label>
