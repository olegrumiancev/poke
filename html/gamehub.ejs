     .bwrap { flex: 1; overflow: auto; display: flex; align-items: flex-start; justify-content: center; padding: 8px; background: var(--bg); position: relative; }
    .bframe {
      border-top: 3px solid var(--bevel-dark); border-left: 3px solid var(--bevel-dark);
      border-bottom: 3px solid var(--bevel-light); border-right: 3px solid var(--bevel-light);
      background: var(--bevel-mid); flex-shrink: 0;
    }
    #grid { display: grid; gap: 0; line-height: 1; }

    .c {
      width: var(--cell); height: var(--cell);
      background: var(--surface-raised);
      border-top: 2px solid var(--bevel-light); border-left: 2px solid var(--bevel-light);
      border-bottom: 2px solid var(--bevel-dark); border-right: 2px solid var(--bevel-dark);
      display: flex; align-items: center; justify-content: center;
