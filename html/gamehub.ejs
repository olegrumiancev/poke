  }
  .touch-zone.left { left: 0; }
  .touch-zone.right { right: 0; }
</style>
</head>
<body>
<div id="cab">
  <div id="crt"></div>
  <div id="hud"><span id="sl">0</span><span id="sr">0</span></div>
  <div id="msg"></div>
  <div id="submsg"></div>

  <!-- Touch zones for mobile -->
  <div class="touch-zone left" id="tz-left"></div>
  <div class="touch-zone right" id="tz-right"></div>

  <!-- Main Menu -->
  <div id="ov-menu" class="ov">
    <h1>POKE<br>PONG 2</h1>
    <div class="mg">
      <button id="btn-1p">1 Player</button>
      <button id="btn-2p">2 Players</button>
    </div>
    <div class="controls-hint">
      W/S or touch left side — Player 1<br>
      ↑/↓ or touch right side — Player 2
    </div>
  </div>

  <!-- Pause -->
  <div id="ov-pause" class="ov hidden">
    <h1 style="font-size:1.5rem;text-shadow:none;color:var(--primary)">PAUSED</h1>
    <div class="mg">
      <div class="sr"><label>Difficulty</label>
        <select id="s-diff">
          <option value="easy">Easy</option>
          <option value="medium" selected>Medium</option>
          <option value="hard">Impossible</option>
        </select>
      </div>
      <div class="sr"><label>Ball Speed</label><input type="range" id="s-speed" min="4" max="12" value="6"></div>
      <div class="sr"><label>Win Score</label>
        <select id="s-score">
          <option value="5">5</option>
          <option value="10" selected>10</option>
          <option value="21">21</option>
        </select>
      </div>
      <div class="sr"><label>Theme</label><input type="color" id="s-color" value="#00ff99"></div>
      <button id="btn-resume">Resume</button>
      <button id="btn-quit">Quit to Menu</button>
    </div>
  </div>

  <button id="gear">⚙️</button>
  <canvas id="cv" width="800" height="600"></canvas>
</div>

<script>
const SFX = {
  ctx: new (window.AudioContext || window.webkitAudioContext)(),
  play(t) {
    if (this.ctx.state === 'suspended') this.ctx.resume();
    const o = this.ctx.createOscillator(), g = this.ctx.createGain();
    o.connect(g); g.connect(this.ctx.destination);
    const n = this.ctx.currentTime;
    ({
      hit() {
        o.type = 'square';
        o.frequency.setValueAtTime(440, n);
        o.frequency.exponentialRampToValueAtTime(120, n + 0.08);
        g.gain.setValueAtTime(0.1, n);
        g.gain.exponentialRampToValueAtTime(0.001, n + 0.08);
        o.start(n); o.stop(n + 0.08);
      },
      smash() {
        o.type = 'sawtooth';
        o.frequency.setValueAtTime(600, n);
        o.frequency.exponentialRampToValueAtTime(80, n + 0.15);
        g.gain.setValueAtTime(0.15, n);
        g.gain.exponentialRampToValueAtTime(0.001, n + 0.15);
        o.start(n); o.stop(n + 0.15);
      },
      wall() {
        o.type = 'triangle';
        o.frequency.setValueAtTime(200, n);
        g.gain.setValueAtTime(0.06, n);
        g.gain.linearRampToValueAtTime(0, n + 0.04);
        o.start(n); o.stop(n + 0.04);
      },
      score() {
        o.type = 'sine';
        o.frequency.setValueAtTime(400, n);
        o.frequency.linearRampToValueAtTime(900, n + 0.15);
        g.gain.setValueAtTime(0.1, n);
        g.gain.linearRampToValueAtTime(0, n + 0.3);
        o.start(n); o.stop(n + 0.3);
      },
      win() {
        o.type = 'sine';
        o.frequency.setValueAtTime(523, n);
        o.frequency.setValueAtTime(659, n + 0.12);
        o.frequency.setValueAtTime(784, n + 0.24);
        o.frequency.setValueAtTime(1047, n + 0.36);
        g.gain.setValueAtTime(0.1, n);
        g.gain.linearRampToValueAtTime(0, n + 0.6);
        o.start(n); o.stop(n + 0.6);
      }
    })[t]?.();
  }
};

/* ═══════ GAME ═══════ */
const G = {
  cv: document.getElementById('cv'),
  W: 800, H: 600,
  state: 'menu', mode: 'pvc', loopId: null,

  // Settings
  winScore: 10, diff: 'medium', baseSpeed: 6, accent: '#00ff99',

  // Entities
  ball: {}, p1: {}, p2: {},

  // Input
  keys: {},
  touchY: { left: null, right: null },

  // FX
  particles: [], trails: [], shake: 0, freeze: 0,

  init() {
    this.cx = this.cv.getContext('2d');

    // Keyboard
    window.addEventListener('keydown', e => { this.keys[e.key] = true; if (['ArrowUp','ArrowDown','w','s'].includes(e.key)) e.preventDefault(); });
    window.addEventListener('keyup', e => this.keys[e.key] = false);

    // Touch — each half controls one paddle
    const tzL = document.getElementById('tz-left');
    const tzR = document.getElementById('tz-right');

    const touchHandler = (zone, side) => {
      zone.addEventListener('touchstart', e => { e.preventDefault(); this.updateTouch(e, side); }, { passive: false });
      zone.addEventListener('touchmove', e => { e.preventDefault(); this.updateTouch(e, side); }, { passive: false });
      zone.addEventListener('touchend', () => { this.touchY[side] = null; });
      zone.addEventListener('touchcancel', () => { this.touchY[side] = null; });
    };
    touchHandler(tzL, 'left');
    touchHandler(tzR, 'right');

    // Mouse (for desktop testing — left half only in 1P)
    this.cv.addEventListener('mousemove', e => {
      const rect = this.cv.getBoundingClientRect();
      const y = (e.clientY - rect.top) / rect.height * this.H;
      this.touchY.left = y;
    });

    // Buttons
    document.getElementById('btn-1p').onclick = () => this.start('pvc');
    document.getElementById('btn-2p').onclick = () => this.start('pvp');
    document.getElementById('btn-resume').onclick = () => this.resume();
    document.getElementById('btn-quit').onclick = () => this.toMenu();
    document.getElementById('gear').onclick = () => this.pause();

    // Settings
    document.getElementById('s-color').addEventListener('input', e => {
      this.accent = e.target.value;
      document.documentElement.style.setProperty('--primary', this.accent);
    });
    document.getElementById('s-diff').addEventListener('change', e => this.diff = e.target.value);
    document.getElementById('s-speed').addEventListener('input', e => this.baseSpeed = +e.target.value);
    document.getElementById('s-score').addEventListener('change', e => this.winScore = +e.target.value);
  },

  updateTouch(e, side) {
    const rect = document.getElementById('cab').getBoundingClientRect();
    // Use the last touch for this zone
    const touch = e.touches[e.touches.length - 1];
    const y = (touch.clientY - rect.top) / rect.height * this.H;
    this.touchY[side] = y;
  },

  start(mode) {
    this.mode = mode;
    this.resetMatch();
    this.state = 'playing';
    this.show('ov-menu', false);
    this.show('ov-pause', false);
    document.getElementById('gear').style.display = 'block';
    this.loop();
  },

  pause() {
    if (this.state !== 'playing') return;
    this.state = 'paused';
    this.show('ov-pause', true);
    cancelAnimationFrame(this.loopId);
  },

  resume() {
    if (this.state !== 'paused') return;
    this.state = 'playing';
    this.show('ov-pause', false);
    this.lastTime = performance.now();
    this.loop();
  },

  toMenu() {
    this.state = 'menu';
    this.show('ov-menu', true);
    this.show('ov-pause', false);
    document.getElementById('gear').style.display = 'none';
    cancelAnimationFrame(this.loopId);
  },

  show(id, visible) {
    document.getElementById(id).classList.toggle('hidden', !visible);
  },

  resetMatch() {
    this.p1 = { x: 20, y: 250, w: 14, h: 90, score: 0, vy: 0, prevY: 250 };
    this.p2 = { x: 766, y: 250, w: 14, h: 90, score: 0, vy: 0, prevY: 250 };
    this.particles = [];
    this.trails = [];
    this.updateHUD();
    this.serveBall(1);
  },

  serveBall(dir) {
    const b = this.ball;
    b.x = this.W / 2;
    b.y = this.H / 2;
    b.size = 7;
    b.speed = this.baseSpeed;
    b.active = false; // Brief pause before serving

    const angle = (Math.random() * 0.6 - 0.3); // ±~17°
    b.vx = dir * b.speed * Math.cos(angle);
    b.vy = b.speed * Math.sin(angle);

    // Ensure minimum vertical component so ball isn't boring-flat
    if (Math.abs(b.vy) < 1.5) b.vy = (Math.random() > 0.5 ? 1 : -1) * 1.5;

    this.freeze = 40; // 40 frames of freeze
    this.flashMsg('READY', '');
  },

  flashMsg(text, sub) {
    const el = document.getElementById('msg');
    const sel = document.getElementById('submsg');
    el.textContent = text; el.classList.add('show');
    sel.textContent = sub || ''; if (sub) sel.classList.add('show');
    setTimeout(() => { el.classList.remove('show'); sel.classList.remove('show'); }, 1200);
  },

  /* ═══════ UPDATE ═══════ */
  update(dt) {
    if (this.state !== 'playing') return;

    // Freeze countdown (serve delay)
    if (this.freeze > 0) { this.freeze--; return; }

    const pSpeed = 7;

    // --- P1 Movement ---
    let p1Target = null;
    if (this.keys['w'] || this.keys['W']) this.p1.y -= pSpeed;
    else if (this.keys['s'] || this.keys['S']) this.p1.y += pSpeed;
    else if (this.touchY.left !== null) p1Target = this.touchY.left;

    if (p1Target !== null) {
      const center = this.p1.y + this.p1.h / 2;
      const diff = p1Target - center;
      this.p1.y += Math.sign(diff) * Math.min(Math.abs(diff), pSpeed + 2);
    }

    // --- P2 Movement ---
    if (this.mode === 'pvp') {
      if (this.keys['ArrowUp']) this.p2.y -= pSpeed;
      else if (this.keys['ArrowDown']) this.p2.y += pSpeed;
      else if (this.touchY.right !== null) {
        const center = this.p2.y + this.p2.h / 2;
        const diff = this.touchY.right - center;
        this.p2.y += Math.sign(diff) * Math.min(Math.abs(diff), pSpeed + 2);
      }
    } else {
      this.aiUpdate();
    }

    // Track paddle velocity for spin
    this.p1.vy = this.p1.y - this.p1.prevY;
    this.p2.vy = this.p2.y - this.p2.prevY;
    this.p1.prevY = this.p1.y;
    this.p2.prevY = this.p2.y;

    // Clamp
    this.p1.y = Math.max(0, Math.min(this.H - this.p1.h, this.p1.y));
    this.p2.y = Math.max(0, Math.min(this.H - this.p2.h, this.p2.y));

    // --- BALL ---
    const b = this.ball;
    b.x += b.vx;
    b.y += b.vy;

    // Wall bounce
    if (b.y - b.size <= 0) {
      b.y = b.size;
      b.vy = Math.abs(b.vy);
      this.spawnParticles(b.x, b.y, 4, '#888');
      SFX.play('wall');
    } else if (b.y + b.size >= this.H) {
      b.y = this.H - b.size;
      b.vy = -Math.abs(b.vy);
      this.spawnParticles(b.x, b.y, 4, '#888');
      SFX.play('wall');
    }

    // Paddle collisions
    this.checkPaddleHit(this.p1, 1);
    this.checkPaddleHit(this.p2, -1);

    // Scoring
    if (b.x < -30) { this.p2.score++; this.onScore(-1); }
    else if (b.x > this.W + 30) { this.p1.score++; this.onScore(1); }

    // Trail
    this.trails.push({ x: b.x, y: b.y, life: 1 });
    if (this.trails.length > 20) this.trails.shift();

    // Shake decay
    if (this.shake > 0) { this.shake *= 0.85; if (this.shake < 0.3) this.shake = 0; }

    // Particles
    for (let i = this.particles.length - 1; i >= 0; i--) {
      const p = this.particles[i];
      p.x += p.vx; p.y += p.vy; p.vy += 0.1; p.life -= 0.04;
      if (p.life <= 0) this.particles.splice(i, 1);
    }
  },

  checkPaddleHit(pad, dir) {
    const b = this.ball;
    // Only check when ball is moving toward this paddle
    if (dir === 1 && b.vx > 0) return;
    if (dir === -1 && b.vx < 0) return;

    if (b.x - b.size < pad.x + pad.w &&
        b.x + b.size > pad.x &&
        b.y + b.size > pad.y &&
        b.y - b.size < pad.y + pad.h) {

      // Where on paddle? -1 (top) to 1 (bottom)
      const hitPos = ((b.y - (pad.y + pad.h / 2)) / (pad.h / 2));
      const clampedHit = Math.max(-1, Math.min(1, hitPos));

      // Base angle: up to 60° at edges, flatter in center
      const maxAngle = Math.PI / 3; // 60°
      let angle = clampedHit * maxAngle;

      // Add spin from paddle movement (up to ±15°)
      const spin = pad.vy * 0.04;
      angle += spin;

      // Clamp total angle to prevent pure-vertical shots
      angle = Math.max(-maxAngle, Math.min(maxAngle, angle));

      // Speed: increase slightly each rally, cap it
      b.speed = Math.min(b.speed + 0.4, this.baseSpeed + 8);

      // Smash detection: paddle moving fast + ball near edge
      const padVel = Math.abs(pad.vy);
      const isSmash = padVel > 5 && Math.abs(clampedHit) > 0.3;

      if (isSmash) {
        b.speed = Math.min(b.speed + 1.5, this.baseSpeed + 10);
        this.shake = 10;
        this.spawnParticles(b.x, b.y, 25, this.accent);
        SFX.play('smash');
        // Flash effect on ball
        b.flash = 8;
      } else {
        this.shake = 4;
        this.spawnParticles(b.x, b.y, 12, '#fff');
        SFX.play('hit');
      }

      b.vx = dir * b.speed * Math.cos(angle);
      b.vy = b.speed * Math.sin(angle);

      // Ensure minimum vy to avoid flat rallies
      if (Math.abs(b.vy) < 1) b.vy = (b.vy >= 0 ? 1 : -1) * 1;

      // Push ball out of paddle
      b.x = dir === 1 ? pad.x + pad.w + b.size : pad.x - b.size;
    }
  },

  /* ═══════ AI ═══════ */
  aiUpdate() {
    const b = this.ball;
    const pad = this.p2;
    const center = pad.y + pad.h / 2;

    let speed, react, errorAmp, anticipation;
    if (this.diff === 'easy')   { speed = 4;   react = 0.55; errorAmp = 50; anticipation = 0; }
    else if (this.diff === 'medium') { speed = 5.5; react = 0.75; errorAmp = 20; anticipation = 0.5; }
    else /* hard */             { speed = 7.5; react = 0.95; errorAmp = 2;  anticipation = 1; }

    let targetY;

    if (b.vx > 0) {
      // Ball coming toward AI — predict landing Y
      targetY = this.predictBallY(anticipation);

      // Add error
      if (!this._aiError || Math.random() < 0.02) {
        this._aiError = (Math.random() - 0.5) * errorAmp;
      }
      targetY += this._aiError;
    } else {
      // Ball going away — drift toward center
      targetY = this.H / 2 + (Math.random() - 0.5) * 40;
    }

    // Only react some fraction of frames
    if (Math.random() < react) {
      const diff = targetY - center;
      if (Math.abs(diff) > 5) {
        pad.y += Math.sign(diff) * Math.min(Math.abs(diff), speed);
      }
    }
  },

  // Predict where ball will arrive at AI's x position
  predictBallY(quality) {
    const b = this.ball;
    if (b.vx <= 0) return this.H / 2;

    // Simple: just use current trajectory
    if (quality < 0.3) return b.y;

    // Better: simulate bounces
    let simX = b.x, simY = b.y, simVx = b.vx, simVy = b.vy;
    const targetX = this.p2.x;
    let steps = 0;

    while (simX < targetX && steps < 200) {
      simX += simVx;
      simY += simVy;
      if (simY <= 0 || simY >= this.H) simVy *= -1;
      steps++;
    }

    return simY;
  },

  onScore(serveDir) {
    SFX.play('score');
    this.updateHUD();

    if (this.p1.score >= this.winScore || this.p2.score >= this.winScore) {
      const w = this.p1.score >= this.winScore ? 'PLAYER 1' : (this.mode === 'pvc' ? 'CPU' : 'PLAYER 2');
      this.flashMsg(w + ' WINS!', 'First to ' + this.winScore);
      SFX.play('win');
      this.state = 'gameover';
      setTimeout(() => this.toMenu(), 3500);
    } else {
      this.serveBall(serveDir);
    }
  },

  updateHUD() {
    document.getElementById('sl').textContent = this.p1.score;
    document.getElementById('sr').textContent = this.p2.score;
  },

  /* ═══════ RENDER ═══════ */
  draw() {
    const cx = this.cx;

    // Fade trail
    cx.fillStyle = 'rgba(10, 10, 16, 0.45)';
    cx.fillRect(0, 0, this.W, this.H);

    cx.save();
    if (this.shake > 0) {
      cx.translate((Math.random()-0.5)*this.shake, (Math.random()-0.5)*this.shake);
    }

    // Center line
    cx.strokeStyle = '#1a1a2a';
    cx.lineWidth = 3;
    cx.setLineDash([8, 14]);
    cx.beginPath(); cx.moveTo(this.W/2, 0); cx.lineTo(this.W/2, this.H); cx.stroke();
    cx.setLineDash([]);

    // Ball trail
    for (let i = 0; i < this.trails.length; i++) {
      const t = this.trails[i];
      const alpha = (i / this.trails.length) * 0.3;
      const sz = this.ball.size * (i / this.trails.length) * 0.8;
      cx.fillStyle = `rgba(255,255,255,${alpha})`;
      cx.beginPath(); cx.arc(t.x, t.y, sz, 0, Math.PI*2); cx.fill();
    }

    cx.shadowColor = this.accent;
    cx.shadowBlur = 12;
    cx.fillStyle = this.accent;

    // Paddles — rounded rects
    this.drawPaddle(cx, this.p1);
    this.drawPaddle(cx, this.p2);

    // Ball
    const b = this.ball;
    if (b.flash && b.flash > 0) {
      cx.shadowBlur = 30;
      cx.shadowColor = '#fff';
      cx.fillStyle = '#fff';
      b.flash--;
    } else {
      cx.shadowBlur = 15;
      cx.fillStyle = '#fff';
    }
    cx.beginPath(); cx.arc(b.x, b.y, b.size, 0, Math.PI*2); cx.fill();

    // Particles
    cx.shadowBlur = 0;
    for (const p of this.particles) {
      cx.fillStyle = p.color.replace(')', `,${p.life})`).replace('rgb', 'rgba');
      cx.fillRect(p.x, p.y, p.size, p.size);
    }

    cx.restore();
  },

  drawPaddle(cx, pad) {
    const r = 4;
    cx.beginPath();
    cx.moveTo(pad.x + r, pad.y);
    cx.lineTo(pad.x + pad.w - r, pad.y);
    cx.quadraticCurveTo(pad.x + pad.w, pad.y, pad.x + pad.w, pad.y + r);
    cx.lineTo(pad.x + pad.w, pad.y + pad.h - r);
    cx.quadraticCurveTo(pad.x + pad.w, pad.y + pad.h, pad.x + pad.w - r, pad.y + pad.h);
    cx.lineTo(pad.x + r, pad.y + pad.h);
    cx.quadraticCurveTo(pad.x, pad.y + pad.h, pad.x, pad.y + pad.h - r);
    cx.lineTo(pad.x, pad.y + r);
    cx.quadraticCurveTo(pad.x, pad.y, pad.x + r, pad.y);
    cx.fill();
  },

  spawnParticles(x, y, n, color) {
    for (let i = 0; i < n; i++) {
      this.particles.push({
        x, y,
        vx: (Math.random() - 0.5) * 8,
        vy: (Math.random() - 0.5) * 8,
        life: 0.7 + Math.random() * 0.3,
        size: 1 + Math.random() * 3,
        color: color.startsWith('#') ? this.hexToRgb(color) : color
      });
    }
  },

  hexToRgb(hex) {
    const r = parseInt(hex.slice(1,3),16);
    const g = parseInt(hex.slice(3,5),16);
    const b = parseInt(hex.slice(5,7),16);
    return `rgb(${r},${g},${b})`;
  },

  /* ═══════ LOOP ═══════ */
  lastTime: 0,
  loop() {
    if (this.state !== 'playing') return;
    this.update();
    this.draw();
    this.loopId = requestAnimationFrame(() => this.loop());
  }
};

G.init();
</script>
</body>
</html>
<% } %>


