<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>POKE PONG 2</title>
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=0">
<link href="https://fonts.bunny.net/css2?family=Press+Start+2P&display=swap" rel="stylesheet">
<style>
  :root {
    --primary: #00ff99;
    --bg: #0a0a10;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html, body { height: 100%; overflow: hidden; touch-action: none; }
  body {
    background: #000; color: var(--primary);
    font-family: 'Press Start 2P', monospace;
    display: flex; justify-content: center; align-items: center;
    height: 100vh;
  }

  #cab {
    position: relative; width: 100%; height: 100%;
    max-width: 1000px; max-height: 700px;
    background: var(--bg); overflow: hidden;
  }

  canvas { display: block; width: 100%; height: 100%; image-rendering: pixelated; }

  #crt {
    position: absolute; inset: 0;
    background: linear-gradient(rgba(18,16,16,0) 50%, rgba(0,0,0,0.2) 50%),
                linear-gradient(90deg, rgba(255,0,0,0.04), rgba(0,255,0,0.02), rgba(0,0,255,0.04));
    background-size: 100% 3px, 3px 100%;
    pointer-events: none; z-index: 10;
    box-shadow: inset 0 0 80px rgba(0,0,0,0.8);
  }

  /* HUD */
  #hud {
    position: absolute; top: 20px; width: 100%;
    display: flex; justify-content: center; gap: 100px;
    font-size: 3rem; pointer-events: none; opacity: 0.4; z-index: 5;
  }
  #msg {
    position: absolute; top: 38%; width: 100%;
    text-align: center; font-size: 1.5rem; color: #fff;
    text-shadow: 0 0 10px var(--primary);
    pointer-events: none; z-index: 5; opacity: 0;
    transition: opacity 0.2s;
  }
  #msg.show { opacity: 1; }
  #submsg {
    position: absolute; top: 48%; width: 100%;
    text-align: center; font-size: 0.6rem; color: #888;
    pointer-events: none; z-index: 5; opacity: 0;
    transition: opacity 0.2s;
  }
  #submsg.show { opacity: 1; }

  /* Overlays */
  .ov {
    position: absolute; inset: 0;
    display: flex; flex-direction: column;
    justify-content: center; align-items: center;
    z-index: 20; background: rgba(0,0,0,0.88);
    backdrop-filter: blur(4px);
    transition: opacity 0.3s;
  }
  .ov.hidden { opacity: 0; pointer-events: none; }

  h1 {
    font-size: clamp(1.8rem, 5vw, 3rem); color: #fff;
    text-shadow: 4px 4px 0 var(--primary);
    margin-bottom: 1.5rem; letter-spacing: -2px;
    text-align: center; line-height: 1.3;
  }

  .mg { display: flex; flex-direction: column; gap: 12px; width: min(300px, 80vw); }

  button {
    background: transparent; border: 2px solid var(--primary);
    color: var(--primary); font-family: 'Press Start 2P';
    padding: 14px; cursor: pointer; text-transform: uppercase;
    font-size: 0.75rem; transition: all 0.15s;
    box-shadow: 0 0 5px var(--primary);
  }
  button:hover { background: var(--primary); color: #000; box-shadow: 0 0 20px var(--primary); }

  .sr {
    display: flex; justify-content: space-between; align-items: center;
    font-size: 0.6rem; color: #aaa; padding: 4px 0;
  }
  select {
    background: #000; color: var(--primary);
    border: 1px solid var(--primary); padding: 5px;
    font-family: inherit; font-size: 0.6rem;
  }
  input[type="range"] { accent-color: var(--primary); cursor: pointer; width: 100px; }
  input[type="color"] { cursor: pointer; }

  #gear {
    position: absolute; bottom: 16px; right: 16px; z-index: 30;
    border: none; box-shadow: none; font-size: 1.2rem; padding: 8px;
  }

  .controls-hint {
    font-size: 0.5rem; color: #555; text-align: center;
