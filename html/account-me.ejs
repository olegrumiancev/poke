<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>My Poke | Subscriptions</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="/css/yt-ukraine.svg?v=6" rel="icon">
  <meta name="librejs-license" content="GPL-3.0-or-later">
  <style>
    :root {
      --bg-body: #121212;
      --bg-sidebar: #181818;
      --bg-element: #252525;
      --bg-hover: #333333;
      --border: #333333;
      --text-main: #e0e0e0;
      --text-muted: #a0a0a0;
      --accent: #3ea6ff; 
      --danger: #ff4e45;
      --e2ee: #4caf7d;
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      padding: 0;
      height: 100vh;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      background-color: var(--bg-body);
      color: var(--text-main);
      display: flex;
      overflow: hidden;
    }

    a { text-decoration: none; color: inherit; }
    button, input { font-family: inherit; }

    aside {
      width: 320px;
      background-color: var(--bg-sidebar);
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      flex-shrink: 0;
    }

    header {
      padding: 16px;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    h1 {
      margin: 0;
      font-size: 1.2rem;
      font-weight: 700;
      color: var(--text-main);
      display: flex;
      align-items: center;
      gap: 8px;
    }

    /* ── E2EE Badge ── */
    .e2ee-badge {
      display: flex;
      align-items: center;
      gap: 5px;
      background: rgba(76, 175, 125, 0.12);
      border: 1px solid rgba(76, 175, 125, 0.35);
      border-radius: 20px;
      padding: 4px 10px 4px 7px;
      cursor: pointer;
      transition: background 0.2s, border-color 0.2s;
      user-select: none;
      flex-shrink: 0;
    }
    .e2ee-badge:hover {
      background: rgba(76, 175, 125, 0.22);
      border-color: var(--e2ee);
    }
    .e2ee-badge svg {
      width: 13px;
      height: 13px;
      fill: var(--e2ee);
      flex-shrink: 0;
    }
    .e2ee-badge span {
      font-size: 11px;
      font-weight: 600;
      color: var(--e2ee);
      letter-spacing: 0.03em;
    }

    /* ── E2EE Modal Overlay ── */
    .e2ee-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.65);
      z-index: 1000;
      align-items: center;
      justify-content: center;
      animation: fadeIn 0.15s ease;
    }
    .e2ee-overlay.open { display: flex; }

    @keyframes fadeIn {
      from { opacity: 0; }
      to   { opacity: 1; }
    }

    .e2ee-modal {
      background: var(--bg-sidebar);
      border: 1px solid var(--border);
      border-top: 3px solid var(--e2ee);
      border-radius: 10px;
      padding: 28px 28px 22px;
      max-width: 360px;
      width: 90%;
      box-shadow: 0 20px 60px rgba(0,0,0,0.7);
      animation: popIn 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
      position: relative;
    }

    @keyframes popIn {
      from { transform: scale(0.88); opacity: 0; }
      to   { transform: scale(1);    opacity: 1; }
    }

    .e2ee-modal-icon {
      width: 48px;
      height: 48px;
      background: rgba(76, 175, 125, 0.15);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 16px;
    }
    .e2ee-modal-icon svg {
      width: 24px;
      height: 24px;
      fill: var(--e2ee);
    }

    .e2ee-modal h2 {
      margin: 0 0 10px;
      font-size: 1rem;
      font-weight: 700;
      color: var(--text-main);
    }

    .e2ee-modal p {
      margin: 0 0 8px;
      font-size: 13px;
      color: var(--text-muted);
      line-height: 1.6;
    }

    .e2ee-detail-list {
      margin: 14px 0 0;
      padding: 0;
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    .e2ee-detail-list li {
      font-size: 12px;
      color: var(--text-muted);
      display: flex;
      align-items: flex-start;
      gap: 8px;
      line-height: 1.5;
    }
    .e2ee-detail-list li::before {
      content: "✦";
      color: var(--e2ee);
      flex-shrink: 0;
      margin-top: 1px;
      font-size: 10px;
    }

    .e2ee-modal-close {
      margin-top: 20px;
      width: 100%;
      padding: 9px;
      background: rgba(76, 175, 125, 0.15);
      border: 1px solid rgba(76, 175, 125, 0.3);
      border-radius: 6px;
      color: var(--e2ee);
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.2s;
    }
    .e2ee-modal-close:hover { background: rgba(76, 175, 125, 0.25); }

    /* Controls (Search & Sort) */
    .controls {
      padding: 10px;
      border-bottom: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .search-wrapper {
      display: flex;
      gap: 5px;
    }

    input[type="text"] {
      flex: 1;
      background: var(--bg-body);
      border: 1px solid var(--border);
      padding: 8px 10px;
      border-radius: 4px;
      color: var(--text-main);
      font-size: 14px;
    }
    input[type="text"]:focus {
      outline: 2px solid var(--accent);
      border-color: transparent;
    }

    .btn {
      padding: 6px 12px;
      background: var(--bg-element);
      border: 1px solid var(--border);
      color: var(--text-main);
      cursor: pointer;
      border-radius: 4px;
      font-size: 13px;
    }
    .btn:hover { background: var(--bg-hover); }
    .btn.active { background: var(--accent); color: #000; font-weight: bold; border-color: var(--accent); }

    .sort-buttons { display: flex; gap: 5px; }
    .sort-buttons button { flex: 1; }

    /* Channel List */
    .channel-list { flex: 1; overflow-y: auto; }

    .channel {
      display: flex;
      align-items: center;
      padding: 10px 16px;
      border-bottom: 1px solid var(--border);
      cursor: pointer;
      transition: background 0.15s;
    }

    .channel:hover { background-color: var(--bg-hover); }
    .channel.selected {
      background-color: var(--bg-element);
      border-left: 4px solid var(--accent);
      padding-left: 12px;
    }

    .channel img {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      margin-right: 12px;
      background: var(--bg-element);
    }

    .channel-info { flex: 1; overflow: hidden; }

    .channel-name {
      font-size: 14px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .unsub-btn {
      font-size: 11px;
      color: var(--danger);
      border: 1px solid var(--border);
      padding: 4px 8px;
      border-radius: 4px;
      margin-left: 10px;
      opacity: 0.6;
      transition: 0.2s;
    }
    .unsub-btn:hover {
      opacity: 1;
      background: rgba(255, 78, 69, 0.1);
      border-color: var(--danger);
    }

    .sidebar-footer {
      padding: 12px;
      border-top: 1px solid var(--border);
      font-size: 12px;
      color: var(--text-muted);
      display: flex;
      justify-content: space-between;
      background: var(--bg-body);
    }

    /* Main Content */
    main {
      flex: 1;
      display: flex;
      flex-direction: column;
      background-color: var(--bg-body);
      position: relative;
    }

    .toolbar {
      height: 50px;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 20px;
      background: var(--bg-sidebar);
    }

    .current-channel { font-weight: 600; font-size: 14px; }

    .viewer-container {
      flex: 1;
      position: relative;
      background: #000;
    }

    iframe {
      width: 100%;
      height: 100%;
      border: none;
      display: none;
    }
    iframe.active { display: block; }

    .empty-state {
      position: absolute;
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      color: var(--text-muted);
      text-align: center;
    }

    .close-btn {
      display: none;
      background: none; border: none; font-size: 20px; color: var(--text-muted); cursor: pointer;
    }
    .close-btn:hover { color: var(--text-main); }

    @media(max-width: 768px) {
      body { flex-direction: column; }
      aside { width: 100%; height: 40vh; }
      main { height: 60vh; }
    }

    noscript {
      position: fixed;
      bottom: 24px;
      right: 24px;
      z-index: 9999;
      width: 300px;
      background-color: var(--bg-element);
      border: 1px solid var(--border);
      border-left: 4px solid var(--danger);
      border-radius: 8px;
      padding: 16px;
      box-shadow: 0 8px 30px rgba(0,0,0,0.6);
      color: var(--text-main);
      font-size: 13px;
      line-height: 1.5;
      animation: slideIn 0.5s ease-out;
    }
    noscript strong {
      display: block;
      color: var(--danger);
      margin-bottom: 4px;
      font-size: 14px;
    }

    @keyframes slideIn {
      from { transform: translateY(20px); opacity: 0; }
      to { transform: translateY(0); opacity: 1; }
    }
  </style>
</head>
<body>

  <noscript>
    <strong>JavaScript Disabled</strong>
    Search and sorting features are unavailable. You can still click channel names to open them.
  </noscript>

  <!-- E2EE Modal -->
  <div class="e2ee-overlay" id="e2eeOverlay" role="dialog" aria-modal="true" aria-label="End-to-end encryption info">
    <div class="e2ee-modal">
      <div class="e2ee-modal-icon">
        <!-- Lock icon -->
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M18 8h-1V6A5 5 0 0 0 7 6v2H6a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V10a2 2 0 0 0-2-2zm-6 9a2 2 0 1 1 0-4 2 2 0 0 1 0 4zm3.1-9H8.9V6a3.1 3.1 0 0 1 6.2 0v2z"/>
        </svg>
      </div>
      <h2>End-to-End Encrypted</h2>
      <p>Your subscriptions are protected with end-to-end encryption. Nobody — not even the server — can read them in plaintext.</p>
      <ul class="e2ee-detail-list">
        <li>Encrypted with AES-256-GCM before being stored</li>
        <li>Keys are derived from your user ID using SHA-384</li>
        <li>Tamper-proof — any modification is detected and rejected</li>
        <li>Only you can decrypt your subscription list</li>
      </ul>
      <button class="e2ee-modal-close" id="e2eeClose">Got it</button>
    </div>
  </div>

  <aside>
    <header>
      <h1>My Poke</h1>
      <button class="e2ee-badge" id="e2eeBadge" title="Subscriptions are end-to-end encrypted" aria-haspopup="dialog">
        <!-- Inline lock SVG -->
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M18 8h-1V6A5 5 0 0 0 7 6v2H6a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V10a2 2 0 0 0-2-2zm-6 9a2 2 0 1 1 0-4 2 2 0 0 1 0 4zm3.1-9H8.9V6a3.1 3.1 0 0 1 6.2 0v2z"/>
        </svg>
        <span>E2EE</span>
      </button>
    </header>

    <div class="controls">
      <div class="search-wrapper">
        <input type="text" id="searchInput" placeholder="Search ur channels..." autocomplete="off">
        <button class="btn" id="clearSearch" title="Clear">X</button>
      </div>
      <div class="sort-buttons">
        <button class="btn active" data-sort="asc">A-Z</button>
        <button class="btn" data-sort="desc">Z-A</button>
      </div>
    </div>

    <%
      const subKeys = (userSubs && Object.keys(userSubs)) || [];
      const subs = subKeys.map(id => ({
        id,
        name: userSubs[id]?.channelName || "Unknown Channel",
        avatar: userSubs[id]?.avatar || ""
      }));
      subs.sort((a,b) => a.name.localeCompare(b.name, 'en', {sensitivity:'base'}));
    %>

    <div class="channel-list" id="channelList">
      <% subs.forEach(c => { %>
        <div class="channel" data-id="<%= c.id %>" data-name="<%= c.name.toLowerCase() %>">
          <img src="<%= c.avatar %>" alt="" loading="lazy">
          <div class="channel-info">
            <div class="channel-name"><%= c.name %></div>
          </div>
          <a class="unsub-btn"
             href="/api/remove-channel-sub?ID=<%= encodeURIComponent(userid) %>&channelID=<%= c.id %>"
             onclick="event.stopPropagation();"
             title="Unsubscribe">
            Unsub
          </a>
        </div>
      <% }) %>
    </div>

    <div class="sidebar-footer">
      <span>User: <%= userid %></span>
      <a href="/privacy" style="text-decoration: underline;">Privacy</a>
    </div>
  </aside>

  <main>
    <div class="toolbar">
      <span class="current-channel" id="toolbarTitle">Select a channel</span>
      <div>
        <button class="btn close-btn" id="closeViewer" title="Close View">✖</button>
        <a href="/api/get-channel-subs?ID=<%= encodeURIComponent(userid) %>" target="_blank" class="btn">JSON</a>
      </div>
    </div>

    <div class="viewer-container">
      <div class="empty-state" id="emptyState">
        <p>Select a channel from the list to view feed.</p>
      </div>
      <iframe id="mainFrame" sandbox="allow-scripts allow-same-origin allow-popups"></iframe>
    </div>
  </main>

<script>
document.addEventListener("DOMContentLoaded", () => {
  const searchInput  = document.getElementById('searchInput');
  const clearBtn     = document.getElementById('clearSearch');
  const sortBtns     = document.querySelectorAll('.sort-buttons .btn');
  const channelList  = document.getElementById('channelList');
  const channels     = document.querySelectorAll('.channel');
  const iframe       = document.getElementById('mainFrame');
  const emptyState   = document.getElementById('emptyState');
  const toolbarTitle = document.getElementById('toolbarTitle');
  const closeViewer  = document.getElementById('closeViewer');

  // ── E2EE Modal ──────────────────────────────────────────
  const overlay   = document.getElementById('e2eeOverlay');
  const badge     = document.getElementById('e2eeBadge');
  const closeE2ee = document.getElementById('e2eeClose');

  badge.addEventListener('click', () => overlay.classList.add('open'));
  closeE2ee.addEventListener('click', () => overlay.classList.remove('open'));
  overlay.addEventListener('click', (e) => {
    if (e.target === overlay) overlay.classList.remove('open');
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') overlay.classList.remove('open');
  });

  // ── Search ───────────────────────────────────────────────
  function filterChannels() {
    const term = searchInput.value.toLowerCase();
    channels.forEach(ch => {
      ch.style.display = ch.dataset.name.includes(term) ? 'flex' : 'none';
    });
  }

  searchInput.addEventListener('input', filterChannels);
  clearBtn.addEventListener('click', () => {
    searchInput.value = '';
    filterChannels();
    searchInput.focus();
  });

  // ── Sort ─────────────────────────────────────────────────
  sortBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      sortBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      const dir = btn.dataset.sort;
      Array.from(channels)
        .sort((a, b) => dir === 'asc'
          ? a.dataset.name.localeCompare(b.dataset.name)
          : b.dataset.name.localeCompare(a.dataset.name))
        .forEach(node => channelList.appendChild(node));
    });
  });

  // ── Channel Selection & Iframe ───────────────────────────
  channels.forEach(ch => {
    ch.addEventListener('click', () => {
      channels.forEach(c => c.classList.remove('selected'));
      ch.classList.add('selected');

      const id = ch.dataset.id;
      const realName = ch.querySelector('.channel-name').textContent;

      toolbarTitle.textContent = realName;
      closeViewer.style.display = 'inline-block';
      emptyState.style.display = 'none';
      iframe.src = `/channel?id=${encodeURIComponent(id)}&embedchannelsubsfeed=true`;
      iframe.classList.add('active');
    });
  });

  // ── Close Viewer ─────────────────────────────────────────
  closeViewer.addEventListener('click', () => {
    iframe.src = '';
    iframe.classList.remove('active');
    emptyState.style.display = 'block';
    toolbarTitle.textContent = 'Select a channel';
    closeViewer.style.display = 'none';
    channels.forEach(c => c.classList.remove('selected'));
  });

  iframe.addEventListener("load", () => {
    try {
      const doc = iframe.contentDocument || iframe.contentWindow.document;
      doc.querySelectorAll("a").forEach(a => a.setAttribute("target", "_blank"));
    } catch(e) { /* cross-origin, ignore */ }
  });
});
</script>
</body>
</html>
