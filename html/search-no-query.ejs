<%
 
  function FilterChannels(videos, blockedAuthors, limit) {
    // First pass: collect all videos that are NOT from blocked authors
    var allowed = videos.filter(function(item) {
      return blockedAuthors.indexOf(item.author) === -1;
    });

    // Return up to `limit` allowed videos
    return allowed.slice(0, limit);
  }

   // yes, these channels are usually gaming channels but they also do a lot of politics,
  // so we dont use them on "gaming" discovery.
   var blockedAuthors = [
    "TheBurntPeanut",
    "Asmongold TV  "
  ];

  // Get up to 16 filtered videos, replacing any blocked-author slots with
  // other videos from the inv object that are not from blocked authors.
  var filteredVideos = FilterChannels(inv, blockedAuthors, 16);
%>
      
<!DOCTYPE html>
<html lang="en" class="no-js">
<head>
<meta charset="UTF-8">
<title>Poke | Search</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<link href="/css/yt-ukraine.svg?v=7" rel="icon">
<meta name="darkreader-lock">

<meta property="og:type" content="website">
<meta property="og:title" content="Poke - The privacy app of your dreams!">
<meta property="og:description" content="Poke is a free software YouTube front-end, translator, map app, and more!! Watch silly videos, check your weather, and do all of that and more anonymously in this all-in-one privacy app!!!">
<meta property="og:image" content="/static/poke-embed.webp">
<meta name="twitter:title" content="Poke - The privacy app of your dreams!">
<meta name="twitter:description" content="Poke is a free software YouTube front-end, translator, map app, and more!! Watch silly videos, check your weather, and do all of that and more anonymously in this all-in-one privacy app!!!">
<meta name="twitter:image" content="/static/poke-embed.webp">
<meta name="twitter:card" content="summary_large_image">

<script>
document.documentElement.className = document.documentElement.className.replace("no-js", "js");
</script>

<style>
@import url("https://p.poketube.fun/https://site-assets.fontawesome.com/releases/v6.1.1/css/all.css");

@font-face {
  font-family: "PokeTube Flex";
  src: url("/static/robotoflex.ttf");
  font-style: normal;
  font-stretch: 1% 800%;
  font-display: swap;
}

:root{
  --bg:#0b0c10;
  --panel:#141821;
  --panel2:#191d27;
  --panel3:#1e2330;
  --text:#f4f6ff;
  --muted:#9fa7bc;
  --muted2:#7f879b;
  --border:#2a3040;
  --border-strong:#394154;
  --accent:#df03a8;
  --accent-soft:rgba(223,3,168,.18);
  --shadow:0 16px 34px rgba(0,0,0,.34);
  --shadow-soft:0 8px 18px rgba(0,0,0,.18);
  --radius:20px;
  --radius-sm:15px;
  --container:min(1240px,92vw);
}

*{
  box-sizing:border-box;
}

html{
  background:var(--bg);
}

body{
  margin:0;
  min-height:100vh;
  background:var(--bg);
  color:var(--text);
  font-family:"PokeTube Flex",Inter,system-ui,-apple-system,"Segoe UI",Roboto,Arial,sans-serif;
  font-variation-settings:"wdth" 118,"wght" 430;
}

a{
  color:inherit;
  text-decoration:none;
}

img{
  display:block;
  max-width:100%;
}

button,
input{
  font:inherit;
}

.page{
  width:var(--container);
  margin:0 auto;
  padding:42px 0 56px;
}

.hero{
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;
  text-align:center;
  padding:34px 0 12px;
}

.logo-wrap{
  display:flex;
  justify-content:center;
  align-items:center;
  margin-bottom:18px;
}

.logo{
  width:252px;
  max-width:74vw;
  filter:drop-shadow(0 10px 18px rgba(0,0,0,.22));
}

.hero-copy{
  max-width:780px;
  margin-bottom:22px;
}

.hero-title{
  margin:0 0 8px;
  color:var(--text);
  font-size:18px;
  line-height:1.2;
  letter-spacing:.1px;
  font-variation-settings:"wdth" 140,"wght" 640;
}

.hero-sub{
  margin:0;
  color:var(--muted);
  font-size:14px;
  line-height:1.5;
  font-variation-settings:"wdth" 122,"wght" 430;
}

.search-wrap{
  width:min(760px,92vw);
  margin:0 auto;
}

.search-form{
  display:block;
}

.search-field{
  position:relative;
}

.search-bar{
  width:100%;
  min-height:58px;
  padding:15px 20px;
  border-radius:999px;
  border:1px solid var(--border);
  background:var(--panel);
  color:var(--text);
  outline:none;
  box-shadow:var(--shadow-soft);
  transition:border-color .18s ease, box-shadow .18s ease, transform .18s ease, background .18s ease;
  font-size:16px;
  font-variation-settings:"wdth" 132,"wght" 455;
}

.search-bar::placeholder{
  color:#8c95aa;
}

.search-bar:hover{
  border-color:var(--border-strong);
  background:#171b25;
}

.search-bar:focus{
  border-color:var(--accent);
  box-shadow:0 0 0 3px var(--accent-soft), var(--shadow-soft);
  transform:translateY(-1px);
}

.quick-links{
  margin-top:22px;
  display:flex;
  align-items:flex-start;
  justify-content:center;
  gap:28px;
  flex-wrap:wrap;
}

.quick-tool{
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:flex-start;
  gap:9px;
  min-width:76px;
}

.quick-link{
  width:60px;
  height:60px;
  border-radius:999px;
  display:inline-flex;
  align-items:center;
  justify-content:center;
  color:#ffffff;
  box-shadow:var(--shadow-soft);
  border:1px solid rgba(255,255,255,.10);
  transition:transform .18s ease, box-shadow .18s ease, filter .18s ease, border-color .18s ease;
}

.quick-link i{
  font-size:20px;
  line-height:1;
}

.quick-link:hover,
.quick-link:focus{
  transform:translateY(-2px);
  box-shadow:0 14px 24px rgba(0,0,0,.26);
  filter:brightness(1.06);
  border-color:rgba(255,255,255,.18);
}

.quick-link:focus{
  outline:none;
}

.quick-label{
  color:var(--muted);
  font-size:12.5px;
  line-height:1.2;
  text-align:center;
  font-variation-settings:"wdth" 126,"wght" 500;
  transition:color .18s ease;
}

.quick-tool:hover .quick-label,
.quick-tool:focus-within .quick-label{
  color:var(--text);
}

.quick-link.translate{
  background:linear-gradient(180deg, #a84dff 0%, #7a32db 100%);
}

.quick-link.weather{
  background:linear-gradient(180deg, #42b8ff 0%, #1d89df 100%);
}

.quick-link.maps{
  background:linear-gradient(180deg, #34d399 0%, #1fa870 100%);
}

.quick-link.calendar{
  background:linear-gradient(180deg, #ff9c42 0%, #e5761e 100%);
}

.search-note{
  margin-top:16px;
  text-align:center;
  color:var(--muted2);
  font-size:12.5px;
  font-variation-settings:"wdth" 126,"wght" 420;
}

.content{
  margin-top:28px;
}

.discover-wrap{
  width:100%;
  background:var(--panel);
  border:1px solid var(--border);
  border-radius:var(--radius);
  box-shadow:var(--shadow);
  overflow:hidden;
}

.discover-header{
  display:flex;
  align-items:flex-start;
  justify-content:space-between;
  gap:16px;
  padding:18px 20px;
  border-bottom:1px solid var(--border);
  background:var(--panel2);
}

.discover-heading{
  min-width:0;
}

.section-title{
  margin:0;
  color:var(--text);
  font-size:17px;
  line-height:1.2;
  font-variation-settings:"wdth" 138,"wght" 650;
}

.section-sub{
  margin:5px 0 0;
  color:var(--muted);
  font-size:13px;
  line-height:1.45;
  font-variation-settings:"wdth" 126,"wght" 430;
}

.discover-toggle{
  display:none;
  flex:0 0 auto;
  align-items:center;
  justify-content:center;
  min-width:108px;
  padding:10px 14px;
  border-radius:999px;
  border:1px solid var(--border-strong);
  background:var(--panel3);
  color:var(--text);
  cursor:pointer;
  transition:border-color .18s ease, background .18s ease, transform .18s ease, box-shadow .18s ease;
  font-size:13px;
  line-height:1;
  font-variation-settings:"wdth" 132,"wght" 580;
}

.js .discover-toggle{
  display:inline-flex;
}

.discover-toggle:hover{
  border-color:var(--accent);
  background:#24293a;
}

.discover-toggle:focus{
  outline:none;
  border-color:var(--accent);
  box-shadow:0 0 0 3px var(--accent-soft);
}

.discover-toggle:active{
  transform:translateY(1px);
}

.discover-details{
  display:block;
}

.native-toggle{
  list-style:none;
  cursor:pointer;
  padding:14px 18px;
  border-bottom:1px solid var(--border);
  background:#171b25;
  color:var(--text);
  user-select:none;
  font-size:13px;
  font-variation-settings:"wdth" 128,"wght" 560;
}

.native-toggle::-webkit-details-marker{
  display:none;
}

.native-toggle::marker{
  content:"";
}

.native-toggle-inner{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:14px;
}

.native-toggle-left{
  display:flex;
  align-items:center;
  gap:10px;
}

.native-dot{
  width:10px;
  height:10px;
  border-radius:999px;
  background:var(--accent);
  box-shadow:0 0 0 4px rgba(223,3,168,.12);
  flex:0 0 auto;
}

.native-toggle-arrow{
  color:var(--muted);
  transition:transform .18s ease;
}

.discover-details[open] .native-toggle-arrow{
  transform:rotate(180deg);
}

.js .native-toggle{
  display:none;
}

.discover-body{
  padding:16px;
  background:var(--panel);
}

.video-grid{
  display:grid;
  grid-template-columns:repeat(4,minmax(0,1fr));
  gap:14px;
}

.video{
  display:block;
  border:1px solid var(--border);
  border-radius:16px;
  background:var(--panel2);
  overflow:hidden;
  box-shadow:0 6px 18px rgba(0,0,0,.16);
  transition:transform .18s ease, border-color .18s ease, box-shadow .18s ease, background .18s ease;
}

.video:hover{
  transform:translateY(-2px);
  border-color:rgba(223,3,168,.58);
  background:#1d2230;
  box-shadow:0 14px 28px rgba(0,0,0,.24);
}

.thumbnail{
  position:relative;
  width:100%;
  aspect-ratio:16/9;
  background-position:center;
  background-size:cover;
  background-repeat:no-repeat;
  border-bottom:1px solid rgba(255,255,255,.05);
}

.thumbnail::after{
  content:"";
  position:absolute;
  inset:0;
  background:linear-gradient(180deg, rgba(0,0,0,0) 52%, rgba(0,0,0,.40) 100%);
  pointer-events:none;
}

.video-length{
  position:absolute;
  right:8px;
  bottom:8px;
  z-index:1;
  padding:5px 7px;
  border-radius:7px;
  background:rgba(9,11,16,.88);
  color:#f6f8ff;
  border:1px solid rgba(255,255,255,.10);
  font-size:11.5px;
  line-height:1;
  font-variation-settings:"wdth" 128,"wght" 560;
}

.info{
  padding:12px 12px 13px;
  display:flex;
  flex-direction:column;
  gap:6px;
}

.title{
  color:var(--text);
  font-size:14px;
  line-height:1.32;
  font-variation-settings:"wdth" 128,"wght" 590;
}

.byline{
  color:var(--muted);
  font-size:12.5px;
  line-height:1.35;
  font-variation-settings:"wdth" 122,"wght" 430;
}

.max-lines-2{
  display:-webkit-box;
  -webkit-line-clamp:2;
  -webkit-box-orient:vertical;
  overflow:hidden;
}

@media (max-width:1100px){
  .video-grid{
    grid-template-columns:repeat(3,minmax(0,1fr));
  }
}

@media (max-width:820px){
  .page{
    padding-top:28px;
  }

  .hero{
    padding-top:16px;
  }

  .logo{
    width:224px;
  }

  .discover-header{
    flex-direction:column;
    align-items:flex-start;
  }

  .discover-toggle{
    min-width:0;
  }

  .video-grid{
    grid-template-columns:repeat(2,minmax(0,1fr));
  }
}

@media (max-width:560px){
  .page{
    width:min(96vw,1240px);
    padding-bottom:36px;
  }

  .hero-title{
    font-size:16px;
  }

  .hero-sub{
    font-size:13px;
  }

  .search-bar{
    min-height:54px;
    font-size:15px;
  }

  .quick-links{
    gap:18px;
    margin-top:18px;
  }

  .quick-tool{
    min-width:68px;
    gap:8px;
  }

  .quick-link{
    width:54px;
    height:54px;
  }

  .quick-link i{
    font-size:18px;
  }

  .quick-label{
    font-size:12px;
  }

  .discover-header{
    padding:16px;
  }

  .discover-body{
    padding:12px;
  }

  .video-grid{
    grid-template-columns:1fr;
    gap:12px;
  }

  .native-toggle{
    padding:14px 16px;
  }
}
</style>
</head>

<body>

<div class="page">
  <div class="hero">
    <div class="logo-wrap">
      <img src="/static/logo-poke.svg" class="logo" alt="Poke Logo">
    </div>
 
    <div class="search-wrap">
      <form class="search-form" action="/search" method="get">
        <div class="search-field">
          <input class="search-bar" autocomplete="on" id="fname" name="query" type="text" placeholder="Search Videos, use bangs, do math, and more...">
        </div>
      </form>

      <div class="quick-links" aria-label="Poke tools">
        <div class="quick-tool">
          <a class="quick-link translate" href="/translate" aria-label="Translate" title="Translate">
            <i class="fa-solid fa-language" aria-hidden="true"></i>
          </a>
          <span class="quick-label">Translate</span>
        </div>

        <div class="quick-tool">
          <a class="quick-link weather" href="/weather" aria-label="Weather" title="Weather">
            <i class="fa-solid fa-cloud-sun" aria-hidden="true"></i>
          </a>
          <span class="quick-label">Weather</span>
        </div>

        <div class="quick-tool">
          <a class="quick-link maps" href="/map" aria-label="Maps" title="Maps">
            <i class="fa-solid fa-map-location-dot" aria-hidden="true"></i>
          </a>
          <span class="quick-label">Maps</span>
        </div>

        <div class="quick-tool">
          <a class="quick-link calendar" href="/calendar" aria-label="Calendar" title="Calendar">
            <i class="fa-solid fa-calendar-days" aria-hidden="true"></i>
          </a>
          <span class="quick-label">Calendar</span>
        </div>
      </div>

     </div>
  </div>

  <div class="content">
    <section class="discover-wrap">
      <div class="discover-header">
        <div class="discover-heading">
          <h2 class="section-title">Poke Gaming</h2>
          <p class="section-sub">Discover Popular Gaming Videos!</p>
        </div>

        <button type="button" class="discover-toggle" id="discover-toggle" aria-controls="discover-section" aria-expanded="true">
          Hide videos
        </button>
      </div>

      <details class="discover-details" id="discover-section" open>
        <summary class="native-toggle">
          <span class="native-toggle-inner">
            <span class="native-toggle-left">
              <span class="native-dot"></span>
              <span>Show or hide trending gaming videos</span>
            </span>
            <span class="native-toggle-arrow">▾</span>
          </span>
        </summary>

        <div class="discover-body">
          <div class="video-grid">
            <% filteredVideos.forEach(function(item) { %>
              <a href="/watch?v=<%- item.videoId %>" class="video canloadhd" data-author="<%- item.author %>">
                <div class="thumbnail" style="background-image:url('/vi/<%= item.videoId %>/hqdefault.jpg?sqp=-oaymwEbCKgBEF5IVfKriqkDDggBFQAAiEIYAXABwAEG&rs=AOn4CLBy_x4UUHLNDZtJtH0PXeQGoRFTgw');">
                  <span class="video-length"><%- turntomins(item.lengthSeconds) %></span>
                </div>

                <div class="info">
                  <span class="title max-lines-2" title="<%- item.title %>"><%- item.title %></span>
                  <span class="byline max-lines-2" title="Video By <%- item.author %>"><%- item.author %></span>
                </div>
              </a>
            <% }); %>
          </div>
        </div>
      </details>
    </section>
  </div>
</div>

<script>
(function () {
  var section = document.getElementById("discover-section");
  var button = document.getElementById("discover-toggle");
  var storageKey = "poke_discover_videos_open";

  if (!section || !button) return;

  function isOpen() {
    return section.hasAttribute("open");
  }

  function setOpenState(open) {
    if (open) {
      section.setAttribute("open", "");
    } else {
      section.removeAttribute("open");
    }
    updateButton();
    saveState();
  }

  function updateButton() {
    var open = isOpen();
    button.textContent = open ? "Hide videos" : "Show videos";
    button.setAttribute("aria-expanded", open ? "true" : "false");
  }

  function saveState() {
    try {
      localStorage.setItem(storageKey, isOpen() ? "1" : "0");
    } catch (e) {}
  }

  try {
    var saved = localStorage.getItem(storageKey);
    if (saved === "0") {
      section.removeAttribute("open");
    } else if (saved === "1") {
      section.setAttribute("open", "");
    }
  } catch (e) {}

  updateButton();

  button.addEventListener("click", function () {
    setOpenState(!isOpen());
  });

  section.addEventListener("toggle", function () {
    updateButton();
    saveState();
  });
})();
</script>

</body>
</html>
