<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Poke</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<link href="/css/yt-ukraine.svg?v=7" rel="icon">
<meta name="darkreader-lock">

<meta property="og:type" content="website">
<meta property="og:title" content="Poke - The privacy app of your dreams!">
<meta property="og:description" content="Poke is a free software YouTube front-end, translator, map app, and more!! Watch silly videos, check your weather, and do all of that and more anonymously in this all-in-one privacy app!!!">
<meta property="og:image" content="/static/poke-embed.webp">
<meta name="og:image:alt" content="A pink gradient promotional banner for the app Poke.">

<meta name="twitter:title" content="Poke - The privacy app of your dreams!">
<meta name="twitter:description" content="Poke is a free software YouTube front-end, translator, map app, and more!! Watch silly videos, check your weather, and do all of that and more anonymously in this all-in-one privacy app!!!">
<meta name="twitter:image" content="/static/poke-embed.webp">
<meta name="twitter:image:alt" content="A pink gradient promotional banner for the app Poke.">
<meta name="twitter:card" content="summary_large_image">

<meta property="facebook:title" content="Poke - The privacy app of your dreams!">
<meta property="facebook:description" content="Poke is a free software YouTube front-end, translator, map app, and more!! Watch silly videos, check your weather, and do all of that and more anonymously in this all-in-one privacy app!!!">
<meta property="og:image" content="/static/poke-embed.webp">

<style>
:root{
  --bg:#0b0c10;
  --panel:#10131a;
  --panel2:#0f1218;
  --text:#f4f6ff;
  --muted:#a7adbf;
  --border:rgba(255,255,255,.08);
  --border2:rgba(255,255,255,.12);
  --accent:#df03a8;
  --accent2:#7c4dff;
  --shadow:0 18px 40px rgba(0,0,0,.55);
  --shadow2:0 10px 24px rgba(0,0,0,.45);
  --radius:20px;
}

*{box-sizing:border-box}

body{
  margin:0;
  min-height:100vh;
  background:
    radial-gradient(1200px 600px at 50% -10%, rgba(223,3,168,.18), transparent 55%),
    radial-gradient(900px 500px at 10% 15%, rgba(124,77,255,.12), transparent 60%),
    radial-gradient(900px 500px at 90% 20%, rgba(0,212,255,.08), transparent 60%),
    var(--bg);
  font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
  color:var(--text);
}

.page{
  width:min(1200px, 92vw);
  margin:0 auto;
  padding:42px 0 54px;
  display:flex;
  flex-direction:column;
  align-items:center;
  gap:22px;
}

.hero{
  width:100%;
  display:flex;
  flex-direction:column;
  align-items:center;
  gap:18px;
  padding-top:10px;
}

.logo{
  width:240px;
  max-width:70vw;
  filter: drop-shadow(0 10px 24px rgba(0,0,0,.45));
}

.search-wrap{
  width:min(680px, 92vw);
}

.search-form{
  display:flex;
  justify-content:center;
}

.search-bar{
  width:100%;
  padding:15px 18px;
  font-size:16px;
  border-radius:999px;
  border:1px solid var(--border2);
  background: linear-gradient(180deg, rgba(255,255,255,.06), rgba(255,255,255,.03));
  color:var(--text);
  outline:none;
  box-shadow: 0 10px 24px rgba(0,0,0,.35);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  transition: box-shadow .18s ease, border-color .18s ease, transform .18s ease;
}

.search-bar::placeholder{color:rgba(244,246,255,.55)}

.search-bar:focus{
  border-color: rgba(223,3,168,.55);
  box-shadow: 0 0 0 4px rgba(223,3,168,.18), 0 16px 34px rgba(0,0,0,.45);
  transform: translateY(-1px);
}

.section{
  width:100%;
  margin-top:12px;
  background: linear-gradient(180deg, rgba(255,255,255,.04), rgba(255,255,255,.02));
  border:1px solid var(--border);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  overflow:hidden;
}

.section-header{
  display:flex;
  align-items:baseline;
  justify-content:space-between;
  gap:14px;
  padding:16px 18px;
  background: linear-gradient(90deg, rgba(223,3,168,.14), rgba(124,77,255,.08), transparent 70%);
  border-bottom:1px solid var(--border);
}

.section-title{
  font-size:16px;
  font-weight:700;
  letter-spacing:.2px;
}

.section-sub{
  font-size:13px;
  color:rgba(244,246,255,.65);
  white-space:nowrap;
  overflow:hidden;
  text-overflow:ellipsis;
}

.video-grid{
  padding:16px;
  display:grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap:14px;
}

@media (max-width: 1100px){
  .video-grid{grid-template-columns: repeat(3, minmax(0, 1fr));}
}
@media (max-width: 820px){
  .video-grid{grid-template-columns: repeat(2, minmax(0, 1fr));}
}
@media (max-width: 520px){
  .video-grid{grid-template-columns: 1fr;}
}

.video{
  display:block;
  text-decoration:none;
  color:inherit;
  border:1px solid rgba(255,255,255,.08);
  border-radius:16px;
  background: linear-gradient(180deg, rgba(16,19,26,.92), rgba(12,14,20,.92));
  box-shadow: var(--shadow2);
  overflow:hidden;
  transform: translateZ(0);
  transition: transform .16s ease, border-color .16s ease, box-shadow .16s ease;
}

.video:hover{
  transform: translateY(-2px);
  border-color: rgba(223,3,168,.35);
  box-shadow: 0 16px 40px rgba(0,0,0,.55);
}

.thumbnail{
  position:relative;
  width:100%;
  aspect-ratio: 16 / 9;
  background-position:center;
  background-size:cover;
  background-repeat:no-repeat;
}

.thumbnail::after{
  content:"";
  position:absolute;
  inset:0;
  background: linear-gradient(180deg, transparent 60%, rgba(0,0,0,.62) 100%);
}

.video-length{
  position:absolute;
  right:10px;
  bottom:10px;
  z-index:1;
  font-size:12px;
  padding:5px 8px;
  border-radius:999px;
  background: rgba(0,0,0,.6);
  border:1px solid rgba(255,255,255,.12);
  color: rgba(255,255,255,.92);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
}

.info{
  padding:12px 12px 14px;
  display:flex;
  flex-direction:column;
  gap:6px;
}

.title{
  font-size:14px;
  line-height:1.25;
  font-weight:700;
  letter-spacing:.1px;
}

.byline{
  font-size:12.5px;
  color: rgba(244,246,255,.68);
}

.max-lines-2{
  display:-webkit-box;
  -webkit-line-clamp:2;
  -webkit-box-orient:vertical;
  overflow:hidden;
}
</style>
</head>

<body>
  <div class="page">
    <div class="hero">
      <img src="/static/logo-poke.svg" class="logo" alt="Poke Logo">

      <div class="search-wrap">
        <form class="search-form" action="/search" method="get">
          <input class="search-bar" autocomplete="on" id="fname" name="query" type="text" placeholder="Search...">
        </form>
      </div>
    </div>

    <section class="section" aria-label="Discover gaming videos">
      <div class="section-header">
        <div class="section-title">Discover gaming videos</div>
       </div>

      <div class="video-grid">
        <% inv.slice(0, 16).forEach(x => { %>
          <a href="/watch?v=<%- x.videoId %>" class="video canloadhd" data-author="<%- x.author %>">
            <div class="thumbnail" style="background-image:url('/vi/<%= x.videoId %>/hqdefault.jpg?sqp=-oaymwEbCKgBEF5IVfKriqkDDggBFQAAiEIYAXABwAEG&rs=AOn4CLBy_x4UUHLNDZtJtH0PXeQGoRFTgw');">
              <span class="video-length"><%- turntomins(x.lengthSeconds) %></span>
            </div>
            <div class="info">
              <span class="title max-lines-2" title="<%- x.title %>"><%- x.title %></span>
              <span class="byline max-lines-2" title="Video By <%- x.author %>">By <%- x.author %></span>
            </div>
          </a>
        <% }) %>
      </div>
    </section>
  </div>
</body>
</html>