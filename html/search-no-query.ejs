<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Poke</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<link href="/css/yt-ukraine.svg?v=7" rel="icon">
<meta name="darkreader-lock">

<meta property="og:type" content="website">
<meta property="og:title" content="Poke - The privacy app of your dreams!">
<meta property="og:description" content="Poke is a free software YouTube front-end, translator, map app, and more!! Watch silly videos, check your weather, and do all of that and more anonymously in this all-in-one privacy app!!!">
<meta property="og:image" content="/static/poke-embed.webp">

<style>
:root{
  --bg:#0b0c10;
  --panel:#151821;
  --panel2:#1a1d26;
  --text:#f4f6ff;
  --muted:#a7adbf;
  --border:#242836;
  --accent:#df03a8;
  --shadow:0 14px 32px rgba(0,0,0,.45);
  --radius:18px;
}

*{box-sizing:border-box}

body{
  margin:0;
  min-height:100vh;
  background:
    radial-gradient(1200px 600px at 50% -10%, rgba(223,3,168,.18), transparent 55%),
    radial-gradient(900px 500px at 10% 15%, rgba(124,77,255,.12), transparent 60%),
    radial-gradient(900px 500px at 90% 20%, rgba(0,212,255,.08), transparent 60%),
    var(--bg);
  font-family:Inter,system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;
  color:var(--text);
}

.page{
  width:min(1200px,92vw);
  margin:0 auto;
  padding:42px 0 54px;
  display:flex;
  flex-direction:column;
  align-items:center;
  gap:22px;
}

.hero{
  width:100%;
  display:flex;
  flex-direction:column;
  align-items:center;
  gap:18px;
}

.logo{
  width:240px;
  filter: drop-shadow(0 10px 24px rgba(0,0,0,.45));
}

.search-wrap{
  width:min(680px,92vw);
}

.search-bar{
  width:100%;
  padding:14px 18px;
  font-size:16px;
  border-radius:999px;
  border:1px solid var(--border);
  background:var(--panel);
  color:var(--text);
  outline:none;
  transition:border-color .18s ease, box-shadow .18s ease;
}

.search-bar::placeholder{
  color:#8c92a6;
}

.search-bar:focus{
  border-color:var(--accent);
  box-shadow:0 0 0 2px rgba(223,3,168,.25);
}

/* No-JS toggle (details/summary) */
.discover{
  width:100%;
  margin-top:12px;
}

.discover details{
  background:var(--panel);
  border:1px solid var(--border);
  border-radius:var(--radius);
  box-shadow:var(--shadow);
  overflow:hidden;
}

.discover summary{
  list-style:none;
  cursor:pointer;
  user-select:none;
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:14px;
  padding:16px 18px;
  border-bottom:1px solid var(--border);
}

.discover summary::-webkit-details-marker{display:none}

.summary-left{
  display:flex;
  flex-direction:column;
  gap:2px;
}

.section-title{
  font-size:16px;
  font-weight:700;
}

.section-sub{
  font-size:13px;
  color:var(--muted);
}

.chev{
  width:34px;
  height:34px;
  border-radius:10px;
  display:grid;
  place-items:center;
  border:1px solid var(--border);
  background:var(--panel2);
  transition:transform .15s ease, border-color .15s ease;
}

details[open] .chev{
  transform:rotate(180deg);
  border-color:rgba(223,3,168,.45);
}

/* JS toggle button (appears only when JS is enabled) */
.js-toggle{
  display:none;
  margin-left:10px;
  padding:8px 10px;
  border-radius:10px;
  border:1px solid var(--border);
  background:var(--panel2);
  color:var(--text);
  font-size:13px;
  cursor:pointer;
  transition:border-color .15s ease, transform .15s ease;
}

.js-toggle:hover{
  border-color:rgba(223,3,168,.45);
  transform:translateY(-1px);
}

.js .js-toggle{
  display:inline-flex;
  align-items:center;
  gap:8px;
}

/* When JS is enabled, we hide the <summary> UI and use a header bar instead */
.js .discover summary{
  display:none;
}

.js-header{
  display:none;
}

.js .js-header{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:14px;
  padding:16px 18px;
  border-bottom:1px solid var(--border);
  background:var(--panel);
}

.js-header-left{
  display:flex;
  flex-direction:column;
  gap:2px;
}

/* Content area */
.video-grid{
  padding:16px;
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:14px;
}

@media (max-width:1100px){
  .video-grid{grid-template-columns:repeat(3,1fr);}
}

@media (max-width:820px){
  .video-grid{grid-template-columns:repeat(2,1fr);}
}

@media (max-width:520px){
  .video-grid{grid-template-columns:1fr;}
}

.video{
  display:block;
  text-decoration:none;
  color:inherit;
  border:1px solid var(--border);
  border-radius:14px;
  background:var(--panel2);
  overflow:hidden;
  transition:transform .15s ease,border-color .15s ease;
}

.video:hover{
  transform:translateY(-2px);
  border-color:var(--accent);
}

.thumbnail{
  position:relative;
  width:100%;
  aspect-ratio:16/9;
  background-position:center;
  background-size:cover;
}

.video-length{
  position:absolute;
  right:8px;
  bottom:8px;
  font-size:12px;
  padding:4px 7px;
  border-radius:6px;
  background:rgba(0,0,0,.75);
}

.info{
  padding:10px 12px 12px;
  display:flex;
  flex-direction:column;
  gap:5px;
}

.title{
  font-size:14px;
  font-weight:600;
  line-height:1.25;
}

.byline{
  font-size:12px;
  color:var(--muted);
}

.max-lines-2{
  display:-webkit-box;
  -webkit-line-clamp:2;
  -webkit-box-orient:vertical;
  overflow:hidden;
}
</style>
</head>

<body>

<div class="page">

<div class="hero">
<img src="/static/logo-poke.svg" class="logo" alt="Poke Logo">

<div class="search-wrap">
<form action="/search" method="get">
<input class="search-bar" autocomplete="on" id="fname" name="query" type="text" placeholder="Search...">
</form>
</div>
</div>

<div class="discover">
  <details id="discoverDetails" open>
    <summary>
      <div class="summary-left">
        <div class="section-title">Discover gaming videos</div>
        <div class="section-sub">Trending gaming videos</div>
      </div>
      <div class="chev" aria-hidden="true">▾</div>
    </summary>

    <div class="js-header" role="heading" aria-level="2">
      <div class="js-header-left">
        <div class="section-title">Discover gaming videos</div>
        <div class="section-sub">Trending gaming videos</div>
      </div>

      <button class="js-toggle" type="button" id="discoverToggle" aria-controls="discoverContent" aria-expanded="true">
        Hide
      </button>
    </div>

    <div id="discoverContent">
      <div class="video-grid">
        <% inv.slice(0,16).forEach(x => { %>

        <a href="/watch?v=<%- x.videoId %>" class="video canloadhd" data-author="<%- x.author %>">
          <div class="thumbnail" style="background-image:url('/vi/<%= x.videoId %>/hqdefault.jpg?sqp=-oaymwEbCKgBEF5IVfKriqkDDggBFQAAiEIYAXABwAEG&rs=AOn4CLBy_x4UUHLNDZtJtH0PXeQGoRFTgw');">
            <span class="video-length"><%- turntomins(x.lengthSeconds) %></span>
          </div>

          <div class="info">
            <span class="title max-lines-2" title="<%- x.title %>"><%- x.title %></span>
            <span class="byline max-lines-2">By <%- x.author %></span>
          </div>
        </a>

        <% }) %>
      </div>
    </div>

  </details>
</div>

</div>

<script>
(function(){
  document.documentElement.classList.add("js");

  var details = document.getElementById("discoverDetails");
  var btn = document.getElementById("discoverToggle");
  var content = document.getElementById("discoverContent");

  if (!details || !btn || !content) return;

  details.open = true;

  function setState(isOpen){
    content.style.display = isOpen ? "" : "none";
    btn.textContent = isOpen ? "Hide" : "Show";
    btn.setAttribute("aria-expanded", isOpen ? "true" : "false");
  }

  setState(true);

  btn.addEventListener("click", function(){
    var currentlyOpen = content.style.display !== "none";
    setState(!currentlyOpen);
  });
})();
</script>

</body>
</html>