<!DOCTYPE html>
<html lang="en" class="no-js">
<head>
<meta charset="UTF-8">
<title>Poke</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<link href="/css/yt-ukraine.svg?v=7" rel="icon">
<meta name="darkreader-lock">

<meta property="og:type" content="website">
<meta property="og:title" content="Poke - The privacy app of your dreams!">
<meta property="og:description" content="Poke is a free software YouTube front-end, translator, map app, and more!! Watch silly videos, check your weather, and do all of that and more anonymously in this all-in-one privacy app!!!">
<meta property="og:image" content="/static/poke-embed.webp">
<meta name="twitter:title" content="Poke - The privacy app of your dreams!">
<meta name="twitter:description" content="Poke is a free software YouTube front-end, translator, map app, and more!! Watch silly videos, check your weather, and do all of that and more anonymously in this all-in-one privacy app!!!">
<meta name="twitter:image" content="/static/poke-embed.webp">
<meta name="twitter:card" content="summary_large_image">

<script>
document.documentElement.className = document.documentElement.className.replace("no-js", "js");
</script>

<style>
@font-face {
  font-family: "PokeTube Flex";
  src: url("/static/robotoflex.ttf");
  font-style: normal;
  font-stretch: 1% 800%;
  font-display: swap;
}

:root{
  --bg:#0a0b10;
  --bg2:#11131b;
  --panel:#151821;
  --panel2:#1a1d26;
  --panel3:#202433;
  --text:#f4f6ff;
  --muted:#9ea6bc;
  --muted2:#7f879d;
  --border:#282d3c;
  --border-strong:#353b4f;
  --accent:#df03a8;
  --accent-soft:rgba(223,3,168,.18);
  --shadow:0 18px 40px rgba(0,0,0,.40);
  --shadow-soft:0 10px 24px rgba(0,0,0,.24);
  --radius:20px;
  --radius-sm:14px;
  --container:min(1240px,92vw);
}

*{
  box-sizing:border-box;
}

html{
  background:var(--bg);
}

body{
  margin:0;
  min-height:100vh;
  color:var(--text);
  font-family:"PokeTube Flex",Inter,system-ui,-apple-system,"Segoe UI",Roboto,Arial,sans-serif;
  font-variation-settings:"wdth" 110,"wght" 420;
  background:
    radial-gradient(900px 500px at 50% -120px, rgba(223,3,168,.10), transparent 60%),
    radial-gradient(800px 420px at 0% 0%, rgba(120,60,255,.08), transparent 58%),
    linear-gradient(180deg, #0b0d13 0%, #0a0b10 100%);
}

a{
  color:inherit;
  text-decoration:none;
}

img{
  max-width:100%;
  display:block;
}

button,
input{
  font:inherit;
}

.page{
  width:var(--container);
  margin:0 auto;
  padding:38px 0 56px;
}

.hero{
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;
  text-align:center;
  padding:30px 0 10px;
}

.logo-wrap{
  display:flex;
  justify-content:center;
  align-items:center;
  margin-bottom:20px;
}

.logo{
  width:252px;
  max-width:74vw;
  filter:drop-shadow(0 10px 18px rgba(0,0,0,.30));
}

.hero-copy{
  max-width:760px;
  margin-bottom:22px;
}

.hero-title{
  margin:0 0 8px;
  font-size:17px;
  line-height:1.2;
  color:var(--text);
  font-variation-settings:"wdth" 118,"wght" 620;
  letter-spacing:.1px;
}

.hero-sub{
  margin:0;
  font-size:14px;
  line-height:1.5;
  color:var(--muted);
  font-variation-settings:"wdth" 108,"wght" 430;
}

.search-wrap{
  width:min(720px,92vw);
  margin:0 auto;
}

.search-form{
  display:block;
}

.search-field{
  position:relative;
}

.search-bar{
  width:100%;
  min-height:56px;
  padding:15px 20px;
  border-radius:999px;
  border:1px solid var(--border);
  background:linear-gradient(180deg, #171b25 0%, #141821 100%);
  color:var(--text);
  outline:none;
  box-shadow:var(--shadow-soft);
  transition:border-color .18s ease, box-shadow .18s ease, transform .18s ease, background .18s ease;
  font-size:16px;
  font-variation-settings:"wdth" 108,"wght" 445;
}

.search-bar::placeholder{
  color:#8d95a9;
}

.search-bar:hover{
  border-color:var(--border-strong);
  background:linear-gradient(180deg, #191d28 0%, #151923 100%);
}

.search-bar:focus{
  border-color:var(--accent);
  box-shadow:0 0 0 3px var(--accent-soft), var(--shadow-soft);
  transform:translateY(-1px);
}

.search-note{
  margin-top:10px;
  text-align:center;
  font-size:12.5px;
  color:var(--muted2);
  font-variation-settings:"wdth" 106,"wght" 420;
}

.content{
  margin-top:26px;
}

.discover{
  width:100%;
  border:1px solid var(--border);
  background:linear-gradient(180deg, #151821 0%, #12151d 100%);
  border-radius:var(--radius);
  box-shadow:var(--shadow);
  overflow:hidden;
}

.discover[open]{
  border-color:#2f3445;
}

.native-toggle{
  list-style:none;
  cursor:pointer;
  padding:15px 18px;
  border-bottom:1px solid var(--border);
  background:linear-gradient(180deg, #191d27 0%, #161922 100%);
  color:var(--text);
  user-select:none;
  font-size:14px;
  font-variation-settings:"wdth" 110,"wght" 560;
}

.native-toggle::-webkit-details-marker{
  display:none;
}

.native-toggle::marker{
  content:"";
}

.native-toggle-inner{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:14px;
}

.native-toggle-text{
  display:flex;
  align-items:center;
  gap:10px;
}

.native-dot{
  width:10px;
  height:10px;
  border-radius:999px;
  background:var(--accent);
  box-shadow:0 0 0 4px rgba(223,3,168,.12);
  flex:0 0 auto;
}

.native-toggle-arrow{
  color:var(--muted);
  transition:transform .18s ease;
}

.discover[open] .native-toggle-arrow{
  transform:rotate(180deg);
}

.js .native-toggle{
  display:none;
}

.discover-shell{
  display:block;
}

.discover-header{
  display:flex;
  align-items:flex-start;
  justify-content:space-between;
  gap:16px;
  padding:18px 20px;
  border-bottom:1px solid var(--border);
  background:
    linear-gradient(90deg, rgba(223,3,168,.10) 0%, rgba(223,3,168,.04) 26%, rgba(255,255,255,0) 60%),
    linear-gradient(180deg, #181b25 0%, #151821 100%);
}

.discover-heading{
  min-width:0;
}

.section-title{
  margin:0;
  font-size:17px;
  line-height:1.2;
  color:var(--text);
  font-variation-settings:"wdth" 115,"wght" 640;
}

.section-sub{
  margin:5px 0 0;
  font-size:13px;
  line-height:1.45;
  color:var(--muted);
  font-variation-settings:"wdth" 108,"wght" 430;
}

.js-toggle{
  display:none;
  flex:0 0 auto;
  min-width:102px;
  padding:10px 14px;
  border-radius:999px;
  border:1px solid var(--border-strong);
  background:linear-gradient(180deg, #232837 0%, #1b2030 100%);
  color:var(--text);
  cursor:pointer;
  transition:border-color .18s ease, transform .18s ease, background .18s ease;
  font-size:13px;
  line-height:1;
  font-variation-settings:"wdth" 110,"wght" 560;
}

.js .js-toggle{
  display:inline-flex;
  align-items:center;
  justify-content:center;
}

.js-toggle:hover{
  border-color:var(--accent);
  background:linear-gradient(180deg, #272d3f 0%, #1f2434 100%);
}

.js-toggle:focus{
  outline:none;
  border-color:var(--accent);
  box-shadow:0 0 0 3px var(--accent-soft);
}

.js-toggle:active{
  transform:translateY(1px);
}

.discover-body{
  padding:16px;
}

.video-grid{
  display:grid;
  grid-template-columns:repeat(4,minmax(0,1fr));
  gap:14px;
}

.video{
  display:block;
  border:1px solid var(--border);
  border-radius:16px;
  background:linear-gradient(180deg, #1b1f2a 0%, #181c26 100%);
  overflow:hidden;
  box-shadow:0 6px 18px rgba(0,0,0,.18);
  transition:transform .18s ease, border-color .18s ease, box-shadow .18s ease, background .18s ease;
}

.video:hover{
  transform:translateY(-2px);
  border-color:rgba(223,3,168,.55);
  box-shadow:0 14px 28px rgba(0,0,0,.28);
  background:linear-gradient(180deg, #1d2230 0%, #191e29 100%);
}

.thumbnail{
  position:relative;
  width:100%;
  aspect-ratio:16/9;
  background-position:center;
  background-size:cover;
  background-repeat:no-repeat;
  border-bottom:1px solid rgba(255,255,255,.04);
}

.thumbnail::after{
  content:"";
  position:absolute;
  inset:0;
  background:linear-gradient(180deg, rgba(0,0,0,0) 52%, rgba(0,0,0,.40) 100%);
  pointer-events:none;
}

.video-length{
  position:absolute;
  right:8px;
  bottom:8px;
  z-index:1;
  font-size:11.5px;
  line-height:1;
  padding:5px 7px;
  border-radius:7px;
  background:rgba(8,10,14,.86);
  color:#f6f8ff;
  border:1px solid rgba(255,255,255,.10);
  font-variation-settings:"wdth" 108,"wght" 540;
}

.info{
  padding:12px 12px 13px;
  display:flex;
  flex-direction:column;
  gap:6px;
}

.title{
  font-size:14px;
  line-height:1.32;
  color:var(--text);
  font-variation-settings:"wdth" 108,"wght" 585;
}

.byline{
  font-size:12.5px;
  line-height:1.35;
  color:var(--muted);
  font-variation-settings:"wdth" 106,"wght" 430;
}

.max-lines-2{
  display:-webkit-box;
  -webkit-line-clamp:2;
  -webkit-box-orient:vertical;
  overflow:hidden;
}

.discover[open] .discover-empty{
  display:none;
}

.discover-empty{
  padding:16px 18px 18px;
  color:var(--muted);
  font-size:13px;
  border-top:1px solid var(--border);
}

@media (max-width:1100px){
  .video-grid{
    grid-template-columns:repeat(3,minmax(0,1fr));
  }
}

@media (max-width:820px){
  .page{
    padding-top:28px;
  }

  .hero{
    padding-top:16px;
  }

  .logo{
    width:224px;
  }

  .discover-header{
    flex-direction:column;
    align-items:flex-start;
  }

  .js-toggle{
    min-width:0;
  }

  .video-grid{
    grid-template-columns:repeat(2,minmax(0,1fr));
  }
}

@media (max-width:560px){
  .page{
    width:min(96vw,1240px);
    padding-bottom:36px;
  }

  .hero-title{
    font-size:16px;
  }

  .hero-sub{
    font-size:13px;
  }

  .search-bar{
    min-height:52px;
    font-size:15px;
  }

  .discover-header{
    padding:16px;
  }

  .discover-body{
    padding:12px;
  }

  .video-grid{
    grid-template-columns:1fr;
    gap:12px;
  }

  .native-toggle{
    padding:14px 16px;
  }
}
</style>
</head>

<body>

<div class="page">
  <div class="hero">
    <div class="logo-wrap">
      <img src="/static/logo-poke.svg" class="logo" alt="Poke Logo">
    </div>

    <div class="hero-copy">
      <h1 class="hero-title">Search privately across Poke</h1>
      <p class="hero-sub">Watch videos, explore trending content, and find things without the usual noise.</p>
    </div>

    <div class="search-wrap">
      <form class="search-form" action="/search" method="get">
        <div class="search-field">
          <input class="search-bar" autocomplete="on" id="fname" name="query" type="text" placeholder="Search...">
        </div>
      </form>
      <div class="search-note">Type anything to search, or browse trending gaming videos below.</div>
    </div>
  </div>

  <div class="content">
    <details class="discover" id="discover-section" open>
      <summary class="native-toggle">
        <span class="native-toggle-inner">
          <span class="native-toggle-text">
            <span class="native-dot"></span>
            <span>Discover gaming videos</span>
          </span>
          <span class="native-toggle-arrow">▾</span>
        </span>
      </summary>

      <div class="discover-shell">
        <div class="discover-header">
          <div class="discover-heading">
            <h2 class="section-title">Discover gaming videos</h2>
            <p class="section-sub">These are trending gaming videos right now.</p>
          </div>

          <button type="button" class="js-toggle" id="discover-toggle" aria-controls="discover-section" aria-expanded="true">
            Hide videos
          </button>
        </div>

        <div class="discover-body">
          <div class="video-grid">
            <% inv.slice(0,16).forEach(x => { %>
              <a href="/watch?v=<%- x.videoId %>" class="video canloadhd" data-author="<%- x.author %>">
                <div class="thumbnail" style="background-image:url('/vi/<%= x.videoId %>/hqdefault.jpg?sqp=-oaymwEbCKgBEF5IVfKriqkDDggBFQAAiEIYAXABwAEG&rs=AOn4CLBy_x4UUHLNDZtJtH0PXeQGoRFTgw');">
                  <span class="video-length"><%- turntomins(x.lengthSeconds) %></span>
                </div>

                <div class="info">
                  <span class="title max-lines-2" title="<%- x.title %>"><%- x.title %></span>
                  <span class="byline max-lines-2" title="Video By <%- x.author %>">By <%- x.author %></span>
                </div>
              </a>
            <% }) %>
          </div>
        </div>
      </div>

      <div class="discover-empty">The trending gaming videos section is hidden.</div>
    </details>
  </div>
</div>

<script>
(function () {
  var section = document.getElementById("discover-section");
  var button = document.getElementById("discover-toggle");
  var storageKey = "poke_discover_videos_open";

  if (!section || !button) return;

  function setButtonState() {
    var isOpen = section.hasAttribute("open");
    button.textContent = isOpen ? "Hide videos" : "Show videos";
    button.setAttribute("aria-expanded", isOpen ? "true" : "false");
  }

  function saveState() {
    try {
      localStorage.setItem(storageKey, section.hasAttribute("open") ? "1" : "0");
    } catch (e) {}
  }

  try {
    var saved = localStorage.getItem(storageKey);
    if (saved === "0") {
      section.removeAttribute("open");
    } else if (saved === "1") {
      section.setAttribute("open", "");
    }
  } catch (e) {}

  setButtonState();

  button.addEventListener("click", function () {
    if (section.hasAttribute("open")) {
      section.removeAttribute("open");
    } else {
      section.setAttribute("open", "");
    }
    setButtonState();
    saveState();
  });

  section.addEventListener("toggle", function () {
    setButtonState();
    saveState();
  });
})();
</script>

</body>
</html>